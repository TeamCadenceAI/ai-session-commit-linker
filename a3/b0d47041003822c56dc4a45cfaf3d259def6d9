{"parentUuid":"7bdb78bb-2b63-44a2-a5d2-4b21bc3fff2e","isSidechain":false,"userType":"external","cwd":"/Users/daveslutzkin/dev/ai-session-commit-linker","sessionId":"ef9bee41-7d77-42f2-bd83-e5ef1170bd43","version":"2.1.38","gitBranch":"main","slug":"federated-crafting-crane","type":"progress","data":{"message":{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DgW6qc43YoLxbhxJh1YfN9","type":"tool_result","content":"     1→//! Session scanning and correlation.\n     2→//!\n     3→//! Scans candidate session log files (JSONL) to find commit hashes,\n     4→//! then parses minimal metadata and verifies the match against the\n     5→//! git repository.\n     6→//!\n     7→//! The core invariant: \"If an AI agent created a commit, the commit hash\n     8→//! appears verbatim in the session log.\" This module implements that\n     9→//! search by streaming files line-by-line (never loading entire files\n    10→//! into memory) and doing substring matching for the full hash and\n    11→//! the short hash (first 7 characters).\n    12→\n    13→use std::fs::File;\n    14→use std::io::{BufRead, BufReader};\n    15→use std::path::{Path, PathBuf};\n    16→\n    17→// ---------------------------------------------------------------------------\n    18→// Types\n    19→// ---------------------------------------------------------------------------\n    20→\n    21→/// The type of AI agent that produced a session log.\n    22→#[derive(Debug, Clone, PartialEq, Eq)]\n    23→pub enum AgentType {\n    24→    Claude,\n    25→    Codex,\n    26→}\n    27→\n    28→impl std::fmt::Display for AgentType {\n    29→    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {\n    30→        match self {\n    31→            AgentType::Claude => write!(f, \"claude-code\"),\n    32→            AgentType::Codex => write!(f, \"codex\"),\n    33→        }\n    34→    }\n    35→}\n    36→\n    37→/// A successful match: a candidate file contains a commit hash.\n    38→#[derive(Debug, Clone)]\n    39→pub struct SessionMatch {\n    40→    /// Path to the session log file that contained the commit hash.\n    41→    pub file_path: PathBuf,\n    42→    /// The agent type, inferred from the file path.\n    43→    pub agent_type: AgentType,\n    44→}\n    45→\n    46→/// Minimal metadata parsed from a session log file.\n    47→///\n    48→/// Not every field is guaranteed to be present -- session logs vary\n    49→/// in structure. Fields are `Option` to handle missing data gracefully.\n    50→#[derive(Debug, Clone, Default)]\n    51→pub struct SessionMetadata {\n    52→    /// The session ID (UUID or similar identifier).\n    53→    pub session_id: Option<String>,\n    54→    /// The working directory where the agent was running.\n    55→    pub cwd: Option<String>,\n    56→    /// The agent type, if determinable from the log content.\n    57→    pub agent_type: Option<AgentType>,\n    58→}\n    59→\n    60→// ---------------------------------------------------------------------------\n    61→// Public API\n    62→// ---------------------------------------------------------------------------\n    63→\n    64→/// Search candidate files for a line containing the given commit hash.\n    65→///\n    66→/// Streams each file line-by-line using `BufReader` to avoid loading\n    67→/// entire files into memory. Checks each line for:\n    68→/// - The full 40-character commit hash (substring match)\n    69→/// - The short hash (first 7 characters, substring match)\n    70→///\n    71→/// Returns `Some(SessionMatch)` on the first match found across all\n    72→/// candidate files. Returns `None` if no files contain the hash.\n    73→///\n    74→/// The agent type is inferred from the file path:\n    75→/// - If the path contains `.claude` -> Claude\n    76→/// - If the path contains `.codex` -> Codex\n    77→/// - Otherwise defaults to Claude (conservative fallback)\n    78→pub fn find_session_for_commit(\n    79→    commit_hash: &str,\n    80→    candidate_files: &[PathBuf],\n    81→) -> Option<SessionMatch> {\n    82→    // Reject invalid commit hashes: must be 7-40 hex characters.\n    83→    // An empty or short string would cause `line.contains(\"\")` to return true\n    84→    // for every line, producing universal false positives. Non-hex strings\n    85→    // can never be valid commit hashes.\n    86→    if crate::git::validate_commit_hash(commit_hash).is_err() {\n    87→        return None;\n    88→    }\n    89→\n    90→    let short_hash = &commit_hash[..7];\n    91→\n    92→    for file_path in candidate_files {\n    93→        let file = match File::open(file_path) {\n    94→            Ok(f) => f,\n    95→            Err(_) => continue,\n    96→        };\n    97→\n    98→        let reader = BufReader::new(file);\n    99→\n   100→        for line in reader.lines() {\n   101→            let line = match line {\n   102→                Ok(l) => l,\n   103→                Err(_) => continue,\n   104→            };\n   105→\n   106→            // Check for full hash first (more specific), then short hash\n   107→            if line.contains(commit_hash) || line.contains(short_hash) {\n   108→                let agent_type = infer_agent_type(file_path);\n   109→                return Some(SessionMatch {\n   110→                    file_path: file_path.clone(),\n   111→                    agent_type,\n   112→                });\n   113→            }\n   114→        }\n   115→    }\n   116→\n   117→    None\n   118→}\n   119→\n   120→/// Parse minimal metadata from a session log file.\n   121→///\n   122→/// Reads the file line-by-line, attempting to parse each line as JSON\n   123→/// and extracting known fields:\n   124→/// - `session_id` (or `sessionId`)\n   125→/// - `cwd` (or `workdir`, `working_directory`)\n   126→/// - `type` field that may indicate the agent\n   127→///\n   128→/// This is best-effort: not every line will be valid JSON, and not\n   129→/// every JSON line will contain the fields we need. The function\n   130→/// accumulates fields across all lines, with first-value-wins semantics\n   131→/// (once a field is found, later occurrences are ignored).\n   132→pub fn parse_session_metadata(file: &Path) -> SessionMetadata {\n   133→    let mut metadata = SessionMetadata::default();\n   134→\n   135→    let file_handle = match File::open(file) {\n   136→        Ok(f) => f,\n   137→        Err(_) => return metadata,\n   138→    };\n   139→\n   140→    let reader = BufReader::new(file_handle);\n   141→\n   142→    for line in reader.lines() {\n   143→        let line = match line {\n   144→            Ok(l) => l,\n   145→            Err(_) => continue,\n   146→        };\n   147→\n   148→        // Attempt to parse as JSON\n   149→        let value: serde_json::Value = match serde_json::from_str(&line) {\n   150→            Ok(v) => v,\n   151→            Err(_) => continue,\n   152→        };\n   153→\n   154→        // Extract session_id\n   155→        if metadata.session_id.is_none()\n   156→            && let Some(id) = value\n   157→                .get(\"session_id\")\n   158→                .or_else(|| value.get(\"sessionId\"))\n   159→                .and_then(|v| v.as_str())\n   160→        {\n   161→            metadata.session_id = Some(id.to_string());\n   162→        }\n   163→\n   164→        // Extract cwd / workdir\n   165→        if metadata.cwd.is_none()\n   166→            && let Some(cwd) = value\n   167→                .get(\"cwd\")\n   168→                .or_else(|| value.get(\"workdir\"))\n   169→                .or_else(|| value.get(\"working_directory\"))\n   170→                .and_then(|v| v.as_str())\n   171→        {\n   172→            metadata.cwd = Some(cwd.to_string());\n   173→        }\n   174→\n   175→        // If we have both fields, stop early\n   176→        if metadata.session_id.is_some() && metadata.cwd.is_some() {\n   177→            break;\n   178→        }\n   179→    }\n   180→\n   181→    // Infer agent type from file path\n   182→    metadata.agent_type = Some(infer_agent_type(file));\n   183→\n   184→    metadata\n   185→}\n   186→\n   187→/// Verify that a session match is valid for a given repository and commit.\n   188→///\n   189→/// Checks two conditions:\n   190→/// 1. The `cwd` from the session metadata resolves to the same git repo\n   191→///    root as the target repository.\n   192→/// 2. The commit exists in that repository.\n   193→///\n   194→/// Returns `false` if any check fails or if the cwd is not available\n   195→/// in the metadata.\n   196→pub fn verify_match(metadata: &SessionMetadata, repo_root: &Path, commit: &str) -> bool {\n   197→    // Validate commit hash before passing to git commands.\n   198→    if crate::git::validate_commit_hash(commit).is_err() {\n   199→        return false;\n   200→    }\n   201→\n   202→    let cwd = match &metadata.cwd {\n   203→        Some(c) => c,\n   204→        None => return false,\n   205→    };\n   206→\n   207→    let cwd_path = Path::new(cwd);\n   208→\n   209→    // Check 1: cwd resolves to the same git repo root\n   210→    match crate::git::repo_root_at(cwd_path) {\n   211→        Ok(cwd_repo_root) => {\n   212→            // Canonicalize both paths for comparison to handle symlinks\n   213→            let canonical_repo = match repo_root.canonicalize() {\n   214→                Ok(p) => p,\n   215→                Err(_) => repo_root.to_path_buf(),\n   216→            };\n   217→            let canonical_cwd_repo = match cwd_repo_root.canonicalize() {\n   218→                Ok(p) => p,\n   219→                Err(_) => cwd_repo_root,\n   220→            };\n   221→            if canonical_repo != canonical_cwd_repo {\n   222→                return false;\n   223→            }\n   224→        }\n   225→        Err(_) => return false,\n   226→    }\n   227→\n   228→    // Check 2: commit exists in the repo\n   229→    crate::git::commit_exists_at(repo_root, commit).unwrap_or_default()\n   230→}\n   231→\n   232→/// Extract commit hashes from git commit confirmation output in a session log.\n   233→///\n   234→/// Looks specifically for the `[branch HASH]` pattern that git outputs when\n   235→/// a commit is created (e.g., `[main abcdef0] Fix bug`). This targets only\n   236→/// commits actually made during the session, avoiding false positives from\n   237→/// git log, git diff, UUIDs, and other hex strings.\n   238→///\n   239→/// Returns a deduplicated `Vec<String>` of extracted hashes (lowercased).\n   240→/// Returns an empty Vec on any I/O error.\n   241→pub fn extract_commit_hashes(file: &Path) -> Vec<String> {\n   242→    let file_handle = match File::open(file) {\n   243→        Ok(f) => f,\n   244→        Err(_) => return Vec::new(),\n   245→    };\n   246→\n   247→    let reader = BufReader::new(file_handle);\n   248→    let mut hashes = Vec::new();\n   249→    let mut seen = std::collections::HashSet::new();\n   250→\n   251→    for line in reader.lines() {\n   252→        let line = match line {\n   253→            Ok(l) => l,\n   254→            Err(_) => continue,\n   255→        };\n   256→\n   257→        extract_hashes_from_line(&line, &mut hashes, &mut seen);\n   258→    }\n   259→\n   260→    hashes\n   261→}\n   262→\n   263→/// Extract commit hashes from `[branch HASH]` patterns in a single line.\n   264→///\n   265→/// Matches the git commit confirmation format: `[branch_name hash]` where\n   266→/// `branch_name` can contain word chars, `/`, `.`, and `-`, and `hash` is\n   267→/// 7-40 hex characters.\n   268→fn extract_hashes_from_line(\n   269→    line: &str,\n   270→    hashes: &mut Vec<String>,\n   271→    seen: &mut std::collections::HashSet<String>,\n   272→) {\n   273→    // Match `[branch hash]` pattern from git commit output.\n   274→    // The branch name can contain word chars, /, ., - (e.g., feature/foo-bar).\n   275→    // The hash is 7-40 hex characters.\n   276→    let bytes = line.as_bytes();\n   277→    let len = bytes.len();\n   278→    let mut i = 0;\n   279→\n   280→    while i < len {\n   281→        // Look for '['\n   282→        if bytes[i] != b'[' {\n   283→            i += 1;\n   284→            continue;\n   285→        }\n   286→        i += 1; // skip '['\n   287→\n   288→        // Parse branch name: [\\w/.#-]+ (at least 1 char)\n   289→        let branch_start = i;\n   290→        while i < len\n   291→            && (bytes[i].is_ascii_alphanumeric()\n   292→                || bytes[i] == b'/'\n   293→                || bytes[i] == b'.'\n   294→                || bytes[i] == b'-'\n   295→                || bytes[i] == b'_'\n   296→                || bytes[i] == b'#')\n   297→        {\n   298→            i += 1;\n   299→        }\n   300→        if i == branch_start {\n   301→            // No branch name chars found\n   302→            continue;\n   303→        }\n   304→\n   305→        // Expect a space between branch name and hash\n   306→        if i >= len || bytes[i] != b' ' {\n   307→            continue;\n   308→        }\n   309→        i += 1; // skip space\n   310→\n   311→        // Parse hex hash: 7-40 hex chars\n   312→        let hash_start = i;\n   313→        while i < len && bytes[i].is_ascii_hexdigit() {\n   314→            i += 1;\n   315→        }\n   316→        let hash_len = i - hash_start;\n   317→        if !(7..=40).contains(&hash_len) {\n   318→            continue;\n   319→        }\n   320→\n   321→        // Expect ']' after hash\n   322→        if i >= len || bytes[i] != b']' {\n   323→            continue;\n   324→        }\n   325→\n   326→        let hash = line[hash_start..hash_start + hash_len].to_ascii_lowercase();\n   327→        if seen.insert(hash.clone()) {\n   328→            hashes.push(hash);\n   329→        }\n   330→\n   331→        i += 1; // skip ']'\n   332→    }\n   333→}\n   334→\n   335→// ---------------------------------------------------------------------------\n   336→// Internal helpers\n   337→// ---------------------------------------------------------------------------\n   338→\n   339→/// Infer the agent type from a file path.\n   340→///\n   341→/// - If path contains `.claude` -> Claude\n   342→/// - If path contains `.codex` -> Codex\n   343→/// - Otherwise -> Claude (conservative default)\n   344→fn infer_agent_type(path: &Path) -> AgentType {\n   345→    let path_str = path.to_string_lossy();\n   346→    if path_str.contains(\".codex\") {\n   347→        AgentType::Codex\n   348→    } else {\n   349→        // Default to Claude -- `.claude` paths and unknown paths\n   350→        AgentType::Claude\n   351→    }\n   352→}\n   353→\n   354→// ---------------------------------------------------------------------------\n   355→// Tests\n   356→// ---------------------------------------------------------------------------\n   357→\n   358→#[cfg(test)]\n   359→mod tests {\n   360→    use super::*;\n   361→    use std::fs;\n   362→    use std::process::Command;\n   363→    use tempfile::TempDir;\n   364→\n   365→    // -----------------------------------------------------------------------\n   366→    // Helper: create a temp file with given content\n   367→    // -----------------------------------------------------------------------\n   368→\n   369→    fn write_temp_file(dir: &Path, name: &str, content: &str) -> PathBuf {\n   370→        let path = dir.join(name);\n   371→        fs::write(&path, content).expect(\"failed to write temp file\");\n   372→        path\n   373→    }\n   374→\n   375→    // -----------------------------------------------------------------------\n   376→    // infer_agent_type\n   377→    // -----------------------------------------------------------------------\n   378→\n   379→    #[test]\n   380→    fn test_infer_agent_type_claude() {\n   381→        let path = Path::new(\"/Users/foo/.claude/projects/-Users-foo-bar/session.jsonl\");\n   382→        assert_eq!(infer_agent_type(path), AgentType::Claude);\n   383→    }\n   384→\n   385→    #[test]\n   386→    fn test_infer_agent_type_codex() {\n   387→        let path = Path::new(\"/Users/foo/.codex/sessions/abc123/session.jsonl\");\n   388→        assert_eq!(infer_agent_type(path), AgentType::Codex);\n   389→    }\n   390→\n   391→    #[test]\n   392→    fn test_infer_agent_type_unknown_defaults_to_claude() {\n   393→        let path = Path::new(\"/tmp/some/random/session.jsonl\");\n   394→        assert_eq!(infer_agent_type(path), AgentType::Claude);\n   395→    }\n   396→\n   397→    // -----------------------------------------------------------------------\n   398→    // AgentType display\n   399→    // -----------------------------------------------------------------------\n   400→\n   401→    #[test]\n   402→    fn test_agent_type_display_claude() {\n   403→        assert_eq!(AgentType::Claude.to_string(), \"claude-code\");\n   404→    }\n   405→\n   406→    #[test]\n   407→    fn test_agent_type_display_codex() {\n   408→        assert_eq!(AgentType::Codex.to_string(), \"codex\");\n   409→    }\n   410→\n   411→    // -----------------------------------------------------------------------\n   412→    // find_session_for_commit — full hash match\n   413→    // -----------------------------------------------------------------------\n   414→\n   415→    #[test]\n   416→    fn test_find_session_full_hash_match() {\n   417→        let dir = TempDir::new().unwrap();\n   418→        let commit_hash = \"abcdef0123456789abcdef0123456789abcdef01\";\n   419→\n   420→        // Create a JSONL file with a line containing the full hash\n   421→        let content =\n   422→            format!(r#\"{{\"type\":\"tool_result\",\"content\":\"Created commit {commit_hash}\"}}\"#,);\n   423→        let file = write_temp_file(\n   424→            dir.path(),\n   425→            \"session.jsonl\",\n   426→            &format!(\"{}\\n{{\\\"type\\\":\\\"other\\\"}}\\n\", content),\n   427→        );\n   428→\n   429→        let result = find_session_for_commit(commit_hash, &[file.clone()]);\n   430→\n   431→        assert!(result.is_some());\n   432→        let m = result.unwrap();\n   433→        assert_eq!(m.file_path, file);\n   434→    }\n   435→\n   436→    // -----------------------------------------------------------------------\n   437→    // find_session_for_commit — short hash match\n   438→    // -----------------------------------------------------------------------\n   439→\n   440→    #[test]\n   441→    fn test_find_session_short_hash_match() {\n   442→        let dir = TempDir::new().unwrap();\n   443→        let commit_hash = \"abcdef0123456789abcdef0123456789abcdef01\";\n   444→        let short_hash = &commit_hash[..7]; // \"abcdef0\"\n   445→\n   446→        // Only the short hash appears in the line\n   447→        let content = format!(r#\"{{\"type\":\"tool_result\",\"content\":\"Committed {short_hash}\"}}\"#,);\n   448→        let file = write_temp_file(dir.path(), \"session.jsonl\", &content);\n   449→\n   450→        let result = find_session_for_commit(commit_hash, &[file]);\n   451→\n   452→        assert!(result.is_some());\n   453→        let m = result.unwrap();\n   454→        assert_eq!(m.agent_type, AgentType::Claude);\n   455→    }\n   456→\n   457→    // -----------------------------------------------------------------------\n   458→    // find_session_for_commit — no match\n   459→    // -----------------------------------------------------------------------\n   460→\n   461→    #[test]\n   462→    fn test_find_session_no_match() {\n   463→        let dir = TempDir::new().unwrap();\n   464→        let commit_hash = \"abcdef0123456789abcdef0123456789abcdef01\";\n   465→\n   466→        // File with unrelated content\n   467→        let file = write_temp_file(\n   468→            dir.path(),\n   469→            \"session.jsonl\",\n   470→            \"{\\\"type\\\":\\\"message\\\"}\\n{\\\"type\\\":\\\"other\\\"}\\n\",\n   471→        );\n   472→\n   473→        let result = find_session_for_commit(commit_hash, &[file]);\n   474→\n   475→        assert!(result.is_none());\n   476→    }\n   477→\n   478→    // -----------------------------------------------------------------------\n   479→    // find_session_for_commit — stops on first match\n   480→    // -----------------------------------------------------------------------\n   481→\n   482→    #[test]\n   483→    fn test_find_session_stops_on_first_file_match() {\n   484→        let dir = TempDir::new().unwrap();\n   485→        let commit_hash = \"abcdef0123456789abcdef0123456789abcdef01\";\n   486→\n   487→        // First file has the match\n   488→        let file1 = write_temp_file(\n   489→            dir.path(),\n   490→            \"first.jsonl\",\n   491→            &format!(r#\"{{\"content\":\"commit {commit_hash}\"}}\"#),\n   492→        );\n   493→        // Second file also has a match (should not be reached)\n   494→        let file2 = write_temp_file(\n   495→            dir.path(),\n   496→            \"second.jsonl\",\n   497→            &format!(r#\"{{\"content\":\"commit {commit_hash}\"}}\"#),\n   498→        );\n   499→\n   500→        let result = find_session_for_commit(commit_hash, &[file1.clone(), file2]);\n   501→\n   502→        assert!(result.is_some());\n   503→        assert_eq!(result.unwrap().file_path, file1);\n   504→    }\n   505→\n   506→    // -----------------------------------------------------------------------\n   507→    // find_session_for_commit — multiple files, match in second\n   508→    // -----------------------------------------------------------------------\n   509→\n   510→    #[test]\n   511→    fn test_find_session_match_in_second_file() {\n   512→        let dir = TempDir::new().unwrap();\n   513→        let commit_hash = \"abcdef0123456789abcdef0123456789abcdef01\";\n   514→\n   515→        // First file has no match\n   516→        let file1 = write_temp_file(\n   517→            dir.path(),\n   518→            \"no-match.jsonl\",\n   519→            \"{\\\"type\\\":\\\"message\\\",\\\"content\\\":\\\"hello\\\"}\\n\",\n   520→        );\n   521→        // Second file has the match\n   522→        let file2 = write_temp_file(\n   523→            dir.path(),\n   524→            \"has-match.jsonl\",\n   525→            &format!(r#\"{{\"content\":\"Created commit {commit_hash}\"}}\"#),\n   526→        );\n   527→\n   528→        let result = find_session_for_commit(commit_hash, &[file1, file2.clone()]);\n   529→\n   530→        assert!(result.is_some());\n   531→        assert_eq!(result.unwrap().file_path, file2);\n   532→    }\n   533→\n   534→    // -----------------------------------------------------------------------\n   535→    // find_session_for_commit — empty candidate list\n   536→    // -----------------------------------------------------------------------\n   537→\n   538→    #[test]\n   539→    fn test_find_session_empty_candidates() {\n   540→        let commit_hash = \"abcdef0123456789abcdef0123456789abcdef01\";\n   541→        let result = find_session_for_commit(commit_hash, &[]);\n   542→        assert!(result.is_none());\n   543→    }\n   544→\n   545→    // -----------------------------------------------------------------------\n   546→    // find_session_for_commit — nonexistent file is skipped gracefully\n   547→    // -----------------------------------------------------------------------\n   548→\n   549→    #[test]\n   550→    fn test_find_session_nonexistent_file_skipped() {\n   551→        let commit_hash = \"abcdef0123456789abcdef0123456789abcdef01\";\n   552→        let nonexistent = PathBuf::from(\"/nonexistent/file.jsonl\");\n   553→        let result = find_session_for_commit(commit_hash, &[nonexistent]);\n   554→        assert!(result.is_none());\n   555→    }\n   556→\n   557→    // -----------------------------------------------------------------------\n   558→    // find_session_for_commit — agent type from path\n   559→    // -----------------------------------------------------------------------\n   560→\n   561→    #[test]\n   562→    fn test_find_session_agent_type_claude_from_path() {\n   563→        let dir = TempDir::new().unwrap();\n   564→        let commit_hash = \"abcdef0123456789abcdef0123456789abcdef01\";\n   565→\n   566→        // Put the file under a .claude directory\n   567→        let claude_dir = dir.path().join(\".claude\").join(\"projects\");\n   568→        fs::create_dir_all(&claude_dir).unwrap();\n   569→        let file = write_temp_file(\n   570→            &claude_dir,\n   571→            \"session.jsonl\",\n   572→            &format!(r#\"{{\"content\":\"{commit_hash}\"}}\"#),\n   573→        );\n   574→\n   575→        let result = find_session_for_commit(commit_hash, &[file]);\n   576→\n   577→        assert!(result.is_some());\n   578→        assert_eq!(result.unwrap().agent_type, AgentType::Claude);\n   579→    }\n   580→\n   581→    #[test]\n   582→    fn test_find_session_agent_type_codex_from_path() {\n   583→        let dir = TempDir::new().unwrap();\n   584→        let commit_hash = \"abcdef0123456789abcdef0123456789abcdef01\";\n   585→\n   586→        // Put the file under a .codex directory\n   587→        let codex_dir = dir.path().join(\".codex\").join(\"sessions\");\n   588→        fs::create_dir_all(&codex_dir).unwrap();\n   589→        let file = write_temp_file(\n   590→            &codex_dir,\n   591→            \"session.jsonl\",\n   592→            &format!(r#\"{{\"content\":\"{commit_hash}\"}}\"#),\n   593→        );\n   594→\n   595→        let result = find_session_for_commit(commit_hash, &[file]);\n   596→\n   597→        assert!(result.is_some());\n   598→        assert_eq!(result.unwrap().agent_type, AgentType::Codex);\n   599→    }\n   600→\n   601→    // -----------------------------------------------------------------------\n   602→    // find_session_for_commit — hash embedded in complex JSONL\n   603→    // -----------------------------------------------------------------------\n   604→\n   605→    #[test]\n   606→    fn test_find_session_hash_in_realistic_jsonl() {\n   607→        let dir = TempDir::new().unwrap();\n   608→        let commit_hash = \"655dd38a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e\";\n   609→\n   610→        // Simulate realistic Claude Code JSONL output\n   611→        let content = format!(\n   612→            r#\"{{\"type\":\"assistant\",\"message\":\"I'll commit this now\"}}\n   613→{{\"type\":\"tool_use\",\"name\":\"Bash\",\"input\":{{\"command\":\"git add . && git commit -m \\\"fix bug\\\"\"}}}}\n   614→{{\"type\":\"tool_result\",\"content\":\"[main {short_hash}] fix bug\\n 1 file changed, 2 insertions(+)\"}}\n   615→{{\"type\":\"assistant\",\"message\":\"Done! The commit has been created.\"}}\n   616→\"#,\n   617→            short_hash = &commit_hash[..7],\n   618→        );\n   619→        let file = write_temp_file(dir.path(), \"session.jsonl\", &content);\n   620→\n   621→        let result = find_session_for_commit(commit_hash, &[file]);\n   622→\n   623→        assert!(result.is_some());\n   624→    }\n   625→\n   626→    // -----------------------------------------------------------------------\n   627→    // find_session_for_commit — hash that partially matches but shouldn't\n   628→    // -----------------------------------------------------------------------\n   629→\n   630→    #[test]\n   631→    fn test_find_session_partial_hash_no_false_positive() {\n   632→        let dir = TempDir::new().unwrap();\n   633→        // Full hash starts with \"abcdef0...\"\n   634→        let commit_hash = \"abcdef0123456789abcdef0123456789abcdef01\";\n   635→\n   636→        // File contains \"abcdef\" (6 chars -- shorter than 7-char short hash)\n   637→        // This should NOT match because we check for 7-char short hash\n   638→        let content = r#\"{\"content\":\"the string abcdef appears here\"}\"#;\n   639→        let file = write_temp_file(dir.path(), \"session.jsonl\", content);\n   640→\n   641→        let result = find_session_for_commit(commit_hash, &[file]);\n   642→\n   643→        // \"abcdef\" is only 6 chars, our short hash is \"abcdef0\" (7 chars).\n   644→        // The line does not contain \"abcdef0\", so no match.\n   645→        assert!(result.is_none());\n   646→    }\n   647→\n   648→    // -----------------------------------------------------------------------\n   649→    // find_session_for_commit — short/empty hash rejected\n   650→    // -----------------------------------------------------------------------\n   651→\n   652→    #[test]\n   653→    fn test_find_session_empty_hash_returns_none() {\n   654→        let dir = TempDir::new().unwrap();\n   655→        // A file where every line would match an empty string\n   656→        let file = write_temp_file(\n   657→            dir.path(),\n   658→            \"session.jsonl\",\n   659→            \"{\\\"type\\\":\\\"message\\\",\\\"content\\\":\\\"hello\\\"}\\n\",\n   660→        );\n   661→\n   662→        let result = find_session_for_commit(\"\", &[file]);\n   663→        assert!(result.is_none());\n   664→    }\n   665→\n   666→    #[test]\n   667→    fn test_find_session_short_hash_returns_none() {\n   668→        let dir = TempDir::new().unwrap();\n   669→        let file = write_temp_file(\n   670→            dir.path(),\n   671→            \"session.jsonl\",\n   672→            \"{\\\"content\\\":\\\"abcdef something\\\"}\\n\",\n   673→        );\n   674→\n   675→        // 6-char hash is too short, should be rejected\n   676→        let result = find_session_for_commit(\"abcdef\", &[file]);\n   677→        assert!(result.is_none());\n   678→    }\n   679→\n   680→    // -----------------------------------------------------------------------\n   681→    // parse_session_metadata\n   682→    // -----------------------------------------------------------------------\n   683→\n   684→    #[test]\n   685→    fn test_parse_metadata_session_id_and_cwd() {\n   686→        let dir = Tem