{"parentUuid":"4fa3a3f7-3f2a-403c-ae41-60d050df0f73","isSidechain":false,"userType":"external","cwd":"/Users/daveslutzkin/dev/ai-session-commit-linker","sessionId":"ef9bee41-7d77-42f2-bd83-e5ef1170bd43","version":"2.1.38","gitBranch":"main","slug":"federated-crafting-crane","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RFFGEk3PnDgvaecRueLR2Q","type":"tool_result","content":"     1→//! Session scanning and correlation.\n     2→//!\n     3→//! Scans candidate session log files (JSONL) to find commit hashes,\n     4→//! then parses minimal metadata and verifies the match against the\n     5→//! git repository.\n     6→//!\n     7→//! The core invariant: \"If an AI agent created a commit, the commit hash\n     8→//! appears verbatim in the session log.\" This module implements that\n     9→//! search by streaming files line-by-line (never loading entire files\n    10→//! into memory) and doing substring matching for the full hash and\n    11→//! the short hash (first 7 characters).\n    12→\n    13→use std::fs::File;\n    14→use std::io::{BufRead, BufReader};\n    15→use std::path::{Path, PathBuf};\n    16→\n    17→// ---------------------------------------------------------------------------\n    18→// Types\n    19→// ---------------------------------------------------------------------------\n    20→\n    21→/// The type of AI agent that produced a session log.\n    22→#[derive(Debug, Clone, PartialEq, Eq)]\n    23→pub enum AgentType {\n    24→    Claude,\n    25→    Codex,\n    26→}\n    27→\n    28→impl std::fmt::Display for AgentType {\n    29→    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {\n    30→        match self {\n    31→            AgentType::Claude => write!(f, \"claude-code\"),\n    32→            AgentType::Codex => write!(f, \"codex\"),\n    33→        }\n    34→    }\n    35→}\n    36→\n    37→/// A successful match: a candidate file contains a commit hash.\n    38→#[derive(Debug, Clone)]\n    39→pub struct SessionMatch {\n    40→    /// Path to the session log file that contained the commit hash.\n    41→    pub file_path: PathBuf,\n    42→    /// The agent type, inferred from the file path.\n    43→    pub agent_type: AgentType,\n    44→}\n    45→\n    46→/// Minimal metadata parsed from a session log file.\n    47→///\n    48→/// Not every field is guaranteed to be present -- session logs vary\n    49→/// in structure. Fields are `Option` to handle missing data gracefully.\n    50→#[derive(Debug, Clone, Default)]\n    51→pub struct SessionMetadata {\n    52→    /// The session ID (UUID or similar identifier).\n    53→    pub session_id: Option<String>,\n    54→    /// The working directory where the agent was running.\n    55→    pub cwd: Option<String>,\n    56→    /// The agent type, if determinable from the log content.\n    57→    pub agent_type: Option<AgentType>,\n    58→}\n    59→\n    60→// ---------------------------------------------------------------------------\n    61→// Public API\n    62→// ---------------------------------------------------------------------------\n    63→\n    64→/// Search candidate files for a line containing the given commit hash.\n    65→///\n    66→/// Streams each file line-by-line using `BufReader` to avoid loading\n    67→/// entire files into memory. Checks each line for:\n    68→/// - The full 40-character commit hash (substring match)\n    69→/// - The short hash (first 7 characters, substring match)\n    70→///\n    71→/// Returns `Some(SessionMatch)` on the first match found across all\n    72→/// candidate files. Returns `None` if no files contain the hash.\n    73→///\n    74→/// The agent type is inferred from the file path:\n    75→/// - If the path contains `.claude` -> Claude\n    76→/// - If the path contains `.codex` -> Codex\n    77→/// - Otherwise defaults to Claude (conservative fallback)\n    78→pub fn find_session_for_commit(\n    79→    commit_hash: &str,\n    80→    candidate_files: &[PathBuf],\n    81→) -> Option<SessionMatch> {\n    82→    // Reject invalid commit hashes: must be 7-40 hex characters.\n    83→    // An empty or short string would cause `line.contains(\"\")` to return true\n    84→    // for every line, producing universal false positives. Non-hex strings\n    85→    // can never be valid commit hashes.\n    86→    if crate::git::validate_commit_hash(commit_hash).is_err() {\n    87→        return None;\n    88→    }\n    89→\n    90→    let short_hash = &commit_hash[..7];\n    91→\n    92→    for file_path in candidate_files {\n    93→        let file = match File::open(file_path) {\n    94→            Ok(f) => f,\n    95→            Err(_) => continue,\n    96→        };\n    97→\n    98→        let reader = BufReader::new(file);\n    99→\n   100→        for line in reader.lines() {\n   101→            let line = match line {\n   102→                Ok(l) => l,\n   103→                Err(_) => continue,\n   104→            };\n   105→\n   106→            // Check for full hash first (more specific), then short hash\n   107→            if line.contains(commit_hash) || line.contains(short_hash) {\n   108→                let agent_type = infer_agent_type(file_path);\n   109→                return Some(SessionMatch {\n   110→                    file_path: file_path.clone(),\n   111→                    agent_type,\n   112→                });\n   113→            }\n   114→        }\n   115→    }\n   116→\n   117→    None\n   118→}\n   119→\n   120→/// Parse minimal metadata from a session log file.\n   121→///\n   122→/// Reads the file line-by-line, attempting to parse each line as JSON\n   123→/// and extracting known fields:\n   124→/// - `session_id` (or `sessionId`)\n   125→/// - `cwd` (or `workdir`, `working_directory`)\n   126→/// - `type` field that may indicate the agent\n   127→///\n   128→/// This is best-effort: not every line will be valid JSON, and not\n   129→/// every JSON line will contain the fields we need. The function\n   130→/// accumulates fields across all lines, with first-value-wins semantics\n   131→/// (once a field is found, later occurrences are ignored).\n   132→pub fn parse_session_metadata(file: &Path) -> SessionMetadata {\n   133→    let mut metadata = SessionMetadata::default();\n   134→\n   135→    let file_handle = match File::open(file) {\n   136→        Ok(f) => f,\n   137→        Err(_) => return metadata,\n   138→    };\n   139→\n   140→    let reader = BufReader::new(file_handle);\n   141→\n   142→    for line in reader.lines() {\n   143→        let line = match line {\n   144→            Ok(l) => l,\n   145→            Err(_) => continue,\n   146→        };\n   147→\n   148→        // Attempt to parse as JSON\n   149→        let value: serde_json::Value = match serde_json::from_str(&line) {\n   150→            Ok(v) => v,\n   151→            Err(_) => continue,\n   152→        };\n   153→\n   154→        // Extract session_id\n   155→        if metadata.session_id.is_none()\n   156→            && let Some(id) = value\n   157→                .get(\"session_id\")\n   158→                .or_else(|| value.get(\"sessionId\"))\n   159→                .and_then(|v| v.as_str())\n   160→        {\n   161→            metadata.session_id = Some(id.to_string());\n   162→        }\n   163→\n   164→        // Extract cwd / workdir\n   165→        if metadata.cwd.is_none()\n   166→            && let Some(cwd) = value\n   167→                .get(\"cwd\")\n   168→                .or_else(|| value.get(\"workdir\"))\n   169→                .or_else(|| value.get(\"working_directory\"))\n   170→                .and_then(|v| v.as_str())\n   171→        {\n   172→            metadata.cwd = Some(cwd.to_string());\n   173→        }\n   174→\n   175→        // If we have both fields, stop early\n   176→        if metadata.session_id.is_some() && metadata.cwd.is_some() {\n   177→            break;\n   178→        }\n   179→    }\n   180→\n   181→    // Infer agent type from file path\n   182→    metadata.agent_type = Some(infer_agent_type(file));\n   183→\n   184→    metadata\n   185→}\n   186→\n   187→/// Verify that a session match is valid for a given repository and commit.\n   188→///\n   189→/// Checks two conditions:\n   190→/// 1. The `cwd` from the session metadata resolves to the same git repo\n   191→///    root as the target repository.\n   192→/// 2. The commit exists in that repository.\n   193→///\n   194→/// Returns `false` if any check fails or if the cwd is not available\n   195→/// in the metadata.\n   196→pub fn verify_match(metadata: &SessionMetadata, repo_root: &Path, commit: &str) -> bool {\n   197→    // Validate commit hash before passing to git commands.\n   198→    if crate::git::validate_commit_hash(commit).is_err() {\n   199→        return false;\n   200→    }\n   201→\n   202→    let cwd = match &metadata.cwd {\n   203→        Some(c) => c,\n   204→        None => return false,\n   205→    };\n   206→\n   207→    let cwd_path = Path::new(cwd);\n   208→\n   209→    // Check 1: cwd resolves to the same git repo root\n   210→    match crate::git::repo_root_at(cwd_path) {\n   211→        Ok(cwd_repo_root) => {\n   212→            // Canonicalize both paths for comparison to handle symlinks\n   213→            let canonical_repo = match repo_root.canonicalize() {\n   214→                Ok(p) => p,\n   215→                Err(_) => repo_root.to_path_buf(),\n   216→            };\n   217→            let canonical_cwd_repo = match cwd_repo_root.canonicalize() {\n   218→                Ok(p) => p,\n   219→                Err(_) => cwd_repo_root,\n   220→            };\n   221→            if canonical_repo != canonical_cwd_repo {\n   222→                return false;\n   223→            }\n   224→        }\n   225→        Err(_) => return false,\n   226→    }\n   227→\n   228→    // Check 2: commit exists in the repo\n   229→    crate::git::commit_exists_at(repo_root, commit).unwrap_or_default()\n   230→}\n   231→\n   232→/// Extract commit hashes from git commit confirmation output in a session log.\n   233→///\n   234→/// Looks specifically for the `[branch HASH]` pattern that git outputs when\n   235→/// a commit is created (e.g., `[main abcdef0] Fix bug`). This targets only\n   236→/// commits actually made during the session, avoiding false positives from\n   237→/// git log, git diff, UUIDs, and other hex strings.\n   238→///\n   239→/// Returns a deduplicated `Vec<String>` of extracted hashes (lowercased).\n   240→/// Returns an empty Vec on any I/O error.\n   241→pub fn extract_commit_hashes(file: &Path) -> Vec<String> {\n   242→    let file_handle = match File::open(file) {\n   243→        Ok(f) => f,\n   244→        Err(_) => return Vec::new(),\n   245→    };\n   246→\n   247→    let reader = BufReader::new(file_handle);\n   248→    let mut hashes = Vec::new();\n   249→    let mut seen = std::collections::HashSet::new();\n   250→\n   251→    for line in reader.lines() {\n   252→        let line = match line {\n   253→            Ok(l) => l,\n   254→            Err(_) => continue,\n   255→        };\n   256→\n   257→        extract_hashes_from_line(&line, &mut hashes, &mut seen);\n   258→    }\n   259→\n   260→    hashes\n   261→}\n   262→\n   263→/// Extract commit hashes from `[branch HASH]` patterns in a single line.\n   264→///\n   265→/// Matches the git commit confirmation format: `[branch_name hash]` where\n   266→/// `branch_name` can contain word chars, `/`, `.`, and `-`, and `hash` is\n   267→/// 7-40 hex characters.\n   268→fn extract_hashes_from_line(\n   269→    line: &str,\n   270→    hashes: &mut Vec<String>,\n   271→    seen: &mut std::collections::HashSet<String>,\n   272→) {\n   273→    // Match `[branch hash]` pattern from git commit output.\n   274→    // The branch name can contain word chars, /, ., - (e.g., feature/foo-bar).\n   275→    // The hash is 7-40 hex characters.\n   276→    let bytes = line.as_bytes();\n   277→    let len = bytes.len();\n   278→    let mut i = 0;\n   279→\n   280→    while i < len {\n   281→        // Look for '['\n   282→        if bytes[i] != b'[' {\n   283→            i += 1;\n   284→            continue;\n   285→        }\n   286→        i += 1; // skip '['\n   287→\n   288→        // Parse branch name: [\\w/.#-]+ (at least 1 char)\n   289→        let branch_start = i;\n   290→        while i < len\n   291→            && (bytes[i].is_ascii_alphanumeric()\n   292→                || bytes[i] == b'/'\n   293→                || bytes[i] == b'.'\n   294→                || bytes[i] == b'-'\n   295→                || bytes[i] == b'_'\n   296→                || bytes[i] == b'#')\n   297→        {\n   298→            i += 1;\n   299→        }\n   300→        if i == branch_start {\n   301→            // No branch name chars found\n   302→            continue;\n   303→        }\n   304→\n   305→        // Expect a space between branch name and hash\n   306→        if i >= len || bytes[i] != b' ' {\n   307→            continue;\n   308→        }\n   309→        i += 1; // skip space\n   310→\n   311→        // Parse hex hash: 7-40 hex chars\n   312→        let hash_start = i;\n   313→        while i < len && bytes[i].is_ascii_hexdigit() {\n   314→            i += 1;\n   315→        }\n   316→        let hash_len = i - hash_start;\n   317→        if !(7..=40).contains(&hash_len) {\n   318→            continue;\n   319→        }\n   320→\n   321→        // Expect ']' after hash\n   322→        if i >= len || bytes[i] != b']' {\n   323→            continue;\n   324→        }\n   325→\n   326→        let hash = line[hash_start..hash_start + hash_len].to_ascii_lowercase();\n   327→        if seen.insert(hash.clone()) {\n   328→            hashes.push(hash);\n   329→        }\n   330→\n   331→        i += 1; // skip ']'\n   332→    }\n   333→}\n   334→\n   335→// ---------------------------------------------------------------------------\n   336→// Internal helpers\n   337→// ---------------------------------------------------------------------------\n   338→\n   339→/// Infer the agent type from a file path.\n   340→///\n   341→/// - If path contains `.claude` -> Claude\n   342→/// - If path contains `.codex` -> Codex\n   343→/// - Otherwise -> Claude (conservative default)\n   344→fn infer_agent_type(path: &Path) -> AgentType {\n   345→    let path_str = path.to_string_lossy();\n   346→    if path_str.contains(\".codex\") {\n   347→        AgentType::Codex\n   348→    } else {\n   349→        // Default to Claude -- `.claude` paths and unknown paths\n   350→        AgentType::Claude\n   351→    }\n   352→}\n   353→\n   354→// ---------------------------------------------------------------------------\n   355→// Tests\n   356→// ---------------------------------------------------------------------------\n   357→\n   358→#[cfg(test)]\n   359→mod tests {\n   360→    use super::*;\n   361→    use std::fs;\n   362→    use std::process::Command;\n   363→    use tempfile::TempDir;\n   364→\n   365→    // -----------------------------------------------------------------------\n   366→    // Helper: create a temp file with given content\n   367→    // -----------------------------------------------------------------------\n   368→\n   369→    fn write_temp_file(dir: &Path, name: &str, content: &str) -> PathBuf {\n   370→        let path = dir.join(name);\n   371→        fs::write(&path, content).expect(\"failed to write temp file\");\n   372→        path\n   373→    }\n   374→\n   375→    // -----------------------------------------------------------------------\n   376→    // infer_agent_type\n   377→    // -----------------------------------------------------------------------\n   378→\n   379→    #[test]\n   380→    fn test_infer_agent_type_claude() {\n   381→        let path = Path::new(\"/Users/foo/.claude/projects/-Users-foo-bar/session.jsonl\");\n   382→        assert_eq!(infer_agent_type(path), AgentType::Claude);\n   383→    }\n   384→\n   385→    #[test]\n   386→    fn test_infer_agent_type_codex() {\n   387→        let path = Path::new(\"/Users/foo/.codex/sessions/abc123/session.jsonl\");\n   388→        assert_eq!(infer_agent_type(path), AgentType::Codex);\n   389→    }\n   390→\n   391→    #[test]\n   392→    fn test_infer_agent_type_unknown_defaults_to_claude() {\n   393→        let path = Path::new(\"/tmp/some/random/session.jsonl\");\n   394→        assert_eq!(infer_agent_type(path), AgentType::Claude);\n   395→    }\n   396→\n   397→    // -----------------------------------------------------------------------\n   398→    // AgentType display\n   399→    // -----------------------------------------------------------------------\n   400→\n   401→    #[test]\n   402→    fn test_agent_type_display_claude() {\n   403→        assert_eq!(AgentType::Claude.to_string(), \"claude-code\");\n   404→    }\n   405→\n   406→    #[test]\n   407→    fn test_agent_type_display_codex() {\n   408→        assert_eq!(AgentType::Codex.to_string(), \"codex\");\n   409→    }\n   410→\n   411→    // -----------------------------------------------------------------------\n   412→    // find_session_for_commit — full hash match\n   413→    // -----------------------------------------------------------------------\n   414→\n   415→    #[test]\n   416→    fn test_find_session_full_hash_match() {\n   417→        let dir = TempDir::new().unwrap();\n   418→        let commit_hash = \"abcdef0123456789abcdef0123456789abcdef01\";\n   419→\n   420→        // Create a JSONL file with a line containing the full hash\n   421→        let content =\n   422→            format!(r#\"{{\"type\":\"tool_result\",\"content\":\"Created commit {commit_hash}\"}}\"#,);\n   423→        let file = write_temp_file(\n   424→            dir.path(),\n   425→            \"session.jsonl\",\n   426→            &format!(\"{}\\n{{\\\"type\\\":\\\"other\\\"}}\\n\", content),\n   427→        );\n   428→\n   429→        let result = find_session_for_commit(commit_hash, &[file.clone()]);\n   430→\n   431→        assert!(result.is_some());\n   432→        let m = result.unwrap();\n   433→        assert_eq!(m.file_path, file);\n   434→    }\n   435→\n   436→    // -----------------------------------------------------------------------\n   437→    // find_session_for_commit — short hash match\n   438→    // -----------------------------------------------------------------------\n   439→\n   440→    #[test]\n   441→    fn test_find_session_short_hash_match() {\n   442→        let dir = TempDir::new().unwrap();\n   443→        let commit_hash = \"abcdef0123456789abcdef0123456789abcdef01\";\n   444→        let short_hash = &commit_hash[..7]; // \"abcdef0\"\n   445→\n   446→        // Only the short hash appears in the line\n   447→        let content = format!(r#\"{{\"type\":\"tool_result\",\"content\":\"Committed {short_hash}\"}}\"#,);\n   448→        let file = write_temp_file(dir.path(), \"session.jsonl\", &content);\n   449→\n   450→        let result = find_session_for_commit(commit_hash, &[file]);\n   451→\n   452→        assert!(result.is_some());\n   453→        let m = result.unwrap();\n   454→        assert_eq!(m.agent_type, AgentType::Claude);\n   455→    }\n   456→\n   457→    // -----------------------------------------------------------------------\n   458→    // find_session_for_commit — no match\n   459→    // -----------------------------------------------------------------------\n   460→\n   461→    #[test]\n   462→    fn test_find_session_no_match() {\n   463→        let dir = TempDir::new().unwrap();\n   464→        let commit_hash = \"abcdef0123456789abcdef0123456789abcdef01\";\n   465→\n   466→        // File with unrelated content\n   467→        let file = write_temp_file(\n   468→            dir.path(),\n   469→            \"session.jsonl\",\n   470→            \"{\\\"type\\\":\\\"message\\\"}\\n{\\\"type\\\":\\\"other\\\"}\\n\",\n   471→        );\n   472→\n   473→        let result = find_session_for_commit(commit_hash, &[file]);\n   474→\n   475→        assert!(result.is_none());\n   476→    }\n   477→\n   478→    // -----------------------------------------------------------------------\n   479→    // find_session_for_commit — stops on first match\n   480→    // -----------------------------------------------------------------------\n   481→\n   482→    #[test]\n   483→    fn test_find_session_stops_on_first_file_match() {\n   484→        let dir = TempDir::new().unwrap();\n   485→        let commit_hash = \"abcdef0123456789abcdef0123456789abcdef01\";\n   486→\n   487→        // First file has the match\n   488→        let file1 = write_temp_file(\n   489→            dir.path(),\n   490→            \"first.jsonl\",\n   491→            &format!(r#\"{{\"content\":\"commit {commit_hash}\"}}\"#),\n   492→        );\n   493→        // Second file also has a match (should not be reached)\n   494→        let file2 = write_temp_file(\n   495→            dir.path(),\n   496→            \"second.jsonl\",\n   497→            &format!(r#\"{{\"content\":\"commit {commit_hash}\"}}\"#),\n   498→        );\n   499→\n   500→        let result = find_session_for_commit(commit_hash, &[file1.clone(), file2]);\n   501→\n   502→        assert!(result.is_some());\n   503→        assert_eq!(result.unwrap().file_path, file1);\n   504→    }\n   505→\n   506→    // -----------------------------------------------------------------------\n   507→    // find_session_for_commit — multiple files, match in second\n   508→    // -----------------------------------------------------------------------\n   509→\n   510→    #[test]\n   511→    fn test_find_session_match_in_second_file() {\n   512→        let dir = TempDir::new().unwrap();\n   513→        let commit_hash = \"abcdef0123456789abcdef0123456789abcdef01\";\n   514→\n   515→        // First file has no match\n   516→        let file1 = write_temp_file(\n   517→            dir.path(),\n   518→            \"no-match.jsonl\",\n   519→            \"{\\\"type\\\":\\\"message\\\",\\\"content\\\":\\\"hello\\\"}\\n\",\n   520→        );\n   521→        // Second file has the match\n   522→        let file2 = write_temp_file(\n   523→            dir.path(),\n   524→            \"has-match.jsonl\",\n   525→            &format!(r#\"{{\"content\":\"Created commit {commit_hash}\"}}\"#),\n   526→        );\n   527→\n   528→        let result = find_session_for_commit(commit_hash, &[file1, file2.clone()]);\n   529→\n   530→        assert!(result.is_some());\n   531→        assert_eq!(result.unwrap().file_path, file2);\n   532→    }\n   533→\n   534→    // -----------------------------------------------------------------------\n   535→    // find_session_for_commit — empty candidate list\n   536→    // -----------------------------------------------------------------------\n   537→\n   538→    #[test]\n   539→    fn test_find_session_empty_candidates() {\n   540→        let commit_hash = \"abcdef0123456789abcdef0123456789abcdef01\";\n   541→        let result = find_session_for_commit(commit_hash, &[]);\n   542→        assert!(result.is_none());\n   543→    }\n   544→\n   545→    // -----------------------------------------------------------------------\n   546→    // find_session_for_commit — nonexistent file is skipped gracefully\n   547→    // -----------------------------------------------------------------------\n   548→\n   549→    #[test]\n   550→    fn test_find_session_nonexistent_file_skipped() {\n   551→        let commit_hash = \"abcdef0123456789abcdef0123456789abcdef01\";\n   552→        let nonexistent = PathBuf::from(\"/nonexistent/file.jsonl\");\n   553→        let result = find_session_for_commit(commit_hash, &[nonexistent]);\n   554→        assert!(result.is_none());\n   555→    }\n   556→\n   557→    // -----------------------------------------------------------------------\n   558→    // find_session_for_commit — agent type from path\n   559→    // -----------------------------------------------------------------------\n   560→\n   561→    #[test]\n   562→    fn test_find_session_agent_type_claude_from_path() {\n   563→        let dir = TempDir::new().unwrap();\n   564→        let commit_hash = \"abcdef0123456789abcdef0123456789abcdef01\";\n   565→\n   566→        // Put the file under a .claude directory\n   567→        let claude_dir = dir.path().join(\".claude\").join(\"projects\");\n   568→        fs::create_dir_all(&claude_dir).unwrap();\n   569→        let file = write_temp_file(\n   570→            &claude_dir,\n   571→            \"session.jsonl\",\n   572→            &format!(r#\"{{\"content\":\"{commit_hash}\"}}\"#),\n   573→        );\n   574→\n   575→        let result = find_session_for_commit(commit_hash, &[file]);\n   576→\n   577→        assert!(result.is_some());\n   578→        assert_eq!(result.unwrap().agent_type, AgentType::Claude);\n   579→    }\n   580→\n   581→    #[test]\n   582→    fn test_find_session_agent_type_codex_from_path() {\n   583→        let dir = TempDir::new().unwrap();\n   584→        let commit_hash = \"abcdef0123456789abcdef0123456789abcdef01\";\n   585→\n   586→        // Put the file under a .codex directory\n   587→        let codex_dir = dir.path().join(\".codex\").join(\"sessions\");\n   588→        fs::create_dir_all(&codex_dir).unwrap();\n   589→        let file = write_temp_file(\n   590→            &codex_dir,\n   591→            \"session.jsonl\",\n   592→            &format!(r#\"{{\"content\":\"{commit_hash}\"}}\"#),\n   593→        );\n   594→\n   595→        let result = find_session_for_commit(commit_hash, &[file]);\n   596→\n   597→        assert!(result.is_some());\n   598→        assert_eq!(result.unwrap().agent_type, AgentType::Codex);\n   599→    }\n   600→\n   601→    // -----------------------------------------------------------------------\n   602→    // find_session_for_commit — hash embedded in complex JSONL\n   603→    // -----------------------------------------------------------------------\n   604→\n   605→    #[test]\n   606→    fn test_find_session_hash_in_realistic_jsonl() {\n   607→        let dir = TempDir::new().unwrap();\n   608→        let commit_hash = \"655dd38a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e\";\n   609→\n   610→        // Simulate realistic Claude Code JSONL output\n   611→        let content = format!(\n   612→            r#\"{{\"type\":\"assistant\",\"message\":\"I'll commit this now\"}}\n   613→{{\"type\":\"tool_use\",\"name\":\"Bash\",\"input\":{{\"command\":\"git add . && git commit -m \\\"fix bug\\\"\"}}}}\n   614→{{\"type\":\"tool_result\",\"content\":\"[main {short_hash}] fix bug\\n 1 file changed, 2 insertions(+)\"}}\n   615→{{\"type\":\"assistant\",\"message\":\"Done! The commit has been created.\"}}\n   616→\"#,\n   617→            short_hash = &commit_hash[..7],\n   618→        );\n   619→        let file = write_temp_file(dir.path(), \"session.jsonl\", &content);\n   620→\n   621→        let result = find_session_for_commit(commit_hash, &[file]);\n   622→\n   623→        assert!(result.is_some());\n   624→    }\n   625→\n   626→    // -----------------------------------------------------------------------\n   627→    // find_session_for_commit — hash that partially matches but shouldn't\n   628→    // -----------------------------------------------------------------------\n   629→\n   630→    #[test]\n   631→    fn test_find_session_partial_hash_no_false_positive() {\n   632→        let dir = TempDir::new().unwrap();\n   633→        // Full hash starts with \"abcdef0...\"\n   634→        let commit_hash = \"abcdef0123456789abcdef0123456789abcdef01\";\n   635→\n   636→        // File contains \"abcdef\" (6 chars -- shorter than 7-char short hash)\n   637→        // This should NOT match because we check for 7-char short hash\n   638→        let content = r#\"{\"content\":\"the string abcdef appears here\"}\"#;\n   639→        let file = write_temp_file(dir.path(), \"session.jsonl\", content);\n   640→\n   641→        let result = find_session_for_commit(commit_hash, &[file]);\n   642→\n   643→        // \"abcdef\" is only 6 chars, our short hash is \"abcdef0\" (7 chars).\n   644→        // The line does not contain \"abcdef0\", so no match.\n   645→        assert!(result.is_none());\n   646→    }\n   647→\n   648→    // -----------------------------------------------------------------------\n   649→    // find_session_for_commit — short/empty hash rejected\n   650→    // -----------------------------------------------------------------------\n   651→\n   652→    #[test]\n   653→    fn test_find_session_empty_hash_returns_none() {\n   654→        let dir = TempDir::new().unwrap();\n   655→        // A file where every line would match an empty string\n   656→        let file = write_temp_file(\n   657→            dir.path(),\n   658→            \"session.jsonl\",\n   659→            \"{\\\"type\\\":\\\"message\\\",\\\"content\\\":\\\"hello\\\"}\\n\",\n   660→        );\n   661→\n   662→        let result = find_session_for_commit(\"\", &[file]);\n   663→        assert!(result.is_none());\n   664→    }\n   665→\n   666→    #[test]\n   667→    fn test_find_session_short_hash_returns_none() {\n   668→        let dir = TempDir::new().unwrap();\n   669→        let file = write_temp_file(\n   670→            dir.path(),\n   671→            \"session.jsonl\",\n   672→            \"{\\\"content\\\":\\\"abcdef something\\\"}\\n\",\n   673→        );\n   674→\n   675→        // 6-char hash is too short, should be rejected\n   676→        let result = find_session_for_commit(\"abcdef\", &[file]);\n   677→        assert!(result.is_none());\n   678→    }\n   679→\n   680→    // -----------------------------------------------------------------------\n   681→    // parse_session_metadata\n   682→    // -----------------------------------------------------------------------\n   683→\n   684→    #[test]\n   685→    fn test_parse_metadata_session_id_and_cwd() {\n   686→        let dir = TempDir::new().unwrap();\n   687→        let content = r#\"{\"session_id\":\"abc-123\",\"cwd\":\"/Users/foo/bar\"}\n   688→{\"type\":\"message\",\"content\":\"hello\"}\n   689→\"#;\n   690→        let file = write_temp_file(dir.path(), \"session.jsonl\", content);\n   691→\n   692→        let metadata = parse_session_metadata(&file);\n   693→\n   694→        assert_eq!(metadata.session_id, Some(\"abc-123\".to_string()));\n   695→        assert_eq!(metadata.cwd, Some(\"/Users/foo/bar\".to_string()));\n   696→    }\n   697→\n   698→    #[test]\n   699→    fn test_parse_metadata_camel_case_session_id() {\n   700→        let dir = TempDir::new().unwrap();\n   701→        let content = r#\"{\"sessionId\":\"def-456\",\"cwd\":\"/Users/baz\"}\"#;\n   702→        let file = write_temp_file(dir.path(), \"session.jsonl\", content);\n   703→\n   704→        let metadata = parse_session_metadata(&file);\n   705→\n   706→        assert_eq!(metadata.session_id, Some(\"def-456\".to_string()));\n   707→    }\n   708→\n   709→    #[test]\n   710→    fn test_parse_metadata_workdir_field() {\n   711→        let dir = TempDir::new().unwrap();\n   712→        let content = r#\"{\"workdir\":\"/home/user/project\"}\"#;\n   713→        let file = write_temp_file(dir.path(), \"session.jsonl\", content);\n   714→\n   715→        let metadata = parse_session_metadata(&file);\n   716→\n   717→        assert_eq!(metadata.cwd, Some(\"/home/user/project\".to_string()));\n   718→    }\n   719→\n   720→    #[test]\n   721→    fn test_parse_metadata_working_directory_field() {\n   722→        let dir = TempDir::new().unwrap();\n   723→        let content = r#\"{\"working_directory\":\"/opt/app\"}\"#;\n   724→        let file = write_temp_file(dir.path(), \"session.jsonl\", content);\n   725→\n   726→        let metadata = parse_session_metadata(&file);\n   727→\n   728→        assert_eq!(metadata.cwd, Some(\"/opt/app\".to_string()));\n   729→    }\n   730→\n   731→    #[test]\n   732→    fn test_parse_metadata_fields_across_multiple_lines() {\n   733→        let dir = TempDir::new().unwrap();\n   734→        // session_id on one line, cwd on another\n   735→        let content = r#\"{\"session_id\":\"multi-line-id\"}\n   736→{\"type\":\"other\"}\n   737→{\"cwd\":\"/Users/foo/repo\"}\n   738→\"#;\n   739→        let file = write_temp_file(dir.path(), \"session.jsonl\", content);\n   740→\n   741→        let metadata = parse_session_metadata(&file);\n   742→\n   743→        assert_eq!(metadata.session_id, Some(\"multi-line-id\".to_string()));\n   744→        assert_eq!(metadata.cwd, Some(\"/Users/foo/repo\".to_string()));\n   745→    }\n   746→\n   747→    #[test]\n   748→    fn test_parse_metadata_no_fields() {\n   749→        let dir = TempDir::new().unwrap();\n   750→        let content = r#\"{\"type\":\"message\",\"content\":\"no metadata here\"}\n   751→{\"type\":\"tool_result\",\"content\":\"more stuff\"}\n   752→\"#;\n   753→        let file = write_temp_file(dir.path(), \"session.jsonl\", content);\n   754→\n   755→        let metadata = parse_session_metadata(&file);\n   756→\n   757→        assert_eq!(metadata.session_id, None);\n   758→        assert_eq!(metadata.cwd, None);\n   759→    }\n   760→\n   761→    #[test]\n   762→    fn test_parse_metadata_invalid_json_lines_skipped() {\n   763→        let dir = TempDir::new().unwrap();\n   764→        let content = r#\"this is not json\n   765→{\"session_id\":\"valid-id\"}\n   766→also not json {{{{\n   767→{\"cwd\":\"/valid/path\"}\n   768→\"#;\n   769→        let file = write_temp_file(dir.path(), \"session.jsonl\", content);\n   770→\n   771→        let metadata = parse_session_metadata(&file);\n   772→\n   773→        assert_eq!(metadata.session_id, Some(\"valid-id\".to_string()));\n   774→        assert_eq!(metadata.cwd, Some(\"/valid/path\".to_string()));\n   775→    }\n   776→\n   777→    #[test]\n   778→    fn test_parse_metadata_empty_file() {\n   779→        let dir = TempDir::new().unwrap();\n   780→        let file = write_temp_file(dir.path(), \"empty.jsonl\", \"\");\n   781→\n   782→        let metadata = parse_session_metadata(&file);\n   783→\n   784→        assert_eq!(metadata.session_id, None);\n   785→        assert_eq!(metadata.cwd, None);\n   786→    }\n   787→\n   788→    #[test]\n   789→    fn test_parse_metadata_nonexistent_file() {\n   790→        let path = Path::new(\"/nonexistent/file.jsonl\");\n   791→        let metadata = parse_session_metadata(path);\n   792→\n   793→        assert_eq!(metadata.session_id, None);\n   794→        assert_eq!(metadata.cwd, None);\n   795→    }\n   796→\n   797→    #[test]\n   798→    fn test_parse_metadata_agent_type_from_claude_path() {\n   799→        let dir = TempDir::new().unwrap();\n   800→        let claude_dir = dir.path().join(\".claude\").join(\"projects\");\n   801→        fs::create_dir_all(&claude_dir).unwrap();\n   802→        let file = write_temp_file(&claude_dir, \"session.jsonl\", \"{}\");\n   803→\n   804→        let metadata = parse_session_metadata(&file);\n   805→\n   806→        assert_eq!(metadata.agent_type, Some(AgentType::Claude));\n   807→    }\n   808→\n   809→    #[test]\n   810→    fn test_parse_metadata_agent_type_from_codex_path() {\n   811→        let dir = TempDir::new().unwrap();\n   812→        let codex_dir = dir.path().join(\".codex\").join(\"sessions\");\n   813→        fs::create_dir_all(&codex_dir).unwrap();\n   814→        let file = write_temp_file(&codex_dir, \"session.jsonl\", \"{}\");\n   815→\n   816→        let metadata = parse_session_metadata(&file);\n   817→\n   818→        assert_eq!(metadata.agent_type, Some(AgentType::Codex));\n   819→    }\n   820→\n   821→    #[test]\n   822→    fn test_parse_metadata_first_value_wins() {\n   823→        let dir = TempDir::new().unwrap();\n   824→        // Two lines with session_id -- first should win\n   825→        let content = r#\"{\"session_id\":\"first-id\"}\n   826→{\"session_id\":\"second-id\"}\n   827→\"#;\n   828→        let file = write_temp_file(dir.path(), \"session.jsonl\", content);\n   829→\n   830→        let metadata = parse_session_metadata(&file);\n   831→\n   832→        assert_eq!(metadata.session_id, Some(\"first-id\".to_string()));\n   833→    }\n   834→\n   835→    // -----------------------------------------------------------------------\n   836→    // verify_match — requires real git repos, run serially\n   837→    // -----------------------------------------------------------------------\n   838→\n   839→    /// Helper: create a temp git repo with one commit, return (TempDir, commit_hash).\n   840→    fn init_temp_repo() -> (TempDir, String) {\n   841→        let dir = TempDir::new().expect(\"failed to create temp dir\");\n   842→        let path = dir.path();\n   843→\n   844→        run_git(path, &[\"init\"]);\n   845→        run_git(path, &[\"config\", \"user.email\", \"test@test.com\"]);\n   846→        run_git(path, &[\"config\", \"user.name\", \"Test User\"]);\n   847→        // Override hooksPath to prevent the global post-commit hook from firing\n   848→        run_git(path, &[\"config\", \"core.hooksPath\", \"/dev/null\"]);\n   849→        fs::write(path.join(\"README.md\"), \"hello\").unwrap();\n   850→        run_git(path, &[\"add\", \"README.md\"]);\n   851→        run_git(path, &[\"commit\", \"-m\", \"initial commit\"]);\n   852→\n   853→        let hash = run_git(path, &[\"rev-parse\", \"HEAD\"]);\n   854→        (dir, hash)\n   855→    }\n   856→\n   857→    fn run_git(dir: &Path, args: &[&str]) -> String {\n   858→        let output = Command::new(\"git\")\n   859→            .args([\"-C\", dir.to_str().unwrap()])\n   860→            .args(args)\n   861→            .output()\n   862→            .expect(\"failed to run git\");\n   863→        if !output.status.success() {\n   864→            let stderr = String::from_utf8_lossy(&output.stderr);\n   865→            panic!(\"git {:?} failed: {}\", args, stderr);\n   866→        }\n   867→        String::from_utf8(output.stdout).unwrap().trim().to_string()\n   868→    }\n   869→\n   870→    #[test]\n   871→    fn test_verify_match_same_repo() {\n   872→        let (dir, commit_hash) = init_temp_repo();\n   873→        let repo_root = dir.path().to_path_buf();\n   874→\n   875→        let metadata = SessionMetadata {\n   876→            session_id: Some(\"test-session\".to_string()),\n   877→            cwd: Some(dir.path().to_string_lossy().to_string()),\n   878→            agent_type: Some(AgentType::Claude),\n   879→        };\n   880→\n   881→        assert!(verify_match(&metadata, &repo_root, &commit_hash));\n   882→    }\n   883→\n   884→    #[test]\n   885→    fn test_verify_match_missing_cwd() {\n   886→        let (dir, commit_hash) = init_temp_repo();\n   887→        let repo_root = dir.path().to_path_buf();\n   888→\n   889→        let metadata = SessionMetadata {\n   890→            session_id: Some(\"test-session\".to_string()),\n   891→            cwd: None,\n   892→            agent_type: Some(AgentType::Claude),\n   893→        };\n   894→\n   895→        assert!(!verify_match(&metadata, &repo_root, &commit_hash));\n   896→    }\n   897→\n   898→    #[test]\n   899→    fn test_verify_match_different_repo() {\n   900→        let (dir1, commit_hash) = init_temp_repo();\n   901→        let (dir2, _) = init_temp_repo();\n   902→\n   903→        let metadata = SessionMetadata {\n   904→            session_id: Some(\"test-session\".to_string()),\n   905→            // cwd points to dir2 but we're checking against dir1\n   906→            cwd: Some(dir2.path().to_string_lossy().to_string()),\n   907→            agent_type: Some(AgentType::Claude),\n   908→        };\n   909→\n   910→        assert!(!verify_match(\n   911→            &metadata,\n   912→            &dir1.path().to_path_buf(),\n   913→            &commit_hash\n   914→        ));\n   915→    }\n   916→\n   917→    #[test]\n   918→    fn test_verify_match_nonexistent_cwd() {\n   919→        let (dir, commit_hash) = init_temp_repo();\n   920→        let repo_root = dir.path().to_path_buf();\n   921→\n   922→        let metadata = SessionMetadata {\n   923→            session_id: Some(\"test-session\".to_string()),\n   924→            cwd: Some(\"/nonexistent/path/that/does/not/exist\".to_string()),\n   925→            agent_type: Some(AgentType::Claude),\n   926→        };\n   927→\n   928→        assert!(!verify_match(&metadata, &repo_root, &commit_hash));\n   929→    }\n   930→\n   931→    #[test]\n   932→    fn test_verify_match_nonexistent_commit() {\n   933→        let (dir, _) = init_temp_repo();\n   934→        let repo_root = dir.path().to_path_buf();\n   935→        let fake_commit = \"0000000000000000000000000000000000000000\";\n   936→\n   937→        let metadata = SessionMetadata {\n   938→            session_id: Some(\"test-session\".to_string()),\n   939→            cwd: Some(dir.path().to_string_lossy().to_string()),\n   940→            agent_type: Some(AgentType::Claude),\n   941→        };\n   942→\n   943→        assert!(!verify_match(&metadata, &repo_root, fake_commit));\n   944→    }\n   945→\n   946→    #[test]\n   947→    fn test_verify_match_cwd_in_subdirectory() {\n   948→        let (dir, commit_hash) = init_temp_repo();\n   949→        let repo_root = dir.path().to_path_buf();\n   950→\n   951→        // Create a subdirectory inside the repo\n   952→        let subdir = dir.path().join(\"src\");\n   953→        fs::create_dir(&subdir).unwrap();\n   954→\n   955→        let metadata = SessionMetadata {\n   956→            session_id: Some(\"test-session\".to_string()),\n   957→            // cwd is a subdirectory of the repo -- should still resolve to same repo root\n   958→            cwd: Some(subdir.to_string_lossy().to_string()),\n   959→            agent_type: Some(AgentType::Claude),\n   960→        };\n   961→\n   962→        assert!(verify_match(&metadata, &repo_root, &commit_hash));\n   963→    }\n   964→\n   965→    // -----------------------------------------------------------------------\n   966→    // extract_commit_hashes\n   967→    // -----------------------------------------------------------------------\n   968→\n   969→    #[test]\n   970→    fn test_extract_commit_hashes_finds_short_hash() {\n   971→        let dir = TempDir::new().unwrap();\n   972→        let content = r#\"{\"content\":\"[main abcdef0] fix bug\"}\"#;\n   973→        let file = write_temp_file(dir.path(), \"session.jsonl\", &content);\n   974→\n   975→        let hashes = extract_commit_hashes(&file);\n   976→        assert_eq!(hashes.len(), 1);\n   977→        assert_eq!(hashes[0], \"abcdef0\");\n   978→    }\n   979→\n   980→    #[test]\n   981→    fn test_extract_commit_hashes_finds_full_hash() {\n   982→        let dir = TempDir::new().unwrap();\n   983→        let hash = \"abcdef0123456789abcdef0123456789abcdef01\";\n   984→        let content = format!(r#\"{{\"content\":\"[main {hash}] fix bug\"}}\"#);\n   985→        let file = write_temp_file(dir.path(), \"session.jsonl\", &content);\n   986→\n   987→        let hashes = extract_commit_hashes(&file);\n   988→        assert_eq!(hashes.len(), 1);\n   989→        assert_eq!(hashes[0], hash);\n   990→    }\n   991→\n   992→    #[test]\n   993→    fn test_extract_commit_hashes_finds_multiple() {\n   994→        let dir = TempDir::new().unwrap();\n   995→        let content = r#\"{\"content\":\"[main abcdef0] first commit\"}\n   996→{\"content\":\"[main 1234567] second commit\"}\n   997→\"#;\n   998→        let file = write_temp_file(dir.path(), \"session.jsonl\", &content);\n   999→\n  1000→        let hashes = extract_commit_hashes(&file);\n  1001→        assert_eq!(hashes.len(), 2);\n  1002→        assert!(hashes.contains(&\"abcdef0\".to_string()));\n  1003→        assert!(hashes.contains(&\"1234567\".to_string()));\n  1004→    }\n  1005→\n  1006→    #[test]\n  1007→    fn test_extract_commit_hashes_deduplicates() {\n  1008→        let dir = TempDir::new().unwrap();\n  1009→        let content = r#\"{\"content\":\"[main abcdef0] fix bug\"}\n  1010→{\"content\":\"[main abcdef0] fix bug\"}\n  1011→\"#;\n  1012→        let file = write_temp_file(dir.path(), \"session.jsonl\", &content);\n  1013→\n  1014→        let hashes = extract_commit_hashes(&file);\n  1015→        assert_eq!(hashes.len(), 1);\n  1016→    }\n  1017→\n  1018→    #[test]\n  1019→    fn test_extract_commit_hashes_no_hashes() {\n  1020→        let dir = TempDir::new().unwrap();\n  1021→        let content = r#\"{\"type\":\"message\",\"content\":\"hello world\"}\"#;\n  1022→        let file = write_temp_file(dir.path(), \"session.jsonl\", content);\n  1023→\n  1024→        let hashes = extract_commit_hashes(&file);\n  1025→        assert!(hashes.is_empty());\n  1026→    }\n  1027→\n  1028→    #[test]\n  1029→    fn test_extract_commit_hashes_ignores_bare_hex() {\n  1030→        let dir = TempDir::new().unwrap();\n  1031→        // Bare hex strings (e.g., from git log) should NOT be extracted\n  1032→        let content = r#\"{\"content\":\"abcdef0 Fix something\"}\"#;\n  1033→        let file = write_temp_file(dir.path(), \"session.jsonl\", content);\n  1034→\n  1035→        let hashes = extract_commit_hashes(&file);\n  1036→        assert!(hashes.is_empty());\n  1037→    }\n  1038→\n  1039→    #[test]\n  1040→    fn test_extract_commit_hashes_ignores_diff_blob_hashes() {\n  1041→        let dir = TempDir::new().unwrap();\n  1042→        // Diff index lines should NOT match\n  1043→        let content = r#\"{\"content\":\"index c84f8ba..b145f18 100644\"}\"#;\n  1044→        let file = write_temp_file(dir.path(), \"session.jsonl\", content);\n  1045→\n  1046→        let hashes = extract_commit_hashes(&file);\n  1047→        assert!(hashes.is_empty());\n  1048→    }\n  1049→\n  1050→    #[test]\n  1051→    fn test_extract_commit_hashes_ignores_too_short_hex() {\n  1052→        let dir = TempDir::new().unwrap();\n  1053→        // 6-char hash in bracket pattern -- below minimum\n  1054→        let content = r#\"{\"content\":\"[main abcdef] fix bug\"}\"#;\n  1055→        let file = write_temp_file(dir.path(), \"session.jsonl\", content);\n  1056→\n  1057→        let hashes = extract_commit_hashes(&file);\n  1058→        assert!(hashes.is_empty());\n  1059→    }\n  1060→\n  1061→    #[test]\n  1062→    fn test_extract_commit_hashes_uppercase_lowered() {\n  1063→        let dir = TempDir::new().unwrap();\n  1064→        let content = r#\"{\"content\":\"[main ABCDEF0] fix bug\"}\"#;\n  1065→        let file = write_temp_file(dir.path(), \"session.jsonl\", content);\n  1066→\n  1067→        let hashes = extract_commit_hashes(&file);\n  1068→        assert_eq!(hashes.len(), 1);\n  1069→        assert_eq!(hashes[0], \"abcdef0\");\n  1070→    }\n  1071→\n  1072→    #[test]\n  1073→    fn test_extract_commit_hashes_feature_branch() {\n  1074→        let dir = TempDir::new().unwrap();\n  1075→        // Branch names with slashes and dashes\n  1076→        let content = r#\"{\"content\":\"[feature/foo-bar abcdef0] fix bug\"}\"#;\n  1077→        let file = write_temp_file(dir.path(), \"session.jsonl\", content);\n  1078→\n  1079→        let hashes = extract_commit_hashes(&file);\n  1080→        assert_eq!(hashes.len(), 1);\n  1081→        assert_eq!(hashes[0], \"abcdef0\");\n  1082→    }\n  1083→\n  1084→    #[test]\n  1085→    fn test_extract_commit_hashes_nonexistent_file() {\n  1086→        let path = Path::new(\"/nonexistent/file.jsonl\");\n  1087→        let hashes = extract_commit_hashes(path);\n  1088→        assert!(hashes.is_empty());\n  1089→    }\n  1090→\n  1091→    #[test]\n  1092→    fn test_extract_commit_hashes_empty_file() {\n  1093→        let dir = TempDir::new().unwrap();\n  1094→        let file = write_temp_file(dir.path(), \"empty.jsonl\", \"\");\n  1095→\n  1096→        let hashes = extract_commit_hashes(&file);\n  1097→        assert!(hashes.is_empty());\n  1098→    }\n  1099→\n  1100→    #[test]\n  1101→    fn test_extract_commit_hashes_realistic_session_log() {\n  1102→        let dir = TempDir::new().unwrap();\n  1103→        let content = r#\"{\"type\":\"assistant\",\"message\":\"I'll commit now\"}\n  1104→{\"type\":\"tool_use\",\"name\":\"Bash\",\"input\":{\"command\":\"git commit -m fix\"}}\n  1105→{\"type\":\"tool_result\",\"content\":\"[main 655dd38] fix\\n 1 file changed\"}\n  1106→{\"type\":\"assistant\",\"message\":\"Done! Commit 655dd38\"}\n  1107→\"#;\n  1108→        let file = write_temp_file(dir.path(), \"session.jsonl\", content);\n  1109→\n  1110→        let hashes = extract_commit_hashes(&file);\n  1111→        // Should find 655dd38 from the [main 655dd38] pattern\n  1112→        // but NOT from the bare \"Commit 655dd38\" mention\n  1113→        assert_eq!(hashes.len(), 1);\n  1114→        assert_eq!(hashes[0], \"655dd38\");\n  1115→    }\n  1116→\n  1117→    // -----------------------------------------------------------------------\n  1118→    // End-to-end: find + parse + verify\n  1119→    // -----------------------------------------------------------------------\n  1120→\n  1121→    #[test]\n  1122→    fn test_end_to_end_find_parse_verify() {\n  1123→        let (dir, commit_hash) = init_temp_repo();\n  1124→        let repo_root = dir.path().to_path_buf();\n  1125→\n  1126→        // Create a fake session log with the commit hash and metadata\n  1127→        let log_dir = TempDir::new().unwrap();\n  1128→        let claude_dir = log_dir.path().join(\".claude\").join(\"projects\");\n  1129→        fs::create_dir_all(&claude_dir).unwrap();\n  1130→\n  1131→        let content = format!(\n  1132→            r#\"{{\"session_id\":\"e2e-session\",\"cwd\":\"{cwd}\"}}\n  1133→{{\"type\":\"tool_result\",\"content\":\"[main {short}] fix bug\\n 1 file changed\"}}\n  1134→{{\"type\":\"assistant\",\"message\":\"Done\"}}\n  1135→\"#,\n  1136→            cwd = dir.path().to_string_lossy(),\n  1137→            short = &commit_hash[..7],\n  1138→        );\n  1139→        let file = write_temp_file(&claude_dir, \"session.jsonl\", &content);\n  1140→\n  1141→        // Step 1: Find the session\n  1142→        let session_match = find_session_for_commit(&commit_hash, &[file.clone()]);\n  1143→        assert!(session_match.is_some());\n  1144→        let session_match = session_match.unwrap();\n  1145→        assert_eq!(session_match.agent_type, AgentType::Claude);\n  1146→\n  1147→        // Step 2: Parse metadata\n  1148→        let metadata = parse_session_metadata(&file);\n  1149→        assert_eq!(metadata.session_id, Some(\"e2e-session\".to_string()));\n  1150→        assert_eq!(metadata.cwd, Some(dir.path().to_string_lossy().to_string()));\n  1151→\n  1152→        // Step 3: Verify\n  1153→        assert!(verify_match(&metadata, &repo_root, &commit_hash));\n  1154→    }\n  1155→}\n  1156→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"uuid":"34f74446-b636-4170-bce8-8bcf60a236b2","timestamp":"2026-02-10T02:17:32.542Z","toolUseResult":{"type":"text","file":{"filePath":"/Users/daveslutzkin/dev/ai-session-commit-linker/src/scanner.rs","content":"//! Session scanning and correlation.\n//!\n//! Scans candidate session log files (JSONL) to find commit hashes,\n//! then parses minimal metadata and verifies the match against the\n//! git repository.\n//!\n//! The core invariant: \"If an AI agent created a commit, the commit hash\n//! appears verbatim in the session log.\" This module implements that\n//! search by streaming files line-by-line (never loading entire files\n//! into memory) and doing substring matching for the full hash and\n//! the short hash (first 7 characters).\n\nuse std::fs::File;\nuse std::io::{BufRead, BufReader};\nuse std::path::{Path, PathBuf};\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\n/// The type of AI agent that produced a session log.\n#[derive(Debug, Clone, PartialEq, Eq)]\npub enum AgentType {\n    Claude,\n    Codex,\n}\n\nimpl std::fmt::Display for AgentType {\n    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {\n        match self {\n            AgentType::Claude => write!(f, \"claude-code\"),\n            AgentType::Codex => write!(f, \"codex\"),\n        }\n    }\n}\n\n/// A successful match: a candidate file contains a commit hash.\n#[derive(Debug, Clone)]\npub struct SessionMatch {\n    /// Path to the session log file that contained the commit hash.\n    pub file_path: PathBuf,\n    /// The agent type, inferred from the file path.\n    pub agent_type: AgentType,\n}\n\n/// Minimal metadata parsed from a session log file.\n///\n/// Not every field is guaranteed to be present -- session logs vary\n/// in structure. Fields are `Option` to handle missing data gracefully.\n#[derive(Debug, Clone, Default)]\npub struct SessionMetadata {\n    /// The session ID (UUID or similar identifier).\n    pub session_id: Option<String>,\n    /// The working directory where the agent was running.\n    pub cwd: Option<String>,\n    /// The agent type, if determinable from the log content.\n    pub agent_type: Option<AgentType>,\n}\n\n// ---------------------------------------------------------------------------\n// Public API\n// ---------------------------------------------------------------------------\n\n/// Search candidate files for a line containing the given commit hash.\n///\n/// Streams each file line-by-line using `BufReader` to avoid loading\n/// entire files into memory. Checks each line for:\n/// - The full 40-character commit hash (substring match)\n/// - The short hash (first 7 characters, substring match)\n///\n/// Returns `Some(SessionMatch)` on the first match found across all\n/// candidate files. Returns `None` if no files contain the hash.\n///\n/// The agent type is inferred from the file path:\n/// - If the path contains `.claude` -> Claude\n/// - If the path contains `.codex` -> Codex\n/// - Otherwise defaults to Claude (conservative fallback)\npub fn find_session_for_commit(\n    commit_hash: &str,\n    candidate_files: &[PathBuf],\n) -> Option<SessionMatch> {\n    // Reject invalid commit hashes: must be 7-40 hex characters.\n    // An empty or short string would cause `line.contains(\"\")` to return true\n    // for every line, producing universal false positives. Non-hex strings\n    // can never be valid commit hashes.\n    if crate::git::validate_commit_hash(commit_hash).is_err() {\n        return None;\n    }\n\n    let short_hash = &commit_hash[..7];\n\n    for file_path in candidate_files {\n        let file = match File::open(file_path) {\n            Ok(f) => f,\n            Err(_) => continue,\n        };\n\n        let reader = BufReader::new(file);\n\n        for line in reader.lines() {\n            let line = match line {\n                Ok(l) => l,\n                Err(_) => continue,\n            };\n\n            // Check for full hash first (more specific), then short hash\n            if line.contains(commit_hash) || line.contains(short_hash) {\n                let agent_type = infer_agent_type(file_path);\n                return Some(SessionMatch {\n                    file_path: file_path.clone(),\n                    agent_type,\n                });\n            }\n        }\n    }\n\n    None\n}\n\n/// Parse minimal metadata from a session log file.\n///\n/// Reads the file line-by-line, attempting to parse each line as JSON\n/// and extracting known fields:\n/// - `session_id` (or `sessionId`)\n/// - `cwd` (or `workdir`, `working_directory`)\n/// - `type` field that may indicate the agent\n///\n/// This is best-effort: not every line will be valid JSON, and not\n/// every JSON line will contain the fields we need. The function\n/// accumulates fields across all lines, with first-value-wins semantics\n/// (once a field is found, later occurrences are ignored).\npub fn parse_session_metadata(file: &Path) -> SessionMetadata {\n    let mut metadata = SessionMetadata::default();\n\n    let file_handle = match File::open(file) {\n        Ok(f) => f,\n        Err(_) => return metadata,\n    };\n\n    let reader = BufReader::new(file_handle);\n\n    for line in reader.lines() {\n        let line = match line {\n            Ok(l) => l,\n            Err(_) => continue,\n        };\n\n        // Attempt to parse as JSON\n        let value: serde_json::Value = match serde_json::from_str(&line) {\n            Ok(v) => v,\n            Err(_) => continue,\n        };\n\n        // Extract session_id\n        if metadata.session_id.is_none()\n            && let Some(id) = value\n                .get(\"session_id\")\n                .or_else(|| value.get(\"sessionId\"))\n                .and_then(|v| v.as_str())\n        {\n            metadata.session_id = Some(id.to_string());\n        }\n\n        // Extract cwd / workdir\n        if metadata.cwd.is_none()\n            && let Some(cwd) = value\n                .get(\"cwd\")\n                .or_else(|| value.get(\"workdir\"))\n                .or_else(|| value.get(\"working_directory\"))\n                .and_then(|v| v.as_str())\n        {\n            metadata.cwd = Some(cwd.to_string());\n        }\n\n        // If we have both fields, stop early\n        if metadata.session_id.is_some() && metadata.cwd.is_some() {\n            break;\n        }\n    }\n\n    // Infer agent type from file path\n    metadata.agent_type = Some(infer_agent_type(file));\n\n    metadata\n}\n\n/// Verify that a session match is valid for a given repository and commit.\n///\n/// Checks two conditions:\n/// 1. The `cwd` from the session metadata resolves to the same git repo\n///    root as the target repository.\n/// 2. The commit exists in that repository.\n///\n/// Returns `false` if any check fails or if the cwd is not available\n/// in the metadata.\npub fn verify_match(metadata: &SessionMetadata, repo_root: &Path, commit: &str) -> bool {\n    // Validate commit hash before passing to git commands.\n    if crate::git::validate_commit_hash(commit).is_err() {\n        return false;\n    }\n\n    let cwd = match &metadata.cwd {\n        Some(c) => c,\n        None => return false,\n    };\n\n    let cwd_path = Path::new(cwd);\n\n    // Check 1: cwd resolves to the same git repo root\n    match crate::git::repo_root_at(cwd_path) {\n        Ok(cwd_repo_root) => {\n            // Canonicalize both paths for comparison to handle symlinks\n            let canonical_repo = match repo_root.canonicalize() {\n                Ok(p) => p,\n                Err(_) => repo_root.to_path_buf(),\n            };\n            let canonical_cwd_repo = match cwd_repo_root.canonicalize() {\n                Ok(p) => p,\n                Err(_) => cwd_repo_root,\n            };\n            if canonical_repo != canonical_cwd_repo {\n                return false;\n            }\n        }\n        Err(_) => return false,\n    }\n\n    // Check 2: commit exists in the repo\n    crate::git::commit_exists_at(repo_root, commit).unwrap_or_default()\n}\n\n/// Extract commit hashes from git commit confirmation output in a session log.\n///\n/// Looks specifically for the `[branch HASH]` pattern that git outputs when\n/// a commit is created (e.g., `[main abcdef0] Fix bug`). This targets only\n/// commits actually made during the session, avoiding false positives from\n/// git log, git diff, UUIDs, and other hex strings.\n///\n/// Returns a deduplicated `Vec<String>` of extracted hashes (lowercased).\n/// Returns an empty Vec on any I/O error.\npub fn extract_commit_hashes(file: &Path) -> Vec<String> {\n    let file_handle = match File::open(file) {\n        Ok(f) => f,\n        Err(_) => return Vec::new(),\n    };\n\n    let reader = BufReader::new(file_handle);\n    let mut hashes = Vec::new();\n    let mut seen = std::collections::HashSet::new();\n\n    for line in reader.lines() {\n        let line = match line {\n            Ok(l) => l,\n            Err(_) => continue,\n        };\n\n        extract_hashes_from_line(&line, &mut hashes, &mut seen);\n    }\n\n    hashes\n}\n\n/// Extract commit hashes from `[branch HASH]` patterns in a single line.\n///\n/// Matches the git commit confirmation format: `[branch_name hash]` where\n/// `branch_name` can contain word chars, `/`, `.`, and `-`, and `hash` is\n/// 7-40 hex characters.\nfn extract_hashes_from_line(\n    line: &str,\n    hashes: &mut Vec<String>,\n    seen: &mut std::collections::HashSet<String>,\n) {\n    // Match `[branch hash]` pattern from git commit output.\n    // The branch name can contain word chars, /, ., - (e.g., feature/foo-bar).\n    // The hash is 7-40 hex characters.\n    let bytes = line.as_bytes();\n    let len = bytes.len();\n    let mut i = 0;\n\n    while i < len {\n        // Look for '['\n        if bytes[i] != b'[' {\n            i += 1;\n            continue;\n        }\n        i += 1; // skip '['\n\n        // Parse branch name: [\\w/.#-]+ (at least 1 char)\n        let branch_start = i;\n        while i < len\n            && (bytes[i].is_ascii_alphanumeric()\n                || bytes[i] == b'/'\n                || bytes[i] == b'.'\n                || bytes[i] == b'-'\n                || bytes[i] == b'_'\n                || bytes[i] == b'#')\n        {\n            i += 1;\n        }\n        if i == branch_start {\n            // No branch name chars found\n            continue;\n        }\n\n        // Expect a space between branch name and hash\n        if i >= len || bytes[i] != b' ' {\n            continue;\n        }\n        i += 1; // skip space\n\n        // Parse hex hash: 7-40 hex chars\n        let hash_start = i;\n        while i < len && bytes[i].is_ascii_hexdigit() {\n            i += 1;\n        }\n        let hash_len = i - hash_start;\n        if !(7..=40).contains(&hash_len) {\n            continue;\n        }\n\n        // Expect ']' after hash\n        if i >= len || bytes[i] != b']' {\n            continue;\n        }\n\n        let hash = line[hash_start..hash_start + hash_len].to_ascii_lowercase();\n        if seen.insert(hash.clone()) {\n            hashes.push(hash);\n        }\n\n        i += 1; // skip ']'\n    }\n}\n\n// ---------------------------------------------------------------------------\n// Internal helpers\n// ---------------------------------------------------------------------------\n\n/// Infer the agent type from a file path.\n///\n/// - If path contains `.claude` -> Claude\n/// - If path contains `.codex` -> Codex\n/// - Otherwise -> Claude (conservative default)\nfn infer_agent_type(path: &Path) -> AgentType {\n    let path_str = path.to_string_lossy();\n    if path_str.contains(\".codex\") {\n        AgentType::Codex\n    } else {\n        // Default to Claude -- `.claude` paths and unknown paths\n        AgentType::Claude\n    }\n}\n\n// ---------------------------------------------------------------------------\n// Tests\n// ---------------------------------------------------------------------------\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n    use std::fs;\n    use std::process::Command;\n    use tempfile::TempDir;\n\n    // -----------------------------------------------------------------------\n    // Helper: create a temp file with given content\n    // -----------------------------------------------------------------------\n\n    fn write_temp_file(dir: &Path, name: &str, content: &str) -> PathBuf {\n        let path = dir.join(name);\n        fs::write(&path, content).expect(\"failed to write temp file\");\n        path\n    }\n\n    // -----------------------------------------------------------------------\n    // infer_agent_type\n    // -----------------------------------------------------------------------\n\n    #[test]\n    fn test_infer_agent_type_claude() {\n        let path = Path::new(\"/Users/foo/.claude/projects/-Users-foo-bar/session.jsonl\");\n        assert_eq!(infer_agent_type(path), AgentType::Claude);\n    }\n\n    #[test]\n    fn test_infer_agent_type_codex() {\n        let path = Path::new(\"/Users/foo/.codex/sessions/abc123/session.jsonl\");\n        assert_eq!(infer_agent_type(path), AgentType::Codex);\n    }\n\n    #[test]\n    fn test_infer_agent_type_unknown_defaults_to_claude() {\n        let path = Path::new(\"/tmp/some/random/session.jsonl\");\n        assert_eq!(infer_agent_type(path), AgentType::Claude);\n    }\n\n    // -----------------------------------------------------------------------\n    // AgentType display\n    // -----------------------------------------------------------------------\n\n    #[test]\n    fn test_agent_type_display_claude() {\n        assert_eq!(AgentType::Claude.to_string(), \"claude-code\");\n    }\n\n    #[test]\n    fn test_agent_type_display_codex() {\n        assert_eq!(AgentType::Codex.to_string(), \"codex\");\n    }\n\n    // -----------------------------------------------------------------------\n    // find_session_for_commit — full hash match\n    // -----------------------------------------------------------------------\n\n    #[test]\n    fn test_find_session_full_hash_match() {\n        let dir = TempDir::new().unwrap();\n        let commit_hash = \"abcdef0123456789abcdef0123456789abcdef01\";\n\n        // Create a JSONL file with a line containing the full hash\n        let content =\n            format!(r#\"{{\"type\":\"tool_result\",\"content\":\"Created commit {commit_hash}\"}}\"#,);\n        let file = write_temp_file(\n            dir.path(),\n            \"session.jsonl\",\n            &format!(\"{}\\n{{\\\"type\\\":\\\"other\\\"}}\\n\", content),\n        );\n\n        let result = find_session_for_commit(commit_hash, &[file.clone()]);\n\n        assert!(result.is_some());\n        let m = result.unwrap();\n        assert_eq!(m.file_path, file);\n    }\n\n    // -----------------------------------------------------------------------\n    // find_session_for_commit — short hash match\n    // -----------------------------------------------------------------------\n\n    #[test]\n    fn test_find_session_short_hash_match() {\n        let dir = TempDir::new().unwrap();\n        let commit_hash = \"abcdef0123456789abcdef0123456789abcdef01\";\n        let short_hash = &commit_hash[..7]; // \"abcdef0\"\n\n        // Only the short hash appears in the line\n        let content = format!(r#\"{{\"type\":\"tool_result\",\"content\":\"Committed {short_hash}\"}}\"#,);\n        let file = write_temp_file(dir.path(), \"session.jsonl\", &content);\n\n        let result = find_session_for_commit(commit_hash, &[file]);\n\n        assert!(result.is_some());\n        let m = result.unwrap();\n        assert_eq!(m.agent_type, AgentType::Claude);\n    }\n\n    // -----------------------------------------------------------------------\n    // find_session_for_commit — no match\n    // -----------------------------------------------------------------------\n\n    #[test]\n    fn test_find_session_no_match() {\n        let dir = TempDir::new().unwrap();\n        let commit_hash = \"abcdef0123456789abcdef0123456789abcdef01\";\n\n        // File with unrelated content\n        let file = write_temp_file(\n            dir.path(),\n            \"session.jsonl\",\n            \"{\\\"type\\\":\\\"message\\\"}\\n{\\\"type\\\":\\\"other\\\"}\\n\",\n        );\n\n        let result = find_session_for_commit(commit_hash, &[file]);\n\n        assert!(result.is_none());\n    }\n\n    // -----------------------------------------------------------------------\n    // find_session_for_commit — stops on first match\n    // -----------------------------------------------------------------------\n\n    #[test]\n    fn test_find_session_stops_on_first_file_match() {\n        let dir = TempDir::new().unwrap();\n        let commit_hash = \"abcdef0123456789abcdef0123456789abcdef01\";\n\n        // First file has the match\n        let file1 = write_temp_file(\n            dir.path(),\n            \"first.jsonl\",\n            &format!(r#\"{{\"content\":\"commit {commit_hash}\"}}\"#),\n        );\n        // Second file also has a match (should not be reached)\n        let file2 = write_temp_file(\n            dir.path(),\n            \"second.jsonl\",\n            &format!(r#\"{{\"content\":\"commit {commit_hash}\"}}\"#),\n        );\n\n        let result = find_session_for_commit(commit_hash, &[file1.clone(), file2]);\n\n        assert!(result.is_some());\n        assert_eq!(result.unwrap().file_path, file1);\n    }\n\n    // -----------------------------------------------------------------------\n    // find_session_for_commit — multiple files, match in second\n    // -----------------------------------------------------------------------\n\n    #[test]\n    fn test_find_session_match_in_second_file() {\n        let dir = TempDir::new().unwrap();\n        let commit_hash = \"abcdef0123456789abcdef0123456789abcdef01\";\n\n        // First file has no match\n        let file1 = write_temp_file(\n            dir.path(),\n            \"no-match.jsonl\",\n            \"{\\\"type\\\":\\\"message\\\",\\\"content\\\":\\\"hello\\\"}\\n\",\n        );\n        // Second file has the match\n        let file2 = write_temp_file(\n            dir.path(),\n            \"has-match.jsonl\",\n            &format!(r#\"{{\"content\":\"Created commit {commit_hash}\"}}\"#),\n        );\n\n        let result = find_session_for_commit(commit_hash, &[file1, file2.clone()]);\n\n        assert!(result.is_some());\n        assert_eq!(result.unwrap().file_path, file2);\n    }\n\n    // -----------------------------------------------------------------------\n    // find_session_for_commit — empty candidate list\n    // -----------------------------------------------------------------------\n\n    #[test]\n    fn test_find_session_empty_candidates() {\n        let commit_hash = \"abcdef0123456789abcdef0123456789abcdef01\";\n        let result = find_session_for_commit(commit_hash, &[]);\n        assert!(result.is_none());\n    }\n\n    // -----------------------------------------------------------------------\n    // find_session_for_commit — nonexistent file is skipped gracefully\n    // -----------------------------------------------------------------------\n\n    #[test]\n    fn test_find_session_nonexistent_file_skipped() {\n        let commit_hash = \"abcdef0123456789abcdef0123456789abcdef01\";\n        let nonexistent = PathBuf::from(\"/nonexistent/file.jsonl\");\n        let result = find_session_for_commit(commit_hash, &[nonexistent]);\n        assert!(result.is_none());\n    }\n\n    // -----------------------------------------------------------------------\n    // find_session_for_commit — agent type from path\n    // -----------------------------------------------------------------------\n\n    #[test]\n    fn test_find_session_agent_type_claude_from_path() {\n        let dir = TempDir::new().unwrap();\n        let commit_hash = \"abcdef0123456789abcdef0123456789abcdef01\";\n\n        // Put the file under a .claude directory\n        let claude_dir = dir.path().join(\".claude\").join(\"projects\");\n        fs::create_dir_all(&claude_dir).unwrap();\n        let file = write_temp_file(\n            &claude_dir,\n            \"session.jsonl\",\n            &format!(r#\"{{\"content\":\"{commit_hash}\"}}\"#),\n        );\n\n        let result = find_session_for_commit(commit_hash, &[file]);\n\n        assert!(result.is_some());\n        assert_eq!(result.unwrap().agent_type, AgentType::Claude);\n    }\n\n    #[test]\n    fn test_find_session_agent_type_codex_from_path() {\n        let dir = TempDir::new().unwrap();\n        let commit_hash = \"abcdef0123456789abcdef0123456789abcdef01\";\n\n        // Put the file under a .codex directory\n        let codex_dir = dir.path().join(\".codex\").join(\"sessions\");\n        fs::create_dir_all(&codex_dir).unwrap();\n        let file = write_temp_file(\n            &codex_dir,\n            \"session.jsonl\",\n            &format!(r#\"{{\"content\":\"{commit_hash}\"}}\"#),\n        );\n\n        let result = find_session_for_commit(commit_hash, &[file]);\n\n        assert!(result.is_some());\n        assert_eq!(result.unwrap().agent_type, AgentType::Codex);\n    }\n\n    // -----------------------------------------------------------------------\n    // find_session_for_commit — hash embedded in complex JSONL\n    // -----------------------------------------------------------------------\n\n    #[test]\n    fn test_find_session_hash_in_realistic_jsonl() {\n        let dir = TempDir::new().unwrap();\n        let commit_hash = \"655dd38a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e\";\n\n        // Simulate realistic Claude Code JSONL output\n        let content = format!(\n            r#\"{{\"type\":\"assistant\",\"message\":\"I'll commit this now\"}}\n{{\"type\":\"tool_use\",\"name\":\"Bash\",\"input\":{{\"command\":\"git add . && git commit -m \\\"fix bug\\\"\"}}}}\n{{\"type\":\"tool_result\",\"content\":\"[main {short_hash}] fix bug\\n 1 file changed, 2 insertions(+)\"}}\n{{\"type\":\"assistant\",\"message\":\"Done! The commit has been created.\"}}\n\"#,\n            short_hash = &commit_hash[..7],\n        );\n        let file = write_temp_file(dir.path(), \"session.jsonl\", &content);\n\n        let result = find_session_for_commit(commit_hash, &[file]);\n\n        assert!(result.is_some());\n    }\n\n    // -----------------------------------------------------------------------\n    // find_session_for_commit — hash that partially matches but shouldn't\n    // -----------------------------------------------------------------------\n\n    #[test]\n    fn test_find_session_partial_hash_no_false_positive() {\n        let dir = TempDir::new().unwrap();\n        // Full hash starts with \"abcdef0...\"\n        let commit_hash = \"abcdef0123456789abcdef0123456789abcdef01\";\n\n        // File contains \"abcdef\" (6 chars -- shorter than 7-char short hash)\n        // This should NOT match because we check for 7-char short hash\n        let content = r#\"{\"content\":\"the string abcdef appears here\"}\"#;\n        let file = write_temp_file(dir.path(), \"session.jsonl\", content);\n\n        let result = find_session_for_commit(commit_hash, &[file]);\n\n        // \"abcdef\" is only 6 chars, our short hash is \"abcdef0\" (7 chars).\n        // The line does not contain \"abcdef0\", so no match.\n        assert!(result.is_none());\n    }\n\n    // -----------------------------------------------------------------------\n    // find_session_for_commit — short/empty hash rejected\n    // -----------------------------------------------------------------------\n\n    #[test]\n    fn test_find_session_empty_hash_returns_none() {\n        let dir = TempDir::new().unwrap();\n        // A file where every line would match an empty string\n        let file = write_temp_file(\n            dir.path(),\n            \"session.jsonl\",\n            \"{\\\"type\\\":\\\"message\\\",\\\"content\\\":\\\"hello\\\"}\\n\",\n        );\n\n        let result = find_session_for_commit(\"\", &[file]);\n        assert!(result.is_none());\n    }\n\n    #[test]\n    fn test_find_session_short_hash_returns_none() {\n        let dir = TempDir::new().unwrap();\n        let file = write_temp_file(\n            dir.path(),\n            \"session.jsonl\",\n            \"{\\\"content\\\":\\\"abcdef something\\\"}\\n\",\n        );\n\n        // 6-char hash is too short, should be rejected\n        let result = find_session_for_commit(\"abcdef\", &[file]);\n        assert!(result.is_none());\n    }\n\n    // -----------------------------------------------------------------------\n    // parse_session_metadata\n    // -----------------------------------------------------------------------\n\n    #[test]\n    fn test_parse_metadata_session_id_and_cwd() {\n        let dir = TempDir::new().unwrap();\n        let content = r#\"{\"session_id\":\"abc-123\",\"cwd\":\"/Users/foo/bar\"}\n{\"type\":\"message\",\"content\":\"hello\"}\n\"#;\n        let file = write_temp_file(dir.path(), \"session.jsonl\", content);\n\n        let metadata = parse_session_metadata(&file);\n\n        assert_eq!(metadata.session_id, Some(\"abc-123\".to_string()));\n        assert_eq!(metadata.cwd, Some(\"/Users/foo/bar\".to_string()));\n    }\n\n    #[test]\n    fn test_parse_metadata_camel_case_session_id() {\n        let dir = TempDir::new().unwrap();\n        let content = r#\"{\"sessionId\":\"def-456\",\"cwd\":\"/Users/baz\"}\"#;\n        let file = write_temp_file(dir.path(), \"session.jsonl\", content);\n\n        let metadata = parse_session_metadata(&file);\n\n        assert_eq!(metadata.session_id, Some(\"def-456\".to_string()));\n    }\n\n    #[test]\n    fn test_parse_metadata_workdir_field() {\n        let dir = TempDir::new().unwrap();\n        let content = r#\"{\"workdir\":\"/home/user/project\"}\"#;\n        let file = write_temp_file(dir.path(), \"session.jsonl\", content);\n\n        let metadata = parse_session_metadata(&file);\n\n        assert_eq!(metadata.cwd, Some(\"/home/user/project\".to_string()));\n    }\n\n    #[test]\n    fn test_parse_metadata_working_directory_field() {\n        let dir = TempDir::new().unwrap();\n        let content = r#\"{\"working_directory\":\"/opt/app\"}\"#;\n        let file = write_temp_file(dir.path(), \"session.jsonl\", content);\n\n        let metadata = parse_session_metadata(&file);\n\n        assert_eq!(metadata.cwd, Some(\"/opt/app\".to_string()));\n    }\n\n    #[test]\n    fn test_parse_metadata_fields_across_multiple_lines() {\n        let dir = TempDir::new().unwrap();\n        // session_id on one line, cwd on another\n        let content = r#\"{\"session_id\":\"multi-line-id\"}\n{\"type\":\"other\"}\n{\"cwd\":\"/Users/foo/repo\"}\n\"#;\n        let file = write_temp_file(dir.path(), \"session.jsonl\", content);\n\n        let metadata = parse_session_metadata(&file);\n\n        assert_eq!(metadata.session_id, Some(\"multi-line-id\".to_string()));\n        assert_eq!(metadata.cwd, Some(\"/Users/foo/repo\".to_string()));\n    }\n\n    #[test]\n    fn test_parse_metadata_no_fields() {\n        let dir = TempDir::new().unwrap();\n        let content = r#\"{\"type\":\"message\",\"content\":\"no metadata here\"}\n{\"type\":\"tool_result\",\"content\":\"more stuff\"}\n\"#;\n        let file = write_temp_file(dir.path(), \"session.jsonl\", content);\n\n        let metadata = parse_session_metadata(&file);\n\n        assert_eq!(metadata.session_id, None);\n        assert_eq!(metadata.cwd, None);\n    }\n\n    #[test]\n    fn test_parse_metadata_invalid_json_lines_skipped() {\n        let dir = TempDir::new().unwrap();\n        let content = r#\"this is not json\n{\"session_id\":\"valid-id\"}\nalso not json {{{{\n{\"cwd\":\"/valid/path\"}\n\"#;\n        let file = write_temp_file(dir.path(), \"session.jsonl\", content);\n\n        let metadata = parse_session_metadata(&file);\n\n        assert_eq!(metadata.session_id, Some(\"valid-id\".to_string()));\n        assert_eq!(metadata.cwd, Some(\"/valid/path\".to_string()));\n    }\n\n    #[test]\n    fn test_parse_metadata_empty_file() {\n        let dir = TempDir::new().unwrap();\n        let file = write_temp_file(dir.path(), \"empty.jsonl\", \"\");\n\n        let metadata = parse_session_metadata(&file);\n\n        assert_eq!(metadata.session_id, None);\n        assert_eq!(metadata.cwd, None);\n    }\n\n    #[test]\n    fn test_parse_metadata_nonexistent_file() {\n        let path = Path::new(\"/nonexistent/file.jsonl\");\n        let metadata = parse_session_metadata(path);\n\n        assert_eq!(metadata.session_id, None);\n        assert_eq!(metadata.cwd, None);\n    }\n\n    #[test]\n    fn test_parse_metadata_agent_type_from_claude_path() {\n        let dir = TempDir::new().unwrap();\n        let claude_dir = dir.path().join(\".claude\").join(\"projects\");\n        fs::create_dir_all(&claude_dir).unwrap();\n        let file = write_temp_file(&claude_dir, \"session.jsonl\", \"{}\");\n\n        let metadata = parse_session_metadata(&file);\n\n        assert_eq!(metadata.agent_type, Some(AgentType::Claude));\n    }\n\n    #[test]\n    fn test_parse_metadata_agent_type_from_codex_path() {\n        let dir = TempDir::new().unwrap();\n        let codex_dir = dir.path().join(\".codex\").join(\"sessions\");\n        fs::create_dir_all(&codex_dir).unwrap();\n        let file = write_temp_file(&codex_dir, \"session.jsonl\", \"{}\");\n\n        let metadata = parse_session_metadata(&file);\n\n        assert_eq!(metadata.agent_type, Some(AgentType::Codex));\n    }\n\n    #[test]\n    fn test_parse_metadata_first_value_wins() {\n        let dir = TempDir::new().unwrap();\n        // Two lines with session_id -- first should win\n        let content = r#\"{\"session_id\":\"first-id\"}\n{\"session_id\":\"second-id\"}\n\"#;\n        let file = write_temp_file(dir.path(), \"session.jsonl\", content);\n\n        let metadata = parse_session_metadata(&file);\n\n        assert_eq!(metadata.session_id, Some(\"first-id\".to_string()));\n    }\n\n    // -----------------------------------------------------------------------\n    // verify_match — requires real git repos, run serially\n    // -----------------------------------------------------------------------\n\n    /// Helper: create a temp git repo with one commit, return (TempDir, commit_hash).\n    fn init_temp_repo() -> (TempDir, String) {\n        let dir = TempDir::new().expect(\"failed to create temp dir\");\n        let path = dir.path();\n\n        run_git(path, &[\"init\"]);\n        run_git(path, &[\"config\", \"user.email\", \"test@test.com\"]);\n        run_git(path, &[\"config\", \"user.name\", \"Test User\"]);\n        // Override hooksPath to prevent the global post-commit hook from firing\n        run_git(path, &[\"config\", \"core.hooksPath\", \"/dev/null\"]);\n        fs::write(path.join(\"README.md\"), \"hello\").unwrap();\n        run_git(path, &[\"add\", \"README.md\"]);\n        run_git(path, &[\"commit\", \"-m\", \"initial commit\"]);\n\n        let hash = run_git(path, &[\"rev-parse\", \"HEAD\"]);\n        (dir, hash)\n    }\n\n    fn run_git(dir: &Path, args: &[&str]) -> String {\n        let output = Command::new(\"git\")\n            .args([\"-C\", dir.to_str().unwrap()])\n            .args(args)\n            .output()\n            .expect(\"failed to run git\");\n        if !output.status.success() {\n            let stderr = String::from_utf8_lossy(&output.stderr);\n            panic!(\"git {:?} failed: {}\", args, stderr);\n        }\n        String::from_utf8(output.stdout).unwrap().trim().to_string()\n    }\n\n    #[test]\n    fn test_verify_match_same_repo() {\n        let (dir, commit_hash) = init_temp_repo();\n        let repo_root = dir.path().to_path_buf();\n\n        let metadata = SessionMetadata {\n            session_id: Some(\"test-session\".to_string()),\n            cwd: Some(dir.path().to_string_lossy().to_string()),\n            agent_type: Some(AgentType::Claude),\n        };\n\n        assert!(verify_match(&metadata, &repo_root, &commit_hash));\n    }\n\n    #[test]\n    fn test_verify_match_missing_cwd() {\n        let (dir, commit_hash) = init_temp_repo();\n        let repo_root = dir.path().to_path_buf();\n\n        let metadata = SessionMetadata {\n            session_id: Some(\"test-session\".to_string()),\n            cwd: None,\n            agent_type: Some(AgentType::Claude),\n        };\n\n        assert!(!verify_match(&metadata, &repo_root, &commit_hash));\n    }\n\n    #[test]\n    fn test_verify_match_different_repo() {\n        let (dir1, commit_hash) = init_temp_repo();\n        let (dir2, _) = init_temp_repo();\n\n        let metadata = SessionMetadata {\n            session_id: Some(\"test-session\".to_string()),\n            // cwd points to dir2 but we're checking against dir1\n            cwd: Some(dir2.path().to_string_lossy().to_string()),\n            agent_type: Some(AgentType::Claude),\n        };\n\n        assert!(!verify_match(\n            &metadata,\n            &dir1.path().to_path_buf(),\n            &commit_hash\n        ));\n    }\n\n    #[test]\n    fn test_verify_match_nonexistent_cwd() {\n        let (dir, commit_hash) = init_temp_repo();\n        let repo_root = dir.path().to_path_buf();\n\n        let metadata = SessionMetadata {\n            session_id: Some(\"test-session\".to_string()),\n            cwd: Some(\"/nonexistent/path/that/does/not/exist\".to_string()),\n            agent_type: Some(AgentType::Claude),\n        };\n\n        assert!(!verify_match(&metadata, &repo_root, &commit_hash));\n    }\n\n    #[test]\n    fn test_verify_match_nonexistent_commit() {\n        let (dir, _) = init_temp_repo();\n        let repo_root = dir.path().to_path_buf();\n        let fake_commit = \"0000000000000000000000000000000000000000\";\n\n        let metadata = SessionMetadata {\n            session_id: Some(\"test-session\".to_string()),\n            cwd: Some(dir.path().to_string_lossy().to_string()),\n            agent_type: Some(AgentType::Claude),\n        };\n\n        assert!(!verify_match(&metadata, &repo_root, fake_commit));\n    }\n\n    #[test]\n    fn test_verify_match_cwd_in_subdirectory() {\n        let (dir, commit_hash) = init_temp_repo();\n        let repo_root = dir.path().to_path_buf();\n\n        // Create a subdirectory inside the repo\n        let subdir = dir.path().join(\"src\");\n        fs::create_dir(&subdir).unwrap();\n\n        let metadata = SessionMetadata {\n            session_id: Some(\"test-session\".to_string()),\n            // cwd is a subdirectory of the repo -- should still resolve to same repo root