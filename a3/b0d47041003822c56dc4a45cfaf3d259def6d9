9→    log_dirs_in(&home)\n    40→}\n    41→\n    42→/// Internal: find Codex session directories under a given home directory.\n    43→///\n    44→/// Separated from `log_dirs` for testability -- tests pass a temp directory\n    45→/// instead of the real home, avoiding `unsafe` env var manipulation.\n    46→fn log_dirs_in(home: &Path) -> Vec<PathBuf> {\n    47→    let sessions_dir = home.join(\".codex\").join(\"sessions\");\n    48→    let entries = match fs::read_dir(&sessions_dir) {\n    49→        Ok(entries) => entries,\n    50→        Err(_) => return Vec::new(),\n    51→    };\n    52→\n    53→    let mut dirs = Vec::new();\n    54→    for entry in entries {\n    55→        let entry = match entry {\n    56→            Ok(e) => e,\n    57→            Err(_) => continue,\n    58→        };\n    59→\n    60→        let path = entry.path();\n    61→        if path.is_dir() {\n    62→            dirs.push(path);\n    63→        }\n    64→    }\n    65→\n    66→    dirs\n    67→}\n    68→\n    69→// ---------------------------------------------------------------------------\n    70→// Tests\n    71→// ---------------------------------------------------------------------------\n    72→\n    73→#[cfg(test)]\n    74→mod tests {\n    75→    use super::*;\n    76→    use std::fs;\n    77→    use tempfile::TempDir;\n    78→\n    79→    #[test]\n    80→    fn test_log_dirs_finds_session_directories() {\n    81→        let home = TempDir::new().unwrap();\n    82→        let sessions_dir = home.path().join(\".codex\").join(\"sessions\");\n    83→        fs::create_dir_all(&sessions_dir).unwrap();\n    84→\n    85→        // Create session directories\n    86→        let session1 = sessions_dir.join(\"session-abc\");\n    87→        let session2 = sessions_dir.join(\"session-def\");\n    88→        fs::create_dir(&session1).unwrap();\n    89→        fs::create_dir(&session2).unwrap();\n    90→\n    91→        let result = log_dirs_in(home.path());\n    92→\n    93→        assert_eq!(result.len(), 2);\n    94→    }\n    95→\n    96→    #[test]\n    97→    fn test_log_dirs_returns_empty_when_sessions_dir_missing() {\n    98→        let home = TempDir::new().unwrap();\n    99→        // Don't create .codex/sessions/\n   100→\n   101→        let result = log_dirs_in(home.path());\n   102→\n   103→        assert!(result.is_empty());\n   104→    }\n   105→\n   106→    #[test]\n   107→    fn test_log_dirs_ignores_files() {\n   108→        let home = TempDir::new().unwrap();\n   109→        let sessions_dir = home.path().join(\".codex\").join(\"sessions\");\n   110→        fs::create_dir_all(&sessions_dir).unwrap();\n   111→\n   112→        // Create a file (not a directory)\n   113→        fs::write(sessions_dir.join(\"not-a-dir.txt\"), \"content\").unwrap();\n   114→\n   115→        // Create an actual directory\n   116→        let session_dir = sessions_dir.join(\"real-session\");\n   117→        fs::create_dir(&session_dir).unwrap();\n   118→\n   119→        let result = log_dirs_in(home.path());\n   120→\n   121→        assert_eq!(result.len(), 1);\n   122→        assert_eq!(result[0], session_dir);\n   123→    }\n   124→\n   125→    #[test]\n   126→    fn test_log_dirs_returns_all_sessions() {\n   127→        // Codex log_dirs should return all session directories regardless\n   128→        // of content -- filtering happens later in candidate_files\n   129→        let home = TempDir::new().unwrap();\n   130→        let sessions_dir = home.path().join(\".codex\").join(\"sessions\");\n   131→        fs::create_dir_all(&sessions_dir).unwrap();\n   132→\n   133→        fs::create_dir(sessions_dir.join(\"session-1\")).unwrap();\n   134→        fs::create_dir(sessions_dir.join(\"session-2\")).unwrap();\n   135→        fs::create_dir(sessions_dir.join(\"session-3\")).unwrap();\n   136→\n   137→        let result = log_dirs_in(home.path());\n   138→\n   139→        assert_eq!(result.len(), 3);\n   140→    }\n   141→\n   142→    // ------------