tim after the closing ---\n   231→        let closing_marker = \"---\\n\";\n   232→        let header_end = note.find(closing_marker).unwrap(); // first ---\n   233→        let payload_start_search = &note[header_end + closing_marker.len()..];\n   234→        let second_marker = payload_start_search.find(closing_marker).unwrap();\n   235→        let payload = &payload_start_search[second_marker + closing_marker.len()..];\n   236→\n   237→        assert_eq!(payload, session_log);\n   238→    }\n   239→\n   240→    #[test]\n   241→    fn test_format_payload_is_verbatim() {\n   242→        // Verify the session log is not modified in any way\n   243→        let session_log = \"  leading spaces\\ttabs\\nnewlines\\n\\n  trailing spaces  \\n\";\n   244→        let note = format(\n   245→            &AgentType::Codex,\n   246→            \"sid\",\n   247→            \"/repo\",\n   248→            \"aabbccdd00112233\",\n   249→            session_log,\n   250→        )\n   251→        .unwrap();\n   252→\n   253→        // The note should end with the verbatim session log\n   254→        assert!(note.ends_with(session_log));\n   255→    }\n   256→\n   257→    #[test]\n   258→    fn test_format_codex_agent() {\n   259→        let note = format(&AgentType::Codex, \"sid\", \"/repo\", \"aabbccdd00112233\", \"log\").unwrap();\n   260→        assert!(note.contains(\"agent: codex\\n\"));\n   261→    }\n   262→\n   263→    #[test]\n   264→    fn test_format_sha256_matches_payload() {\n   265→        let session_log = \"some session log content\\nwith multiple lines\\n\";\n   266→        let note = format(\n   267→            &AgentType::Claude,\n   268→            \"sid\",\n   269→            \"/repo\",\n   270→            \"aabbccdd00112233\",\n   271→            session_log,\n   272→        )\n   273→        .unwrap();\n   274→\n   275→        let expected_sha = payload_sha256(session_log);\n   276→        assert!(note.contains(&format!(\"payload_sha256: {}\\n\", expected_sha)));\n   277→    }\n   278→\n   279→    // -----------------------------------------------------------------------\n   280→    // format — round-trip: payload extraction\n   281→    // -----------------------------------------------------------------------\n   282→\n   283→    #[test]\n   284→    fn test_format_roundtrip_payload_extraction() {\n   285→        let session_log = r#\"{\"session_id\":\"abc\",\"cwd\":\"/foo\"}\n   286→{\"type\":\"tool_result\",\"content\":\"[main 655dd38] fix\\n 1 file changed\"}\n   287→{\"type\":\"assistant\",\"message\":\"Done!\"}\n   288→\"#;\n   289→        let note = format(\n   290→            &AgentType::Claude,\n   291→            \"abc\",\n   292→            \"/foo\",\n   293→            \"655dd38a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e\",\n   294→            session_log,\n   295→        )\n   296→        .unwrap();\n   297→\n   298→        // Split on \"---\\n\" to extract payload\n   299→        let parts: Vec<&str> = note.splitn(3, \"---\\n\").collect();\n   300→        assert_eq!(parts.len(), 3);\n   301→        let extracted_payload = parts[2];\n   302→\n   303→        assert_eq!(extracted_payload, session_log);\n   304→\n   305→        // Verify the SHA in the header matches the extracted payload\n   306→        let sha_from_extraction = payload_sha256(extracted_payload);\n   307→        assert!(parts[1].contains(&format!(\"payload_sha256: {}\\n\", sha_from_extraction)));\n   308→    }\n   309→\n   310→    // -----------------------------------------------------------------------\n   311→    // format — payload containing `---` delimiter\n   312→    // -----------------------------------------------------------------------\n   313→\n   314→    #[test]\n   315→    fn test_format_payload_containing_delimiter() {\n   316→        // Payload that contains `---` on its own line — this is the edge case\n   317→        // where a naive parser scanning for `---` delimiters would misparse.\n   318→        let session_log = \"line one\\n---\\n