{"parentUuid":"723a7fa2-a9dc-4da2-848b-4520378b7841","isSidechain":false,"userType":"external","cwd":"/Users/daveslutzkin/dev/ai-barometer","sessionId":"8b1cb2e1-6a2d-4a92-9bf8-f7390f7dcb89","version":"2.1.37","gitBranch":"main","slug":"stateful-tickling-firefly","type":"progress","data":{"message":{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01J4tMawRX9wiaCsz9dfzAPK","type":"tool_result","content":"     1→//! Note formatting for AI session data.\n     2→//!\n     3→//! Produces human-readable notes with a YAML-style header delimited by `---`\n     4→//! followed by the verbatim session log (JSONL) payload. The header contains\n     5→//! metadata fields: agent, session_id, repo, commit, confidence, and\n     6→//! payload_sha256.\n     7→\n     8→use crate::scanner::AgentType;\n     9→use sha2::{Digest, Sha256};\n    10→\n    11→// ---------------------------------------------------------------------------\n    12→// Public API\n    13→// ---------------------------------------------------------------------------\n    14→\n    15→/// Produce a complete note with YAML-style header and verbatim session log.\n    16→///\n    17→/// The note format is:\n    18→/// ```text\n    19→/// ---\n    20→/// agent: claude-code | codex\n    21→/// session_id: <uuid>\n    22→/// repo: <path>\n    23→/// commit: <full hash>\n    24→/// confidence: exact_hash_match\n    25→/// payload_sha256: <hash>\n    26→/// ---\n    27→/// <verbatim session log (JSONL)>\n    28→/// ```\n    29→///\n    30→/// The `confidence` field is always `exact_hash_match` for now.\n    31→/// The `payload_sha256` is computed from `session_log`.\n    32→///\n    33→/// The `commit` parameter is validated via [`crate::git::validate_commit_hash`]\n    34→/// and must be 7-40 hex characters. Returns an error if validation fails.\n    35→///\n    36→/// # Parsing caveat\n    37→///\n    38→/// The payload is appended verbatim after the closing `---` delimiter. If the\n    39→/// payload itself contains a line that is exactly `---\\n`, a naive parser that\n    40→/// scans for `---` delimiters will misparse the note. Parsers should use\n    41→/// `splitn(3, \"---\\n\")` (splitting on at most 3 occurrences) to correctly\n    42→/// separate the header from the payload, and verify integrity using the\n    43→/// `payload_sha256` field.\n    44→pub fn format(\n    45→    agent: &AgentType,\n    46→    session_id: &str,\n    47→    repo: &str,\n    48→    commit: &str,\n    49→    session_log: &str,\n    50→) -> anyhow::Result<String> {\n    51→    crate::git::validate_commit_hash(commit)?;\n    52→    let sha = payload_sha256(session_log);\n    53→\n    54→    let mut note = String::new();\n    55→    note.push_str(\"---\\n\");\n    56→    note.push_str(&format!(\"agent: {}\\n\", agent));\n    57→    note.push_str(&format!(\"session_id: {}\\n\", session_id));\n    58→    note.push_str(&format!(\"repo: {}\\n\", repo));\n    59→    note.push_str(&format!(\"commit: {}\\n\", commit));\n    60→    note.push_str(\"confidence: exact_hash_match\\n\");\n    61→    note.push_str(&format!(\"payload_sha256: {}\\n\", sha));\n    62→    note.push_str(\"---\\n\");\n    63→    note.push_str(session_log);\n    64→\n    65→    Ok(note)\n    66→}\n    67→\n    68→/// Compute the SHA-256 hash of the session log payload.\n    69→///\n    70→/// Returns the hash as a lowercase hex string (64 characters).\n    71→pub fn payload_sha256(content: &str) -> String {\n    72→    let mut hasher = Sha256::new();\n    73→    hasher.update(content.as_bytes());\n    74→    let result = hasher.finalize();\n    75→    format!(\"{:x}\", result)\n    76→}\n    77→\n    78→// ---------------------------------------------------------------------------\n    79→// Tests\n    80→// ---------------------------------------------------------------------------\n    81→\n    82→#[cfg(test)]\n    83→mod tests {\n    84→    use super::*;\n    85→\n    86→    // -----------------------------------------------------------------------\n    87→    // payload_sha256\n    88→    // -----------------------------------------------------------------------\n    89→\n    90→    #[test]\n    91→    fn test_payload_sha256_known_input() {\n    92→        // SHA-256 of \"hello\" is well-known\n    93→        let hash = payload_sha256(\"hello\");\n    94→        assert_eq!(\n    95→            hash,\n    96→            \"2cf24dba5fb0a30e26e83b2ac5b9e29e1b161e5c1fa7425e73043362938b9824\"\n    97→        );\n    98→    }\n    99→\n   100→    #[test]\n   101→    fn test_payload_sha256_empty_input() {\n   102→        // SHA-256 of empty string is well-known\n   103→        let hash = payload_sha256(\"\");\n   104→        assert_eq!(\n   105→            hash,\n   106→            \"e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855\"\n   107→        );\n   108→    }\n   109→\n   110→    #[test]\n   111→    fn test_payload_sha256_produces_64_char_hex() {\n   112→        let hash = payload_sha256(\"some content\");\n   113→        assert_eq!(hash.len(), 64);\n   114→        assert!(hash.chars().all(|c| c.is_ascii_hexdigit()));\n   115→    }\n   116→\n   117→    #[test]\n   118→    fn test_payload_sha256_multiline() {\n   119→        let content = \"line one\\nline two\\nline three\\n\";\n   120→        let hash = payload_sha256(content);\n   121→        assert_eq!(hash.len(), 64);\n   122→        // Verify determinism\n   123→        assert_eq!(hash, payload_sha256(content));\n   124→    }\n   125→\n   126→    // -----------------------------------------------------------------------\n   127→    // format — exact note structure\n   128→    // -----------------------------------------------------------------------\n   129→\n   130→    #[test]\n   131→    fn test_format_produces_correct_structure() {\n   132→        let session_id = \"abc-123-def-456\";\n   133→        let repo = \"/Users/foo/dev/my-repo\";\n   134→        let commit = \"655dd38a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e\";\n   135→        let session_log = r#\"{\"type\":\"message\",\"content\":\"hello\"}\n   136→{\"type\":\"tool_result\",\"content\":\"done\"}\n   137→\"#;\n   138→\n   139→        let note = format(&AgentType::Claude, session_id, repo, commit, session_log).unwrap();\n   140→\n   141→        // Verify the note starts with ---\n   142→        assert!(note.starts_with(\"---\\n\"));\n   143→\n   144→        // Split into header and payload\n   145→        let parts: Vec<&str> = note.splitn(3, \"---\\n\").collect();\n   146→        assert_eq!(parts.len(), 3);\n   147→\n   148→        // parts[0] is empty (before first ---)\n   149→        assert_eq!(parts[0], \"\");\n   150→\n   151→        // parts[1] is the header content (between the two ---)\n   152→        let header = parts[1];\n   153→        assert!(header.contains(\"agent: claude-code\\n\"));\n   154→        assert!(header.contains(\"session_id: abc-123-def-456\\n\"));\n   155→        assert!(header.contains(\"repo: /Users/foo/dev/my-repo\\n\"));\n   156→        assert!(header.contains(\"commit: 655dd38a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e\\n\"));\n   157→        assert!(header.contains(\"confidence: exact_hash_match\\n\"));\n   158→\n   159→        // Verify the payload_sha256 in the header matches the actual SHA-256\n   160→        let expected_sha = payload_sha256(session_log);\n   161→        assert!(header.contains(&format!(\"payload_sha256: {}\\n\", expected_sha)));\n   162→\n   163→        // parts[2] is the verbatim payload after the closing ---\n   164→        assert_eq!(parts[2], session_log);\n   165→    }\n   166→\n   167→    #[test]\n   168→    fn test_format_header_field_order() {\n   169→        let note = format(\n   170→            &AgentType::Codex,\n   171→            \"sid\",\n   172→            \"/repo\",\n   173→            \"aabbccdd00112233\",\n   174→            \"payload\",\n   175→        )\n   176→        .unwrap();\n   177→\n   178→        // Extract lines between the two --- d