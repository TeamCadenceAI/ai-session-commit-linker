→        .output()\n   126→        .context(\"failed to execute git rev-parse --show-toplevel\")?;\n   127→\n   128→    if !output.status.success() {\n   129→        let stderr = String::from_utf8_lossy(&output.stderr);\n   130→        bail!(\"git rev-parse --show-toplevel failed: {}\", stderr.trim());\n   131→    }\n   132→\n   133→    let stdout = String::from_utf8(output.stdout).context(\"git output was not valid UTF-8\")?;\n   134→    Ok(PathBuf::from(stdout.trim()))\n   135→}\n   136→\n   137→/// Check whether an AI-session note already exists for the given commit,\n   138→/// in a specific repository directory.\n   139→///\n   140→/// This is the directory-parameterised version of [`note_exists`], for use\n   141→/// by commands that operate on repos other than the CWD (e.g., `hydrate`).\n   142→pub(crate) fn note_exists_at(repo: &Path, commit: &str) -> Result<bool> {\n   143→    validate_commit_hash(commit)?;\n   144→    let repo_str = repo.to_string_lossy();\n   145→    let status = Command::new(\"git\")\n   146→        .args([\n   147→            \"-C\", &repo_str, \"notes\", \"--ref\", NOTES_REF, \"show\", \"--\", commit,\n   148→        ])\n   149→        .stdout(std::process::Stdio::null())\n   150→        .stderr(std::process::Stdio::null())\n   151→        .status()\n   152→        .context(\"failed to execute git notes show\")?;\n   153→    Ok(status.success())\n   154→}\n   155→\n   156→/// Attach an AI-session note to a commit in a specific repository directory.\n   157→///\n   158→/// This is the directory-parameterised version of [`add_note`], for use\n   159→/// by commands that operate on repos other than the CWD (e.g., `hydrate`).\n   160→///\n   161→/// **Precondition:** Callers must check [`note_exists_at`] first and skip if\n   162→/// a note is already present.\n   163→pub(crate) fn add_note_at(repo: &Path, commit: &str, content: &str) -> Result<()> {\n   164→    validate_commit_hash(commit)?;\n   165→    let repo_str = repo.to_string_lossy