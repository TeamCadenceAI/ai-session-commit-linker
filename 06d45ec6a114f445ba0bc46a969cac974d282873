put = Command::new(\"git\")\n    37→        .args(args)\n    38→        .output()\n    39→        .context(\"failed to execute git\")?;\n    40→\n    41→    if !output.status.success() {\n    42→        let stderr = String::from_utf8_lossy(&output.stderr);\n    43→        bail!(\n    44→            \"git {} failed (exit {}): {}\",\n    45→            args.join(\" \"),\n    46→            output.status,\n    47→            stderr.trim()\n    48→        );\n    49→    }\n    50→\n    51→    let stdout = String::from_utf8(output.stdout).context(\"git output was not valid UTF-8\")?;\n    52→    Ok(stdout.trim().to_string())\n    53→}\n    54→\n    55→/// Run a git command and return whether it succeeded (exit code 0).\n    56→/// Does not treat non-zero exit as an error — just returns `false`.\n    57→fn git_succeeds(args: &[&str]) -> Result<bool> {\n    58→    let status = Command::new(\"git\")\n    59→        .args(args)\n    60→        .stdout(std::process::Stdio::null())\n    61→        .stderr(std::process::Stdio::null())\n    62→        .status()\n    63→        .context(\"failed to execute git\")?;\n    64→    Ok(status.success())\n    65→}\n    66→\n    67→// ---------------------------------------------------------------------------\n    68→// Public API\n    69→// ---------------------------------------------------------------------------\n    70→\n    71→/// Check whether AI Barometer is enabled for the current repository.\n    72→///\n    73→/// Reads `git config ai.barometer.enabled`. If the value is exactly\n    74→/// `\"false\"`, returns `false` -- the caller should skip ALL processing\n    75→/// (session scanning, note attachment, pending records, push, retry).\n    76→/// Any other value (including unset) returns `true`.\n    77→///\n    78→/// This is placed in the `git` module (not `push`) because it gates\n    79→/// the entire hook lifecycle, not just the push decision.\n    80→pub fn check_enabled() -> bool {\n    81→    match config_get(\"ai.bar