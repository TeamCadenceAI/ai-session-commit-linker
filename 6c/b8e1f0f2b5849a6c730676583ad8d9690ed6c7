ply a mild gaussian blur via CoreImage.\\nlet innerImage = NSImage(size: tileRect.size)\\ninnerImage.lockFocus()\\nNSGraphicsContext.current?.imageInterpolation = .high\\ninputImage.draw(in: NSRect(origin: .zero, size: tileRect.size), from: NSRect(origin: .zero, size: size), operation: .sourceOver, fraction: 1.0)\\ninnerImage.unlockFocus()\\n\\nif let tiff = innerImage.tiffRepresentation, let ciImage = CIImage(data: tiff) {\\n  let filter = CIFilter(name: \\\"CIGaussianBlur\\\")\\n  filter?.setValue(ciImage, forKey: kCIInputImageKey)\\n  filter?.setValue(2.2, forKey: kCIInputRadiusKey)\\n  if let outputCI = filter?.outputImage {\\n    let rep = NSCIImageRep(ciImage: outputCI)\\n    let blurred = NSImage(size: tileRect.size)\\n    blurred.addRepresentation(rep)\\n    blurred.draw(in: tileRect, from: NSRect(origin: .zero, size: tileRect.size), operation: .sourceOver, fraction: 0.85)\\n  }\\n}\\n\\n// Add a soft white sheen gradient\\nlet sheenGradient = NSGradient(colors: [\\n  NSColor(calibratedWhite: 1.0, alpha: 0.35),\\n  NSColor(calibratedWhite: 1.0, alpha: 0.0)\\n])\\nlet sheenRect = NSRect(x: tileRect.minX, y: tileRect.minY + tileRect.height * 0.45, width: tileRect.width, height: tileRect.height * 0.55)\\nlet sheenPath = NSBezierPath(roundedRect: sheenRect, xRadius: radius * 0.9, yRadius: radius * 0.9)\\n\\nsheenPath.addClip()\\nsheenGradient?.draw(in: sheenRect, angle: 90)\\n\\n// Restore clipping for border/highlight strokes\\nNSGraphicsContext.current?.restoreGraphicsState()\\nNSGraphicsContext.current?.saveGraphicsState()\\n\\n// Glossy highlight rim\\nlet rimPath = NSBezierPath(roundedRect: tileRect, xRadius: radius, yRadius: radius)\\nNSColor(calibratedWhite: 1.0, alpha: 0.55).setStroke()\\nrimPath.lineWidth = minSide * 0.004\\nrimPath.stroke()\\n\\n// Subtle inner shadow (fake by drawing a slightly smaller translucent stroke)\\nlet innerInset: CGFloat = minSide * 0.006\\nlet innerRect = tileRect.insetBy(dx: innerInset, dy: innerInset)\\nlet innerPath = NS