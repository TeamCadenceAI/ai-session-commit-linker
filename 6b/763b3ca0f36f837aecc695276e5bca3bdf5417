{"timestamp":"2026-02-12T02:34:24.124Z","type":"response_item","payload":{"type":"function_call_output","call_id":"call_fxnxHS3o03olOx5vmAkfeuLA","output":"Chunk ID: 1d9461\nWall time: 0.0521 seconds\nProcess exited with code 0\nOriginal token count: 622\nOutput:\n//! Antigravity log discovery (VS Code style workspace storage).\n//!\n//! Antigravity stores chat sessions under:\n//! ~/Library/Application Support/Antigravity/User/workspaceStorage/*/chatSessions/*.json\n\nuse std::collections::BTreeSet;\nuse std::path::{Path, PathBuf};\n\nuse super::{find_chat_session_dirs, home_dir};\n\n/// Return all Antigravity log directories for use by the post-commit hook.\npub fn log_dirs() -> Vec<PathBuf> {\n    let home = match home_dir() {\n        Some(h) => h,\n        None => return Vec::new(),\n    };\n    log_dirs_in(&home)\n}\n\n/// Return all Antigravity log directories for hydrate (not repo-scoped).\npub fn all_log_dirs() -> Vec<PathBuf> {\n    log_dirs()\n}\n\nfn log_dirs_in(home: &Path) -> Vec<PathBuf> {\n    let ws_root = home\n        .join(\"Library\")\n        .join(\"Application Support\")\n        .join(\"Antigravity\")\n        .join(\"User\")\n        .join(\"workspaceStorage\");\n    let user_root = home\n        .join(\"Library\")\n        .join(\"Application Support\")\n        .join(\"Antigravity\")\n        .join(\"User\");\n\n    let mut dirs = BTreeSet::new();\n    for dir in find_chat_session_dirs(&ws_root) {\n        dirs.insert(dir);\n    }\n    // Some forks store chatSessions outside workspaceStorage; scan User root too.\n    for dir in find_chat_session_dirs(&user_root) {\n        dirs.insert(dir);\n    }\n\n    dirs.into_iter().collect()\n}\n\n// ---------------------------------------------------------------------------\n// Tests\n// ---------------------------------------------------------------------------\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n    use std::fs;\n    use tempfile::TempDir;\n\n    #[test]\n    fn test_antigravity_log_dirs_collects_chat_sessions() {\n        let home = TempDir::new().unwrap();\n        let ws_root = home\n            .path()\n            .join(\"Library\")\n            .join(\"Application Support\")\n            .join(\"Antigravity\")\n            .join(\"User\")\n            .join(\"workspaceStorage\")\n            .join(\"abc\")\n            .join(\"chatSessions\");\n        fs::create_dir_all(&ws_root).unwrap();\n        let other_root = home\n            .path()\n            .join(\"Library\")\n            .join(\"Application Support\")\n            .join(\"Antigravity\")\n            .join(\"User\")\n            .join(\"other\")\n            .join(\"chatSessions\");\n        fs::create_dir_all(&other_root).unwrap();\n\n        let dirs = log_dirs_in(home.path());\n        assert!(dirs.contains(&ws_root));\n        assert!(dirs.contains(&other_root));\n    }\n}\n"}}
