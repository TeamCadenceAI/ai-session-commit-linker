{"parentUuid":"94f5b427-026f-4c8c-9c47-f69f613137ff","isSidechain":false,"userType":"external","cwd":"/Users/daveslutzkin/dev/ai-barometer","sessionId":"df2069e4-9409-487c-b802-4ce7a022c1f9","version":"2.1.37","gitBranch":"main","slug":"zippy-wibbling-rose","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DjNFWTDwrc4SotS4SSa3yj","type":"tool_result","content":"     1→//! Git utility helpers.\n     2→//!\n     3→//! All functions shell out to `git` via `std::process::Command`.\n     4→//! The notes ref used throughout is `refs/notes/ai-sessions`.\n     5→\n     6→use anyhow::{Context, Result, bail};\n     7→use std::io::Write;\n     8→use std::path::{Path, PathBuf};\n     9→use std::process::Command;\n    10→\n    11→/// The dedicated git notes ref for AI session data.\n    12→const NOTES_REF: &str = \"refs/notes/ai-sessions\";\n    13→\n    14→/// Validate that a commit hash is a valid hex string of 7-40 characters.\n    15→///\n    16→/// This prevents flag injection (e.g., passing `--help` as a commit) and\n    17→/// ensures we only pass well-formed refs to git.\n    18→pub(crate) fn validate_commit_hash(commit: &str) -> Result<()> {\n    19→    let is_valid =\n    20→        commit.len() >= 7 && commit.len() <= 40 && commit.bytes().all(|b| b.is_ascii_hexdigit());\n    21→    if !is_valid {\n    22→        bail!(\n    23→            \"invalid commit hash {:?}: must be 7-40 lowercase hex characters\",\n    24→            commit\n    25→        );\n    26→    }\n    27→    Ok(())\n    28→}\n    29→\n    30→// ---------------------------------------------------------------------------\n    31→// Internal helper\n    32→// ---------------------------------------------------------------------------\n    33→\n    34→/// Run a git command and return its stdout as a trimmed `String`.\n    35→/// Returns an error if the command exits with a non-zero status.\n    36→fn git_output(args: &[&str]) -> Result<String> {\n    37→    let output = Command::new(\"git\")\n    38→        .args(args)\n    39→        .output()\n    40→        .context(\"failed to execute git\")?;\n    41→\n    42→    if !output.status.success() {\n    43→        let stderr = String::from_utf8_lossy(&output.stderr);\n    44→        bail!(\n    45→            \"git {} failed (exit {}): {}\",\n    46→            args.join(\" \"),\n    47→            output.status,\n    48→            stderr.trim()\n    49→        );\n    50→    }\n    51→\n    52→    let stdout = String::from_utf8(output.stdout).context(\"git output was not valid UTF-8\")?;\n    53→    Ok(stdout.trim().to_string())\n    54→}\n    55→\n    56→/// Run a git command and return whether it succeeded (exit code 0).\n    57→/// Does not treat non-zero exit as an error — just returns `false`.\n    58→fn git_succeeds(args: &[&str]) -> Result<bool> {\n    59→    let status = Command::new(\"git\")\n    60→        .args(args)\n    61→        .stdout(std::process::Stdio::null())\n    62→        .stderr(std::process::Stdio::null())\n    63→        .status()\n    64→        .context(\"failed to execute git\")?;\n    65→    Ok(status.success())\n    66→}\n    67→\n    68→// ---------------------------------------------------------------------------\n    69→// Public API\n    70→// ---------------------------------------------------------------------------\n    71→\n    72→/// Check whether AI Barometer is enabled for the current repository.\n    73→///\n    74→/// Reads `git config ai.barometer.enabled`. If the value is exactly\n    75→/// `\"false\"`, returns `false` -- the caller should skip ALL processing\n    76→/// (session scanning, note attachment, pending records, push, retry).\n    77→/// Any other value (including unset) returns `true`.\n    78→///\n    79→/// This is placed in the `git` module (not `push`) because it gates\n    80→/// the entire hook lifecycle, not just the push decision.\n    81→pub fn check_enabled() -> bool {\n    82→    match config_get(\"ai.barometer.enabled\") {\n    83→        Ok(Some(val)) => val != \"false\",\n    84→        // Unset or error: default to enabled\n    85→        _ => true,\n    86→    }\n    87→}\n    88→\n    89→/// Check whether AI Barometer is enabled for a specific repository directory.\n    90→///\n    91→/// This is the directory-parameterised version of [`check_enabled`], for use\n    92→/// by commands that operate on repos other than the CWD (e.g., `hydrate`).\n    93→///\n    94→/// Reads `git -C <repo> config ai.barometer.enabled`. If the value is exactly\n    95→/// `\"false\"`, returns `false`. Any other value (including unset) returns `true`.\n    96→pub(crate) fn check_enabled_at(repo: &Path) -> bool {\n    97→    let repo_str = repo.to_string_lossy();\n    98→    let output = Command::new(\"git\")\n    99→        .args([\"-C\", &repo_str, \"config\", \"--get\", \"ai.barometer.enabled\"])\n   100→        .output();\n   101→\n   102→    match output {\n   103→        Ok(o) if o.status.success() => {\n   104→            let value = String::from_utf8_lossy(&o.stdout).trim().to_string();\n   105→            value != \"false\"\n   106→        }\n   107→        // Unset (exit code 1) or error: default to enabled\n   108→        _ => true,\n   109→    }\n   110→}\n   111→\n   112→/// Return the repository root (`git rev-parse --show-toplevel`).\n   113→pub fn repo_root() -> Result<PathBuf> {\n   114→    let path = git_output(&[\"rev-parse\", \"--show-toplevel\"])?;\n   115→    Ok(PathBuf::from(path))\n   116→}\n   117→\n   118→/// Return the repository root for a given working directory.\n   119→///\n   120→/// Runs `git -C <dir> rev-parse --show-toplevel`. This handles the case\n   121→/// where `dir` is a subdirectory of the repo.\n   122→pub(crate) fn repo_root_at(dir: &Path) -> Result<PathBuf> {\n   123→    let dir_str = dir.to_string_lossy();\n   124→    let output = Command::new(\"git\")\n   125→        .args([\"-C\", &dir_str, \"rev-parse\", \"--show-toplevel\"])\n   126→        .output()\n   127→        .context(\"failed to execute git rev-parse --show-toplevel\")?;\n   128→\n   129→    if !output.status.success() {\n   130→        let stderr = String::from_utf8_lossy(&output.stderr);\n   131→        bail!(\"git rev-parse --show-toplevel failed: {}\", stderr.trim());\n   132→    }\n   133→\n   134→    let stdout = String::from_utf8(output.stdout).context(\"git output was not valid UTF-8\")?;\n   135→    Ok(PathBuf::from(stdout.trim()))\n   136→}\n   137→\n   138→/// Check whether an AI-session note already exists for the given commit,\n   139→/// in a specific repository directory.\n   140→///\n   141→/// This is the directory-parameterised version of [`note_exists`], for use\n   142→/// by commands that operate on repos other than the CWD (e.g., `hydrate`).\n   143→pub(crate) fn note_exists_at(repo: &Path, commit: &str) -> Result<bool> {\n   144→    validate_commit_hash(commit)?;\n   145→    let repo_str = repo.to_string_lossy();\n   146→    let status = Command::new(\"git\")\n   147→        .args([\n   148→            \"-C\", &repo_str, \"notes\", \"--ref\", NOTES_REF, \"show\", \"--\", commit,\n   149→        ])\n   150→        .stdout(std::process::Stdio::null())\n   151→        .stderr(std::process::Stdio::null())\n   152→        .status()\n   153→        .context(\"failed to execute git notes show\")?;\n   154→    Ok(status.success())\n   155→}\n   156→\n   157→/// Attach an AI-session note to a commit in a specific repository directory.\n   158→///\n   159→/// This is the directory-parameterised version of [`add_note`], for use\n   160→/// by commands that operate on repos other than the CWD (e.g., `hydrate`).\n   161→///\n   162→/// **Precondition:** Callers must check [`note_exists_at`] first and skip if\n   163→/// a note is already present.\n   164→pub(crate) fn add_note_at(repo: &Path, commit: &str, content: &str) -> Result<()> {\n   165→    validate_commit_hash(commit)?;\n   166→\n   167→    // Write content to a temp file to avoid ARG_MAX limits on large notes.\n   168→    let mut tmp = tempfile::NamedTempFile::new().context(\"failed to create temp file for note\")?;\n   169→    tmp.write_all(content.as_bytes())\n   170→        .context(\"failed to write note to temp file\")?;\n   171→    tmp.flush().context(\"failed to flush note temp file\")?;\n   172→    let tmp_path = tmp.path().to_string_lossy().to_string();\n   173→\n   174→    let repo_str = repo.to_string_lossy();\n   175→    let output = Command::new(\"git\")\n   176→        .args([\n   177→            \"-C\", &repo_str, \"notes\", \"--ref\", NOTES_REF, \"add\", \"-F\", &tmp_path, \"--\", commit,\n   178→        ])\n   179→        .output()\n   180→        .context(\"failed to execute git notes add\")?;\n   181→\n   182→    if !output.status.success() {\n   183→        let stderr = String::from_utf8_lossy(&output.stderr);\n   184→        bail!(\"git notes add failed: {}\", stderr.trim());\n   185→    }\n   186→    Ok(())\n   187→}\n   188→\n   189→/// Check whether a commit exists in a given repository.\n   190→///\n   191→/// Runs `git -C <repo> cat-file -t -- <commit>` and checks for success.\n   192→/// The `--` separator prevents the commit argument from being interpreted\n   193→/// as a flag.\n   194→pub(crate) fn commit_exists_at(repo: &Path, commit: &str) -> Result<bool> {\n   195→    let repo_str = repo.to_string_lossy();\n   196→    let status = Command::new(\"git\")\n   197→        .args([\"-C\", &repo_str, \"cat-file\", \"-t\", \"--\", commit])\n   198→        .stdout(std::process::Stdio::null())\n   199→        .stderr(std::process::Stdio::null())\n   200→        .status()\n   201→        .context(\"failed to execute git cat-file\")?;\n   202→    Ok(status.success())\n   203→}\n   204→\n   205→/// Return the full 40-character SHA of HEAD.\n   206→pub fn head_hash() -> Result<String> {\n   207→    git_output(&[\"rev-parse\", \"HEAD\"])\n   208→}\n   209→\n   210→/// Return the commit timestamp of HEAD as a Unix epoch `i64`.\n   211→pub fn head_timestamp() -> Result<i64> {\n   212→    let ts_str = git_output(&[\"show\", \"-s\", \"--format=%ct\", \"HEAD\"])?;\n   213→    ts_str\n   214→        .parse::<i64>()\n   215→        .context(\"failed to parse HEAD timestamp as i64\")\n   216→}\n   217→\n   218→/// Check whether an AI-session note already exists for the given commit.\n   219→pub fn note_exists(commit: &str) -> Result<bool> {\n   220→    validate_commit_hash(commit)?;\n   221→    git_succeeds(&[\"notes\", \"--ref\", NOTES_REF, \"show\", \"--\", commit])\n   222→}\n   223→\n   224→/// Attach an AI-session note to the given commit.\n   225→///\n   226→/// **Precondition:** Callers must check [`note_exists`] first and skip if a note\n   227→/// is already present. `git notes add` will fail if a note already exists for the\n   228→/// given commit. The PLAN.md deduplication rules require checking before attaching:\n   229→/// \"if a note already exists, treat as success, do nothing.\"\n   230→pub fn add_note(commit: &str, content: &str) -> Result<()> {\n   231→    validate_commit_hash(commit)?;\n   232→\n   233→    // Write content to a temp file to avoid ARG_MAX limits on large notes.\n   234→    let mut tmp = tempfile::NamedTempFile::new().context(\"failed to create temp file for note\")?;\n   235→    tmp.write_all(content.as_bytes())\n   236→        .context(\"failed to write note to temp file\")?;\n   237→    tmp.flush().context(\"failed to flush note temp file\")?;\n   238→    let tmp_path = tmp.path().to_string_lossy().to_string();\n   239→\n   240→    let output = Command::new(\"git\")\n   241→        .args([\n   242→            \"notes\", \"--ref\", NOTES_REF, \"add\", \"-F\", &tmp_path, \"--\", commit,\n   243→        ])\n   244→        .output()\n   245→        .context(\"failed to execute git notes add\")?;\n   246→\n   247→    if !output.status.success() {\n   248→        let stderr = String::from_utf8_lossy(&output.stderr);\n   249→        bail!(\"git notes add failed: {}\", stderr.trim());\n   250→    }\n   251→    Ok(())\n   252→}\n   253→\n   254→/// Push the AI-session notes ref to `origin`.\n   255→pub fn push_notes() -> Result<()> {\n   256→    let output = Command::new(\"git\")\n   257→        .args([\"push\", \"origin\", NOTES_REF])\n   258→        .output()\n   259→        .context(\"failed to execute git push\")?;\n   260→\n   261→    if !output.status.success() {\n   262→        let stderr = String::from_utf8_lossy(&output.stderr);\n   263→        bail!(\"git push notes failed: {}\", stderr.trim());\n   264→    }\n   265→    Ok(())\n   266→}\n   267→\n   268→/// Check whether the repository has at least one configured remote.\n   269→///\n   270→/// Returns `Ok(false)` if `git remote` fails (e.g., not in a git repository)\n   271→/// rather than propagating the error. This matches the `git_succeeds` pattern\n   272→/// used by `note_exists` and makes the function safe to call defensively.\n   273→pub fn has_upstream() -> Result<bool> {\n   274→    match git_output(&[\"remote\"]) {\n   275→        Ok(remotes) => Ok(!remotes.is_empty()),\n   276→        Err(_) => Ok(false),\n   277→    }\n   278→}\n   279→\n   280→/// Extract owner/org from ALL remote URLs.\n   281→///\n   282→/// Returns a deduplicated list of org names extracted from all configured\n   283→/// remotes. Deduplication is case-insensitive (e.g., `My-Org` and `my-org`\n   284→/// from different remotes are considered the same org; only the first\n   285→/// encountered variant is kept). This is used for org filtering: \"Extract\n   286→/// owner from **all** Git remotes. If **any** remote matches org, allowed.\"\n   287→/// (PLAN.md)\n   288→///\n   289→/// Returns an empty Vec if no remotes are configured or no URLs can be parsed.\n   290→pub fn remote_orgs() -> Result<Vec<String>> {\n   291→    let remotes = git_output(&[\"remote\"])?;\n   292→    let mut orgs = Vec::new();\n   293→\n   294→    for remote_name in remotes.lines() {\n   295→        if remote_name.is_empty() {\n   296→            continue;\n   297→        }\n   298→        if let Ok(url) = git_output(&[\"remote\", \"get-url\", remote_name])\n   299→            && let Some(org) = parse_org_from_url(&url)\n   300→            && !orgs\n   301→                .iter()\n   302→                .any(|existing: &String| existing.eq_ignore_ascii_case(&org))\n   303→        {\n   304→            orgs.push(org);\n   305→        }\n   306→    }\n   307→\n   308→    Ok(orgs)\n   309→}\n   310→\n   311→/// Parse the owner/org segment from a git remote URL.\n   312→///\n   313→/// This is a pure function extracted for testability.\n   314→pub fn parse_org_from_url(url: &str) -> Option<String> {\n   315→    // SSH: git@github.com:org/repo.git\n   316→    if let Some(after_colon) = url.strip_prefix(\"git@\").and_then(|s| {\n   317→        // Find the colon that separates host from path\n   318→        s.split_once(':').map(|(_, path)| path)\n   319→    }) {\n   320→        let org = after_colon.split('/').next()?;\n   321→        if org.is_empty() {\n   322→            return None;\n   323→        }\n   324→        return Some(org.to_string());\n   325→    }\n   326→\n   327→    // HTTPS: https://github.com/org/repo.git\n   328→    if url.starts_with(\"https://\") || url.starts_with(\"http://\") {\n   329→        // Split on '/' and take the path segments after the host\n   330→        let without_scheme = url\n   331→            .strip_prefix(\"https://\")\n   332→            .or_else(|| url.strip_prefix(\"http://\"))?;\n   333→        let mut segments = without_scheme.split('/');\n   334→        let _host = segments.next(); // e.g. \"github.com\"\n   335→        let org = segments.next()?;\n   336→        if org.is_empty() {\n   337→            return None;\n   338→        }\n   339→        return Some(org.to_string());\n   340→    }\n   341→\n   342→    None\n   343→}\n   344→\n   345→/// Read a git config value. Returns `Ok(None)` if the key is not set.\n   346→///\n   347→/// Distinguishes exit code 1 (key not set) from other exit codes (e.g., 2 for\n   348→/// invalid config file) to avoid silently swallowing genuine errors.\n   349→pub fn config_get(key: &str) -> Result<Option<String>> {\n   350→    let output = Command::new(\"git\")\n   351→        .args([\"config\", \"--get\", key])\n   352→        .output()\n   353→        .context(\"failed to execute git config --get\")?;\n   354→\n   355→    if !output.status.success() {\n   356→        // Exit code 1 means the key is not set — that is not an error.\n   357→        // Any other non-zero exit (e.g., code 2 for corrupt config) is a real error.\n   358→        let code = output.status.code().unwrap_or(-1);\n   359→        if code != 1 {\n   360→            let stderr = String::from_utf8_lossy(&output.stderr);\n   361→            bail!(\n   362→                \"git config --get {:?} failed (exit {}): {}\",\n   363→                key,\n   364→                code,\n   365→                stderr.trim()\n   366→            );\n   367→        }\n   368→        return Ok(None);\n   369→    }\n   370→\n   371→    let value =\n   372→        String::from_utf8(output.stdout).context(\"git config output was not valid UTF-8\")?;\n   373→    Ok(Some(value.trim().to_string()))\n   374→}\n   375→\n   376→/// Read a git config value from global scope. Returns `Ok(None)` if the key is not set.\n   377→///\n   378→/// Uses `--global` flag to read only the global config, not repo-local.\n   379→/// This is used for settings like `ai.barometer.org` that are set at install time.\n   380→pub fn config_get_global(key: &str) -> Result<Option<String>> {\n   381→    let output = Command::new(\"git\")\n   382→        .args([\"config\", \"--global\", \"--get\", key])\n   383→        .output()\n   384→        .context(\"failed to execute git config --global --get\")?;\n   385→\n   386→    if !output.status.success() {\n   387→        let code = output.status.code().unwrap_or(-1);\n   388→        if code != 1 {\n   389→            let stderr = String::from_utf8_lossy(&output.stderr);\n   390→            bail!(\n   391→                \"git config --global --get {:?} failed (exit {}): {}\",\n   392→                key,\n   393→                code,\n   394→                stderr.trim()\n   395→            );\n   396→        }\n   397→        return Ok(None);\n   398→    }\n   399→\n   400→    let value =\n   401→        String::from_utf8(output.stdout).context(\"git config output was not valid UTF-8\")?;\n   402→    Ok(Some(value.trim().to_string()))\n   403→}\n   404→\n   405→/// Write a git config value (repo-local scope).\n   406→pub fn config_set(key: &str, value: &str) -> Result<()> {\n   407→    let output = Command::new(\"git\")\n   408→        .args([\"config\", key, value])\n   409→        .output()\n   410→        .context(\"failed to execute git config set\")?;\n   411→\n   412→    if !output.status.success() {\n   413→        let stderr = String::from_utf8_lossy(&output.stderr);\n   414→        bail!(\"git config set failed: {}\", stderr.trim());\n   415→    }\n   416→    Ok(())\n   417→}\n   418→\n   419→/// Write a git config value in global scope (`--global`).\n   420→///\n   421→/// Used by the `install` subcommand to persist settings like\n   422→/// `core.hooksPath` and `ai.barometer.org` globally.\n   423→pub fn config_set_global(key: &str, value: &str) -> Result<()> {\n   424→    let output = Command::new(\"git\")\n   425→        .args([\"config\", \"--global\", key, value])\n   426→        .output()\n   427→        .context(\"failed to execute git config --global set\")?;\n   428→\n   429→    if !output.status.success() {\n   430→        let stderr = String::from_utf8_lossy(&output.stderr);\n   431→        bail!(\"git config --global set failed: {}\", stderr.trim());\n   432→    }\n   433→    Ok(())\n   434→}\n   435→\n   436→// ---------------------------------------------------------------------------\n   437→// Tests\n   438→// ---------------------------------------------------------------------------\n   439→\n   440→#[cfg(test)]\n   441→mod tests {\n   442→    use super::*;\n   443→    use serial_test::serial;\n   444→    use std::process::Command;\n   445→    use tempfile::TempDir;\n   446→\n   447→    /// Helper: create a temporary git repo with one commit.\n   448→    /// Returns the TempDir (which cleans up on drop) and sets the\n   449→    /// working directory for the test by returning a guard.\n   450→    ///\n   451→    /// Note: since we cannot change the process-wide CWD safely in\n   452→    /// parallel tests, all git commands in tests must use `-C <path>`.\n   453→    /// We provide a `git_in` helper for this.\n   454→    fn init_temp_repo() -> TempDir {\n   455→        let dir = TempDir::new().expect(\"failed to create temp dir\");\n   456→        let path = dir.path();\n   457→\n   458→        // git init\n   459→        run_git(path, &[\"init\"]);\n   460→        // Set required user config for commits\n   461→        run_git(path, &[\"config\", \"user.email\", \"test@test.com\"]);\n   462→        run_git(path, &[\"config\", \"user.name\", \"Test User\"]);\n   463→        // Create an initial commit\n   464→        std::fs::write(path.join(\"README.md\"), \"hello\").unwrap();\n   465→        run_git(path, &[\"add\", \"README.md\"]);\n   466→        run_git(path, &[\"commit\", \"-m\", \"initial commit\"]);\n   467→\n   468→        dir\n   469→    }\n   470→\n   471→    /// Run a git command inside the given directory, panicking on failure.\n   472→    fn run_git(dir: &std::path::Path, args: &[&str]) -> String {\n   473→        let output = Command::new(\"git\")\n   474→            .args([\"-C\", dir.to_str().unwrap()])\n   475→            .args(args)\n   476→            .output()\n   477→            .expect(\"failed to run git\");\n   478→        if !output.status.success() {\n   479→            let stderr = String::from_utf8_lossy(&output.stderr);\n   480→            panic!(\"git {:?} failed: {}\", args, stderr);\n   481→        }\n   482→        String::from_utf8(output.stdout).unwrap().trim().to_string()\n   483→    }\n   484→\n   485→    /// Run one of our git module functions inside a specific directory\n   486→    /// by temporarily overriding GIT_DIR behaviour via `-C`.\n   487→    /// Since our public functions don't take a path arg (they rely on cwd),\n   488→    /// we use a wrapper approach: spawn a git command with `-C`.\n   489→    fn git_output_in(dir: &std::path::Path, args: &[&str]) -> Result<String> {\n   490→        let output = Command::new(\"git\")\n   491→            .args([\"-C\", dir.to_str().unwrap()])\n   492→            .args(args)\n   493→            .output()\n   494→            .context(\"failed to execute git\")?;\n   495→\n   496→        if !output.status.success() {\n   497→            let stderr = String::from_utf8_lossy(&output.stderr);\n   498→            bail!(\"git {} failed: {}\", args.join(\" \"), stderr.trim());\n   499→        }\n   500→\n   501→        let stdout = String::from_utf8(output.stdout).context(\"git output was not valid UTF-8\")?;\n   502→        Ok(stdout.trim().to_string())\n   503→    }\n   504→\n   505→    // -----------------------------------------------------------------------\n   506→    // repo_root — tested via direct git command in temp dir\n   507→    // -----------------------------------------------------------------------\n   508→\n   509→    #[test]\n   510→    fn test_repo_root() {\n   511→        let dir = init_temp_repo();\n   512→        let root = git_output_in(dir.path(), &[\"rev-parse\", \"--show-toplevel\"]).unwrap();\n   513→        let root_path = PathBuf::from(&root);\n   514→        // The root should be the temp dir (possibly canonicalized)\n   515→        assert!(root_path.exists());\n   516→        // The root should contain the README we created\n   517→        assert!(root_path.join(\"README.md\").exists());\n   518→    }\n   519→\n   520→    // -----------------------------------------------------------------------\n   521→    // head_hash\n   522→    // -----------------------------------------------------------------------\n   523→\n   524→    #[test]\n   525→    fn test_head_hash() {\n   526→        let dir = init_temp_repo();\n   527→        let hash = git_output_in(dir.path(), &[\"rev-parse\", \"HEAD\"]).unwrap();\n   528→        // Full SHA is 40 hex characters\n   529→        assert_eq!(hash.len(), 40);\n   530→        assert!(hash.chars().all(|c| c.is_ascii_hexdigit()));\n   531→    }\n   532→\n   533→    // -----------------------------------------------------------------------\n   534→    // head_timestamp\n   535→    // -----------------------------------------------------------------------\n   536→\n   537→    #[test]\n   538→    fn test_head_timestamp() {\n   539→        let dir = init_temp_repo();\n   540→        let ts_str = git_output_in(dir.path(), &[\"show\", \"-s\", \"--format=%ct\", \"HEAD\"]).unwrap();\n   541→        let ts: i64 = ts_str.parse().unwrap();\n   542→        // Should be a reasonable Unix timestamp (after 2020)\n   543→        assert!(ts > 1_577_836_800);\n   544→    }\n   545→\n   546→    // -----------------------------------------------------------------------\n   547→    // note_exists + add_note\n   548→    // -----------------------------------------------------------------------\n   549→\n   550→    #[test]\n   551→    fn test_note_exists_false_then_true_after_add() {\n   552→        let dir = init_temp_repo();\n   553→        let path = dir.path();\n   554→        let hash = run_git(path, &[\"rev-parse\", \"HEAD\"]);\n   555→\n   556→        // No note yet\n   557→        let status = Command::new(\"git\")\n   558→            .args([\"-C\", path.to_str().unwrap()])\n   559→            .args([\"notes\", \"--ref\", NOTES_REF, \"show\", &hash])\n   560→            .stdout(std::process::Stdio::null())\n   561→            .stderr(std::process::Stdio::null())\n   562→            .status()\n   563→            .unwrap();\n   564→        assert!(!status.success());\n   565→\n   566→        // Add a note\n   567→        run_git(\n   568→            path,\n   569→            &[\n   570→                \"notes\",\n   571→                \"--ref\",\n   572→                NOTES_REF,\n   573→                \"add\",\n   574→                \"-m\",\n   575→                \"test note content\",\n   576→                &hash,\n   577→            ],\n   578→        );\n   579→\n   580→        // Now note exists\n   581→        let status = Command::new(\"git\")\n   582→            .args([\"-C\", path.to_str().unwrap()])\n   583→            .args([\"notes\", \"--ref\", NOTES_REF, \"show\", &hash])\n   584→            .stdout(std::process::Stdio::null())\n   585→            .stderr(std::process::Stdio::null())\n   586→            .status()\n   587→            .unwrap();\n   588→        assert!(status.success());\n   589→\n   590→        // Verify content\n   591→        let note_content =\n   592→            git_output_in(path, &[\"notes\", \"--ref\", NOTES_REF, \"show\", &hash]).unwrap();\n   593→        assert_eq!(note_content, \"test note content\");\n   594→    }\n   595→\n   596→    // -----------------------------------------------------------------------\n   597→    // has_upstream\n   598→    // -----------------------------------------------------------------------\n   599→\n   600→    #[test]\n   601→    fn test_has_upstream_false_when_no_remote() {\n   602→        let dir = init_temp_repo();\n   603→        let remotes = git_output_in(dir.path(), &[\"remote\"]).unwrap();\n   604→        assert!(remotes.is_empty());\n   605→    }\n   606→\n   607→    #[test]\n   608→    fn test_has_upstream_true_when_remote_added() {\n   609→        let dir = init_temp_repo();\n   610→        let path = dir.path();\n   611→        run_git(\n   612→            path,\n   613→            &[\n   614→                \"remote\",\n   615→                \"add\",\n   616→                \"origin\",\n   617→                \"https://github.com/test-org/test-repo.git\",\n   618→            ],\n   619→        );\n   620→        let remotes = git_output_in(path, &[\"remote\"]).unwrap();\n   621→        assert!(!remotes.is_empty());\n   622→    }\n   623→\n   624→    // -----------------------------------------------------------------------\n   625→    // remote_org (via parse_org_from_url — pure function)\n   626→    // -----------------------------------------------------------------------\n   627→\n   628→    #[test]\n   629→    fn test_parse_org_from_ssh_url() {\n   630→        let org = parse_org_from_url(\"git@github.com:my-org/my-repo.git\");\n   631→        assert_eq!(org, Some(\"my-org\".to_string()));\n   632→    }\n   633→\n   634→    #[test]\n   635→    fn test_parse_org_from_https_url() {\n   636→        let org = parse_org_from_url(\"https://github.com/other-org/some-repo.git\");\n   637→        assert_eq!(org, Some(\"other-org\".to_string()));\n   638→    }\n   639→\n   640→    #[test]\n   641→    fn test_parse_org_from_http_url() {\n   642→        let org = parse_org_from_url(\"http://github.com/http-org/repo.git\");\n   643→        assert_eq!(org, Some(\"http-org\".to_string()));\n   644→    }\n   645→\n   646→    #[test]\n   647→    fn test_parse_org_from_unknown_url() {\n   648→        let org = parse_org_from_url(\"svn://example.com/repo\");\n   649→        assert_eq!(org, None);\n   650→    }\n   651→\n   652→    #[test]\n   653→    fn test_parse_org_empty_url() {\n   654→        let org = parse_org_from_url(\"\");\n   655→        assert_eq!(org, None);\n   656→    }\n   657→\n   658→    // -----------------------------------------------------------------------\n   659→    // parse_org_from_url (integration test with temp repo)\n   660→    // -----------------------------------------------------------------------\n   661→\n   662→    #[test]\n   663→    fn test_parse_org_from_url_integration() {\n   664→        let dir = init_temp_repo();\n   665→        let path = dir.path();\n   666→        run_git(\n   667→            path,\n   668→            &[\n   669→                \"remote\",\n   670→                \"add\",\n   671→                \"origin\",\n   672→                \"git@github.com:acme-corp/widgets.git\",\n   673→            ],\n   674→        );\n   675→        let url = git_output_in(path, &[\"remote\", \"get-url\", \"origin\"]).unwrap();\n   676→        let org = parse_org_from_url(&url);\n   677→        assert_eq!(org, Some(\"acme-corp\".to_string()));\n   678→    }\n   679→\n   680→    // -----------------------------------------------------------------------\n   681→    // config_get + config_set\n   682→    // -----------------------------------------------------------------------\n   683→\n   684→    #[test]\n   685→    fn test_config_get_missing_key() {\n   686→        let dir = init_temp_repo();\n   687→        let path = dir.path();\n   688→        let output = Command::new(\"git\")\n   689→            .args([\"-C\", path.to_str().unwrap()])\n   690→            .args([\"config\", \"--get\", \"ai.barometer.nonexistent\"])\n   691→            .output()\n   692→            .unwrap();\n   693→        // Should exit non-zero (key not set)\n   694→        assert!(!output.status.success());\n   695→    }\n   696→\n   697→    #[test]\n   698→    fn test_config_set_then_get() {\n   699→        let dir = init_temp_repo();\n   700→        let path = dir.path();\n   701→\n   702→        // Set a config value\n   703→        run_git(path, &[\"config\", \"ai.barometer.autopush\", \"true\"]);\n   704→\n   705→        // Read it back\n   706→        let value = git_output_in(path, &[\"config\", \"--get\", \"ai.barometer.autopush\"]).unwrap();\n   707→        assert_eq!(value, \"true\");\n   708→    }\n   709→\n   710→    #[test]\n   711→    fn test_config_overwrite() {\n   712→        let dir = init_temp_repo();\n   713→        let path = dir.path();\n   714→\n   715→        run_git(path, &[\"config\", \"ai.barometer.org\", \"first-org\"]);\n   716→        run_git(path, &[\"config\", \"ai.barometer.org\", \"second-org\"]);\n   717→\n   718→        let value = git_output_in(path, &[\"config\", \"--get\", \"ai.barometer.org\"]).unwrap();\n   719→        assert_eq!(value, \"second-org\");\n   720→    }\n   721→\n   722→    // -----------------------------------------------------------------------\n   723→    // Multiple commits — verify head_hash changes\n   724→    // -----------------------------------------------------------------------\n   725→\n   726→    #[test]\n   727→    fn test_head_hash_changes_after_new_commit() {\n   728→        let dir = init_temp_repo();\n   729→        let path = dir.path();\n   730→\n   731→        let hash1 = run_git(path, &[\"rev-parse\", \"HEAD\"]);\n   732→\n   733→        // Make another commit\n   734→        std::fs::write(path.join(\"file2.txt\"), \"content\").unwrap();\n   735→        run_git(path, &[\"add\", \"file2.txt\"]);\n   736→        run_git(path, &[\"commit\", \"-m\", \"second commit\"]);\n   737→\n   738→        let hash2 = run_git(path, &[\"rev-parse\", \"HEAD\"]);\n   739→\n   740→        assert_ne!(hash1, hash2);\n   741→        assert_eq!(hash2.len(), 40);\n   742→    }\n   743→\n   744→    // -----------------------------------------------------------------------\n   745→    // validate_commit_hash\n   746→    // -----------------------------------------------------------------------\n   747→\n   748→    #[test]\n   749→    fn test_validate_commit_hash_valid_short() {\n   750→        assert!(validate_commit_hash(\"abcdef0\").is_ok());\n   751→    }\n   752→\n   753→    #[test]\n   754→    fn test_validate_commit_hash_valid_full() {\n   755→        assert!(validate_commit_hash(\"abcdef0123456789abcdef0123456789abcdef01\").is_ok());\n   756→    }\n   757→\n   758→    #[test]\n   759→    fn test_validate_commit_hash_rejects_flag_injection() {\n   760→        assert!(validate_commit_hash(\"--help\").is_err());\n   761→    }\n   762→\n   763→    #[test]\n   764→    fn test_validate_commit_hash_rejects_too_short() {\n   765→        assert!(validate_commit_hash(\"abc\").is_err());\n   766→    }\n   767→\n   768→    #[test]\n   769→    fn test_validate_commit_hash_rejects_non_hex() {\n   770→        assert!(validate_commit_hash(\"ghijklm\").is_err());\n   771→    }\n   772→\n   773→    #[test]\n   774→    fn test_validate_commit_hash_rejects_empty() {\n   775→        assert!(validate_commit_hash(\"\").is_err());\n   776→    }\n   777→\n   778→    #[test]\n   779→    fn test_validate_commit_hash_rejects_too_long() {\n   780→        assert!(validate_commit_hash(\"a\".repeat(41).as_str()).is_err());\n   781→    }\n   782→\n   783→    // -----------------------------------------------------------------------\n   784→    // parse_org_from_url — edge cases\n   785→    // -----------------------------------------------------------------------\n   786→\n   787→    #[test]\n   788→    fn test_parse_org_from_url_https_with_trailing_slash() {\n   789→        // Trailing slash after org — org segment should still parse\n   790→        let org = parse_org_from_url(\"https://github.com/org/\");\n   791→        assert_eq!(org, Some(\"org\".to_string()));\n   792→    }\n   793→\n   794→    #[test]\n   795→    fn test_parse_org_from_url_https_host_only() {\n   796→        // No org segment after host\n   797→        let org = parse_org_from_url(\"https://github.com/\");\n   798→        assert_eq!(org, None);\n   799→    }\n   800→\n   801→    #[test]\n   802→    fn test_parse_org_from_url_https_host_no_trailing_slash() {\n   803→        let org = parse_org_from_url(\"https://github.com\");\n   804→        assert_eq!(org, None);\n   805→    }\n   806→\n   807→    #[test]\n   808→    fn test_parse_org_from_url_ssh_nested_path() {\n   809→        // SSH with nested paths — org is the first segment after the colon\n   810→        let org = parse_org_from_url(\"git@github.com:org/sub/repo.git\");\n   811→        assert_eq!(org, Some(\"org\".to_string()));\n   812→    }\n   813→\n   814→    #[test]\n   815→    fn test_parse_org_from_url_https_with_port() {\n   816→        let org = parse_org_from_url(\"https://github.com:443/org/repo.git\");\n   817→        // The host segment is \"github.com:443\", org is next path segment\n   818→        assert_eq!(org, Some(\"org\".to_string()));\n   819→    }\n   820→\n   821→    #[test]\n   822→    fn test_parse_org_from_url_https_with_auth() {\n   823→        // URL with authentication credentials embedded\n   824→        let org = parse_org_from_url(\"https://user:pass@github.com/org/repo.git\");\n   825→        // \"user:pass@github.com\" is treated as host, \"org\" is the org\n   826→        assert_eq!(org, Some(\"org\".to_string()));\n   827→    }\n   828→\n   829→    // -----------------------------------------------------------------------\n   830→    // Public API tests — use set_current_dir, must run serially\n   831→    //\n   832→    // These tests exercise the actual Rust wrapper functions against temp\n   833→    // repos to ensure the wrappers (argument order, trim, error mapping)\n   834→    // work correctly, not just the underlying git commands.\n   835→    // -----------------------------------------------------------------------\n   836→\n   837→    /// Helper: create a temp repo and chdir into it. Returns the TempDir\n   838→    /// (must be kept alive to prevent cleanup) and the original cwd for\n   839→    /// restoration.\n   840→    fn enter_temp_repo() -> (TempDir, PathBuf) {\n   841→        let original_cwd = std::env::current_dir().expect(\"failed to get cwd\");\n   842→        let dir = init_temp_repo();\n   843→        std::env::set_current_dir(dir.path()).expect(\"failed to chdir into temp repo\");\n   844→        (dir, original_cwd)\n   845→    }\n   846→\n   847→    #[test]\n   848→    #[serial]\n   849→    fn test_api_repo_root() {\n   850→        let (_dir, original_cwd) = enter_temp_repo();\n   851→        let root = repo_root().expect(\"repo_root failed\");\n   852→        assert!(root.join(\"README.md\").exists());\n   853→        std::env::set_current_dir(original_cwd).unwrap();\n   854→    }\n   855→\n   856→    #[test]\n   857→    #[serial]\n   858→    fn test_api_head_hash() {\n   859→        let (_dir, original_cwd) = enter_temp_repo();\n   860→        let hash = head_hash().expect(\"head_hash failed\");\n   861→        assert_eq!(hash.len(), 40);\n   862→        assert!(hash.chars().all(|c| c.is_ascii_hexdigit()));\n   863→        std::env::set_current_dir(original_cwd).unwrap();\n   864→    }\n   865→\n   866→    #[test]\n   867→    #[serial]\n   868→    fn test_api_head_timestamp() {\n   869→        let (_dir, original_cwd) = enter_temp_repo();\n   870→        let ts = head_timestamp().expect(\"head_timestamp failed\");\n   871→        assert!(ts > 1_577_836_800); // After 2020\n   872→        std::env::set_current_dir(original_cwd).unwrap();\n   873→    }\n   874→\n   875→    #[test]\n   876→    #[serial]\n   877→    fn test_api_note_exists_and_add_note() {\n   878→        let (_dir, original_cwd) = enter_temp_repo();\n   879→        let hash = head_hash().expect(\"head_hash failed\");\n   880→\n   881→        // No note yet\n   882→        assert!(!note_exists(&hash).expect(\"note_exists failed\"));\n   883→\n   884→        // Add a note via the public API\n   885→        add_note(&hash, \"test session data\").expect(\"add_note failed\");\n   886→\n   887→        // Now it should exist\n   888→        assert!(note_exists(&hash).expect(\"note_exists failed after add\"));\n   889→\n   890→        std::env::set_current_dir(original_cwd).unwrap();\n   891→    }\n   892→\n   893→    #[test]\n   894→    #[serial]\n   895→    fn test_api_has_upstream_no_remote() {\n   896→        let (_dir, original_cwd) = enter_temp_repo();\n   897→        assert!(!has_upstream().expect(\"has_upstream failed\"));\n   898→        std::env::set_current_dir(original_cwd).unwrap();\n   899→    }\n   900→\n   901→    #[test]\n   902→    #[serial]\n   903→    fn test_api_has_upstream_with_remote() {\n   904→        let (dir, original_cwd) = enter_temp_repo();\n   905→        run_git(\n   906→            dir.path(),\n   907→            &[\n   908→                \"remote\",\n   909→                \"add\",\n   910→                \"origin\",\n   911→                \"https://github.com/test-org/test-repo.git\",\n   912→            ],\n   913→        );\n   914→        assert!(has_upstream().expect(\"has_upstream failed\"));\n   915→        std::env::set_current_dir(original_cwd).unwrap();\n   916→    }\n   917→\n   918→    #[test]\n   919→    #[serial]\n   920→    fn test_api_config_get_missing() {\n   921→        let (_dir, original_cwd) = enter_temp_repo();\n   922→        let val = config_get(\"ai.barometer.nonexistent\").expect(\"config_get failed\");\n   923→        assert_eq!(val, None);\n   924→        std::env::set_current_dir(original_cwd).unwrap();\n   925→    }\n   926→\n   927→    #[test]\n   928→    #[serial]\n   929→    fn test_api_config_set_then_get() {\n   930→        let (_dir, original_cwd) = enter_temp_repo();\n   931→        config_set(\"ai.barometer.autopush\", \"true\").expect(\"config_set failed\");\n   932→        let val = config_get(\"ai.barometer.autopush\").expect(\"config_get failed\");\n   933→        assert_eq!(val, Some(\"true\".to_string()));\n   934→        std::env::set_current_dir(original_cwd).unwrap();\n   935→    }\n   936→\n   937→    // -----------------------------------------------------------------------\n   938→    // check_enabled\n   939→    // -----------------------------------------------------------------------\n   940→\n   941→    #[test]\n   942→    #[serial]\n   943→    fn test_check_enabled_default_true() {\n   944→        let (_dir, original_cwd) = enter_temp_repo();\n   945→\n   946→        // No config set -- should default to enabled\n   947→        assert!(check_enabled());\n   948→\n   949→        std::env::set_current_dir(original_cwd).unwrap();\n   950→    }\n   951→\n   952→    #[test]\n   953→    #[serial]\n   954→    fn test_check_enabled_explicitly_true() {\n   955→        let (dir, original_cwd) = enter_temp_repo();\n   956→\n   957→        run_git(dir.path(), &[\"config\", \"ai.barometer.enabled\", \"true\"]);\n   958→        assert!(check_enabled());\n   959→\n   960→        std::env::set_current_dir(original_cwd).unwrap();\n   961→    }\n   962→\n   963→    #[test]\n   964→    #[serial]\n   965→    fn test_check_enabled_explicitly_false() {\n   966→        let (dir, original_cwd) = enter_temp_repo();\n   967→\n   968→        run_git(dir.path(), &[\"config\", \"ai.barometer.enabled\", \"false\"]);\n   969→        assert!(!check_enabled());\n   970→\n   971→        std::env::set_current_dir(original_cwd).unwrap();\n   972→    }\n   973→\n   974→    #[test]\n   975→    #[serial]\n   976→    fn test_check_enabled_other_value_treated_as_true() {\n   977→        let (dir, original_cwd) = enter_temp_repo();\n   978→\n   979→        run_git(dir.path(), &[\"config\", \"ai.barometer.enabled\", \"yes\"]);\n   980→        assert!(check_enabled());\n   981→\n   982→        std::env::set_current_dir(original_cwd).unwrap();\n   983→    }\n   984→\n   985→    // -----------------------------------------------------------------------\n   986→    // Phase 12 hardening: detached HEAD\n   987→    // -----------------------------------------------------------------------\n   988→\n   989→    #[test]\n   990→    fn test_head_hash_works_in_detached_head() {\n   991→        let dir = init_temp_repo();\n   992→        let path = dir.path();\n   993→\n   994→        // Get the current HEAD hash, then detach HEAD\n   995→        let hash = run_git(path, &[\"rev-parse\", \"HEAD\"]);\n   996→        run_git(path, &[\"checkout\", \"--detach\", \"HEAD\"]);\n   997→\n   998→        // `git rev-parse HEAD` should still return the same hash in detached state\n   999→        let detached_hash = git_output_in(path, &[\"rev-parse\", \"HEAD\"]).unwrap();\n  1000→        assert_eq!(hash, detached_hash);\n  1001→        assert_eq!(detached_hash.len(), 40);\n  1002→    }\n  1003→\n  1004→    #[test]\n  1005→    fn test_head_timestamp_works_in_detached_head() {\n  1006→        let dir = init_temp_repo();\n  1007→        let path = dir.path();\n  1008→\n  1009→        // Get the timestamp before detaching\n  1010→        let ts_before = git_output_in(path, &[\"show\", \"-s\", \"--format=%ct\", \"HEAD\"]).unwrap();\n  1011→\n  1012→        run_git(path, &[\"checkout\", \"--detach\", \"HEAD\"]);\n  1013→\n  1014→        // Timestamp should still be readable in detached state\n  1015→        let ts_after = git_output_in(path, &[\"show\", \"-s\", \"--format=%ct\", \"HEAD\"]).unwrap();\n  1016→        assert_eq!(ts_before, ts_after);\n  1017→    }\n  1018→\n  1019→    #[test]\n  1020→    fn test_note_operations_work_in_detached_head() {\n  1021→        let dir = init_temp_repo();\n  1022→        let path = dir.path();\n  1023→\n  1024→        let hash = run_git(path, &[\"rev-parse\", \"HEAD\"]);\n  1025→        run_git(path, &[\"checkout\", \"--detach\", \"HEAD\"]);\n  1026→\n  1027→        // note_exists_at should work in detached HEAD\n  1028→        let exists = note_exists_at(path, &hash).expect(\"note_exists_at failed in detached HEAD\");\n  1029→        assert!(!exists);\n  1030→\n  1031→        // add_note_at should work in detached HEAD\n  1032→        add_note_at(path, &hash, \"test detached note\")\n  1033→            .expect(\"add_note_at failed in detached HEAD\");\n  1034→\n  1035→        // Verify the note was attached\n  1036→        let exists = note_exists_at(path, &hash).expect(\"note_exists_at failed after add\");\n  1037→        assert!(exists);\n  1038→    }\n  1039→\n  1040→    // -----------------------------------------------------------------------\n  1041→    // Phase 12 hardening: repo with no remotes\n  1042→    // -----------------------------------------------------------------------\n  1043→\n  1044→    #[test]\n  1045→    #[serial]\n  1046→    fn test_push_notes_fails_gracefully_no_remote() {\n  1047→        let (_dir, original_cwd) = enter_temp_repo();\n  1048→\n  1049→        // push_notes should fail (no remote) but not panic\n  1050→        let result = push_notes();\n  1051→        assert!(result.is_err());\n  1052→\n  1053→        std::env::set_current_dir(original_cwd).unwrap();\n  1054→    }\n  1055→\n  1056→    #[test]\n  1057→    #[serial]\n  1058→    fn test_remote_orgs_empty_when_no_remotes() {\n  1059→        let (_dir, original_cwd) = enter_temp_repo();\n  1060→\n  1061→        let orgs = remote_orgs().expect(\"remote_orgs failed\");\n  1062→        assert!(orgs.is_empty());\n  1063→\n  1064→        std::env::set_current_dir(original_cwd).unwrap();\n  1065→    }\n  1066→}\n  1067→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"uuid":"986551ff-0497-43c6-92fa-2c41d9ad39f8","timestamp":"2026-02-09T20:28:14.581Z","toolUseResult":{"type":"text","file":{"filePath":"/Users/daveslutzkin/dev/ai-barometer/src/git.rs","content":"//! Git utility helpers.\n//!\n//! All functions shell out to `git` via `std::process::Command`.\n//! The notes ref used throughout is `refs/notes/ai-sessions`.\n\nuse anyhow::{Context, Result, bail};\nuse std::io::Write;\nuse std::path::{Path, PathBuf};\nuse std::process::Command;\n\n/// The dedicated git notes ref for AI session data.\nconst NOTES_REF: &str = \"refs/notes/ai-sessions\";\n\n/// Validate that a commit hash is a valid hex string of 7-40 characters.\n///\n/// This prevents flag injection (e.g., passing `--help` as a commit) and\n/// ensures we only pass well-formed refs to git.\npub(crate) fn validate_commit_hash(commit: &str) -> Result<()> {\n    let is_valid =\n        commit.len() >= 7 && commit.len() <= 40 && commit.bytes().all(|b| b.is_ascii_hexdigit());\n    if !is_valid {\n        bail!(\n            \"invalid commit hash {:?}: must be 7-40 lowercase hex characters\",\n            commit\n        );\n    }\n    Ok(())\n}\n\n// ---------------------------------------------------------------------------\n// Internal helper\n// ---------------------------------------------------------------------------\n\n/// Run a git command and return its stdout as a trimmed `String`.\n/// Returns an error if the command exits with a non-zero status.\nfn git_output(args: &[&str]) -> Result<String> {\n    let output = Command::new(\"git\")\n        .args(args)\n        .output()\n        .context(\"failed to execute git\")?;\n\n    if !output.status.success() {\n        let stderr = String::from_utf8_lossy(&output.stderr);\n        bail!(\n            \"git {} failed (exit {}): {}\",\n            args.join(\" \"),\n            output.status,\n            stderr.trim()\n        );\n    }\n\n    let stdout = String::from_utf8(output.stdout).context(\"git output was not valid UTF-8\")?;\n    Ok(stdout.trim().to_string())\n}\n\n/// Run a git command and return whether it succeeded (exit code 0).\n/// Does not treat non-zero exit as an error — just returns `false`.\nfn git_succeeds(args: &[&str]) -> Result<bool> {\n    let status = Command::new(\"git\")\n        .args(args)\n        .stdout(std::process::Stdio::null())\n        .stderr(std::process::Stdio::null())\n        .status()\n        .context(\"failed to execute git\")?;\n    Ok(status.success())\n}\n\n// ---------------------------------------------------------------------------\n// Public API\n// ---------------------------------------------------------------------------\n\n/// Check whether AI Barometer is enabled for the current repository.\n///\n/// Reads `git config ai.barometer.enabled`. If the value is exactly\n/// `\"false\"`, returns `false` -- the caller should skip ALL processing\n/// (session scanning, note attachment, pending records, push, retry).\n/// Any other value (including unset) returns `true`.\n///\n/// This is placed in the `git` module (not `push`) because it gates\n/// the entire hook lifecycle, not just the push decision.\npub fn check_enabled() -> bool {\n    match config_get(\"ai.barometer.enabled\") {\n        Ok(Some(val)) => val != \"false\",\n        // Unset or error: default to enabled\n        _ => true,\n    }\n}\n\n/// Check whether AI Barometer is enabled for a specific repository directory.\n///\n/// This is the directory-parameterised version of [`check_enabled`], for use\n/// by commands that operate on repos other than the CWD (e.g., `hydrate`).\n///\n/// Reads `git -C <repo> config ai.barometer.enabled`. If the value is exactly\n/// `\"false\"`, returns `false`. Any other value (including unset) returns `true`.\npub(crate) fn check_enabled_at(repo: &Path) -> bool {\n    let repo_str = repo.to_string_lossy();\n    let output = Command::new(\"git\")\n        .args([\"-C\", &repo_str, \"config\", \"--get\", \"ai.barometer.enabled\"])\n        .output();\n\n    match output {\n        Ok(o) if o.status.success() => {\n            let value = String::from_utf8_lossy(&o.stdout).trim().to_string();\n            value != \"false\"\n        }\n        // Unset (exit code 1) or error: default to enabled\n        _ => true,\n    }\n}\n\n/// Return the repository root (`git rev-parse --show-toplevel`).\npub fn repo_root() -> Result<PathBuf> {\n    let path = git_output(&[\"rev-parse\", \"--show-toplevel\"])?;\n    Ok(PathBuf::from(path))\n}\n\n/// Return the repository root for a given working directory.\n///\n/// Runs `git -C <dir> rev-parse --show-toplevel`. This handles the case\n/// where `dir` is a subdirectory of the repo.\npub(crate) fn repo_root_at(dir: &Path) -> Result<PathBuf> {\n    let dir_str = dir.to_string_lossy();\n    let output = Command::new(\"git\")\n        .args([\"-C\", &dir_str, \"rev-parse\", \"--show-toplevel\"])\n        .output()\n        .context(\"failed to execute git rev-parse --show-toplevel\")?;\n\n    if !output.status.success() {\n        let stderr = String::from_utf8_lossy(&output.stderr);\n        bail!(\"git rev-parse --show-toplevel failed: {}\", stderr.trim());\n    }\n\n    let stdout = String::from_utf8(output.stdout).context(\"git output was not valid UTF-8\")?;\n    Ok(PathBuf::from(stdout.trim()))\n}\n\n/// Check whether an AI-session note already exists for the given commit,\n/// in a specific repository directory.\n///\n/// This is the directory-parameterised version of [`note_exists`], for use\n/// by commands that operate on repos other than the CWD (e.g., `hydrate`).\npub(crate) fn note_exists_at(repo: &Path, commit: &str) -> Result<bool> {\n    validate_commit_hash(commit)?;\n    let repo_str = repo.to_string_lossy();\n    let status = Command::new(\"git\")\n        .args([\n            \"-C\", &repo_str, \"notes\", \"--ref\", NOTES_REF, \"show\", \"--\", commit,\n        ])\n        .stdout(std::process::Stdio::null())\n        .stderr(std::process::Stdio::null())\n        .status()\n        .context(\"failed to execute git notes show\")?;\n    Ok(status.success())\n}\n\n/// Attach an AI-session note to a commit in a specific repository directory.\n///\n/// This is the directory-parameterised version of [`add_note`], for use\n/// by commands that operate on repos other than the CWD (e.g., `hydrate`).\n///\n/// **Precondition:** Callers must check [`note_exists_at`] first and skip if\n/// a note is already present.\npub(crate) fn add_note_at(repo: &Path, commit: &str, content: &str) -> Result<()> {\n    validate_commit_hash(commit)?;\n\n    // Write content to a temp file to avoid ARG_MAX limits on large notes.\n    let mut tmp = tempfile::NamedTempFile::new().context(\"failed to create temp file for note\")?;\n    tmp.write_all(content.as_bytes())\n        .context(\"failed to write note to temp file\")?;\n    tmp.flush().context(\"failed to flush note temp file\")?;\n    let tmp_path = tmp.path().to_string_lossy().to_string();\n\n    let repo_str = repo.to_string_lossy();\n    let output = Command::new(\"git\")\n        .args([\n            \"-C\", &repo_str, \"notes\", \"--ref\", NOTES_REF, \"add\", \"-F\", &tmp_path, \"--\", commit,\n        ])\n        .output()\n        .context(\"failed to execute git notes add\")?;\n\n    if !output.status.success() {\n        let stderr = String::from_utf8_lossy(&output.stderr);\n        bail!(\"git notes add failed: {}\", stderr.trim());\n    }\n    Ok(())\n}\n\n/// Check whether a commit exists in a given repository.\n///\n/// Runs `git -C <repo> cat-file -t -- <commit>` and checks for success.\n/// The `--` separator prevents the commit argument from being interpreted\n/// as a flag.\npub(crate) fn commit_exists_at(repo: &Path, commit: &str) -> Result<bool> {\n    let repo_str = repo.to_string_lossy();\n    let status = Command::new(\"git\")\n        .args([\"-C\", &repo_str, \"cat-file\", \"-t\", \"--\", commit])\n        .stdout(std::process::Stdio::null())\n        .stderr(std::process::Stdio::null())\n        .status()\n        .context(\"failed to execute git cat-file\")?;\n    Ok(status.success())\n}\n\n/// Return the full 40-character SHA of HEAD.\npub fn head_hash() -> Result<String> {\n    git_output(&[\"rev-parse\", \"HEAD\"])\n}\n\n/// Return the commit timestamp of HEAD as a Unix epoch `i64`.\npub fn head_timestamp() -> Result<i64> {\n    let ts_str = git_output(&[\"show\", \"-s\", \"--format=%ct\", \"HEAD\"])?;\n    ts_str\n        .parse::<i64>()\n        .context(\"failed to parse HEAD timestamp as i64\")\n}\n\n/// Check whether an AI-session note already exists for the given commit.\npub fn note_exists(commit: &str) -> Result<bool> {\n    validate_commit_hash(commit)?;\n    git_succeeds(&[\"notes\", \"--ref\", NOTES_REF, \"show\", \"--\", commit])\n}\n\n/// Attach an AI-session note to the given commit.\n///\n/// **Precondition:** Callers must check [`note_exists`] first and skip if a note\n/// is already present. `git notes add` will fail if a note already exists for the\n/// given commit. The PLAN.md deduplication rules require checking before attaching:\n/// \"if a note already exists, treat as success, do nothing.\"\npub fn add_note(commit: &str, content: &str) -> Result<()> {\n    validate_commit_hash(commit)?;\n\n    // Write content to a temp file to avoid ARG_MAX limits on large notes.\n    let mut tmp = tempfile::NamedTempFile::new().context(\"failed to create temp file for note\")?;\n    tmp.write_all(content.as_bytes())\n        .context(\"failed to write note to temp file\")?;\n    tmp.flush().context(\"failed to flush note temp file\")?;\n    let tmp_path = tmp.path().to_string_lossy().to_string();\n\n    let output = Command::new(\"git\")\n        .args([\n            \"notes\", \"--ref\", NOTES_REF, \"add\", \"-F\", &tmp_path, \"--\", commit,\n        ])\n        .output()\n        .context(\"failed to execute git notes add\")?;\n\n    if !output.status.success() {\n        let stderr = String::from_utf8_lossy(&output.stderr);\n        bail!(\"git notes add failed: {}\", stderr.trim());\n    }\n    Ok(())\n}\n\n/// Push the AI-session notes ref to `origin`.\npub fn push_notes() -> Result<()> {\n    let output = Command::new(\"git\")\n        .args([\"push\", \"origin\", NOTES_REF])\n        .output()\n        .context(\"failed to execute git push\")?;\n\n    if !output.status.success() {\n        let stderr = String::from_utf8_lossy(&output.stderr);\n        bail!(\"git push notes failed: {}\", stderr.trim());\n    }\n    Ok(())\n}\n\n/// Check whether the repository has at least one configured remote.\n///\n/// Returns `Ok(false)` if `git remote` fails (e.g., not in a git repository)\n/// rather than propagating the error. This matches the `git_succeeds` pattern\n/// used by `note_exists` and makes the function safe to call defensively.\npub fn has_upstream() -> Result<bool> {\n    match git_output(&[\"remote\"]) {\n        Ok(remotes) => Ok(!remotes.is_empty()),\n        Err(_) => Ok(false),\n    }\n}\n\n/// Extract owner/org from ALL remote URLs.\n///\n/// Returns a deduplicated list of org names extracted from all configured\n/// remotes. Deduplication is case-insensitive (e.g., `My-Org` and `my-org`\n/// from different remotes are considered the same org; only the first\n/// encountered variant is kept). This is used for org filtering: \"Extract\n/// owner from **all** Git remotes. If **any** remote matches org, allowed.\"\n/// (PLAN.md)\n///\n/// Returns an empty Vec if no remotes are configured or no URLs can be parsed.\npub fn remote_orgs() -> Result<Vec<String>> {\n    let remotes = git_output(&[\"remote\"])?;\n    let mut orgs = Vec::new();\n\n    for remote_name in remotes.lines() {\n        if remote_name.is_empty() {\n            continue;\n        }\n        if let Ok(url) = git_output(&[\"remote\", \"get-url\", remote_name])\n            && let Some(org) = parse_org_from_url(&url)\n            && !orgs\n                .iter()\n                .any(|existing: &String| existing.eq_ignore_ascii_case(&org))\n        {\n            orgs.push(org);\n        }\n    }\n\n    Ok(orgs)\n}\n\n/// Parse the owner/org segment from a git remote URL.\n///\n/// This is a pure function extracted for testability.\npub fn parse_org_from_url(url: &str) -> Option<String> {\n    // SSH: git@github.com:org/repo.git\n    if let Some(after_colon) = url.strip_prefix(\"git@\").and_then(|s| {\n        // Find the colon that separates host from path\n        s.split_once(':').map(|(_, path)| path)\n    }) {\n        let org = after_colon.split('/').next()?;\n        if org.is_empty() {\n            return None;\n        }\n        return Some(org.to_string());\n    }\n\n    // HTTPS: https://github.com/org/repo.git\n    if url.starts_with(\"https://\") || url.starts_with(\"http://\") {\n        // Split on '/' and take the path segments after the host\n        let without_scheme = url\n            .strip_prefix(\"https://\")\n            .or_else(|| url.strip_prefix(\"http://\"))?;\n        let mut segments = without_scheme.split('/');\n        let _host = segments.next(); // e.g. \"github.com\"\n        let org = segments.next()?;\n        if org.is_empty() {\n            return None;\n        }\n        return Some(org.to_string());\n    }\n\n    None\n}\n\n/// Read a git config value. Returns `Ok(None)` if the key is not set.\n///\n/// Distinguishes exit code 1 (key not set) from other exit codes (e.g., 2 for\n/// invalid config file) to avoid silently swallowing genuine errors.\npub fn config_get(key: &str) -> Result<Option<String>> {\n    let output = Command::new(\"git\")\n        .args([\"config\", \"--get\", key])\n        .output()\n        .context(\"failed to execute git config --get\")?;\n\n    if !output.status.success() {\n        // Exit code 1 means the key is not set — that is not an error.\n        // Any other non-zero exit (e.g., code 2 for corrupt config) is a real error.\n        let code = output.status.code().unwrap_or(-1);\n        if code != 1 {\n            let stderr = String::from_utf8_lossy(&output.stderr);\n            bail!(\n                \"git config --get {:?} failed (exit {}): {}\",\n                key,\n                code,\n                stderr.trim()\n            );\n        }\n        return Ok(None);\n    }\n\n    let value =\n        String::from_utf8(output.stdout).context(\"git config output was not valid UTF-8\")?;\n    Ok(Some(value.trim().to_string()))\n}\n\n/// Read a git config value from global scope. Returns `Ok(None)` if the key is not set.\n///\n/// Uses `--global` flag to read only the global config, not repo-local.\n/// This is used for settings like `ai.barometer.org` that are set at install time.\npub fn config_get_global(key: &str) -> Result<Option<String>> {\n    let output = Command::new(\"git\")\n        .args([\"config\", \"--global\", \"--get\", key])\n        .output()\n        .context(\"failed to execute git config --global --get\")?;\n\n    if !output.status.success() {\n        let code = output.status.code().unwrap_or(-1);\n        if code != 1 {\n            let stderr = String::from_utf8_lossy(&output.stderr);\n            bail!(\n                \"git config --global --get {:?} failed (exit {}): {}\",\n                key,\n                code,\n                stderr.trim()\n            );\n        }\n        return Ok(None);\n    }\n\n    let value =\n        String::from_utf8(output.stdout).context(\"git config output was not valid UTF-8\")?;\n    Ok(Some(value.trim().to_string()))\n}\n\n/// Write a git config value (repo-local scope).\npub fn config_set(key: &str, value: &str) -> Result<()> {\n    let output = Command::new(\"git\")\n        .args([\"config\", key, value])\n        .output()\n        .context(\"failed to execute git config set\")?;\n\n    if !output.status.success() {\n        let stderr = String::from_utf8_lossy(&output.stderr);\n        bail!(\"git config set failed: {}\", stderr.trim());\n    }\n    Ok(())\n}\n\n/// Write a git config value in global scope (`--global`).\n///\n/// Used by the `install` subcommand to persist settings like\n/// `core.hooksPath` and `ai.barometer.org` globally.\npub fn config_set_global(key: &str, value: &str) -> Result<()> {\n    let output = Command::new(\"git\")\n        .args([\"config\", \"--global\", key, value])\n        .output()\n        .context(\"failed to execute git config --global set\")?;\n\n    if !output.status.success() {\n        let stderr = String::from_utf8_lossy(&output.stderr);\n        bail!(\"git config --global set failed: {}\", stderr.trim());\n    }\n    Ok(())\n}\n\n// ---------------------------------------------------------------------------\n// Tests\n// ---------------------------------------------------------------------------\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n    use serial_test::serial;\n    use std::process::Command;\n    use tempfile::TempDir;\n\n    /// Helper: create a temporary git repo with one commit.\n    /// Returns the TempDir (which cleans up on drop) and sets the\n    /// working directory for the test by returning a guard.\n    ///\n    /// Note: since we cannot change the process-wide CWD safely in\n    /// parallel tests, all git commands in tests must use `-C <path>`.\n    /// We provide a `git_in` helper for this.\n    fn init_temp_repo() -> TempDir {\n        let dir = TempDir::new().expect(\"failed to create temp dir\");\n        let path = dir.path();\n\n        // git init\n        run_git(path, &[\"init\"]);\n        // Set required user config for commits\n        run_git(path, &[\"config\", \"user.email\", \"test@test.com\"]);\n        run_git(path, &[\"config\", \"user.name\", \"Test User\"]);\n        // Create an initial commit\n        std::fs::write(path.join(\"README.md\"), \"hello\").unwrap();\n        run_git(path, &[\"add\", \"README.md\"]);\n        run_git(path, &[\"commit\", \"-m\", \"initial commit\"]);\n\n        dir\n    }\n\n    /// Run a git command inside the given directory, panicking on failure.\n    fn run_git(dir: &std::path::Path, args: &[&str]) -> String {\n        let output = Command::new(\"git\")\n            .args([\"-C\", dir.to_str().unwrap()])\n            .args(args)\n            .output()\n            .expect(\"failed to run git\");\n        if !output.status.success() {\n            let stderr = String::from_utf8_lossy(&output.stderr);\n            panic!(\"git {:?} failed: {}\", args, stderr);\n        }\n        String::from_utf8(output.stdout).unwrap().trim().to_string()\n    }\n\n    /// Run one of our git module functions inside a specific directory\n    /// by temporarily overriding GIT_DIR behaviour via `-C`.\n    /// Since our public functions don't take a path arg (they rely on cwd),\n    /// we use a wrapper approach: spawn a git command with `-C`.\n    fn git_output_in(dir: &std::path::Path, args: &[&str]) -> Result<String> {\n        let output = Command::new(\"git\")\n            .args([\"-C\", dir.to_str().unwrap()])\n            .args(args)\n            .output()\n            .context(\"failed to execute git\")?;\n\n        if !output.status.success() {\n            let stderr = String::from_utf8_lossy(&output.stderr);\n            bail!(\"git {} failed: {}\", args.join(\" \"), stderr.trim());\n        }\n\n        let stdout = String::from_utf8(output.stdout).context(\"git output was not valid UTF-8\")?;\n        Ok(stdout.trim().to_string())\n    }\n\n    // -----------------------------------------------------------------------\n    // repo_root — tested via direct git command in temp dir\n    // -----------------------------------------------------------------------\n\n    #[test]\n    fn test_repo_root() {\n        let dir = init_temp_repo();\n        let root = git_output_in(dir.path(), &[\"rev-parse\", \"--show-toplevel\"]).unwrap();\n        let root_path = PathBuf::from(&root);\n        // The root should be the temp dir (possibly canonicalized)\n        assert!(root_path.exists());\n        // The root should contain the README we created\n        assert!(root_path.join(\"README.md\").exists());\n    }\n\n    // -----------------------------------------------------------------------\n    // head_hash\n    // -----------------------------------------------------------------------\n\n    #[test]\n    fn test_head_hash() {\n        let dir = init_temp_repo();\n        let hash = git_output_in(dir.path(), &[\"rev-parse\", \"HEAD\"]).unwrap();\n        // Full SHA is 40 hex characters\n        assert_eq!(hash.len(), 40);\n        assert!(hash.chars().all(|c| c.is_ascii_hexdigit()));\n    }\n\n    // -----------------------------------------------------------------------\n    // head_timestamp\n    // -----------------------------------------------------------------------\n\n    #[test]\n    fn test_head_timestamp() {\n        let dir = init_temp_repo();\n        let ts_str = git_output_in(dir.path(), &[\"show\", \"-s\", \"--format=%ct\", \"HEAD\"]).unwrap();\n        let ts: i64 = ts_str.parse().unwrap();\n        // Should be a reasonable Unix timestamp (after 2020)\n        assert!(ts > 1_577_836_800);\n    }\n\n    // -----------------------------------------------------------------------\n    // note_exists + add_note\n    // -----------------------------------------------------------------------\n\n    #[test]\n    fn test_note_exists_false_then_true_after_add() {\n        let dir = init_temp_repo();\n        let path = dir.path();\n        let hash = run_git(path, &[\"rev-parse\", \"HEAD\"]);\n\n        // No note yet\n        let status = Command::new(\"git\")\n            .args([\"-C\", path.to_str().unwrap()])\n            .args([\"notes\", \"--ref\", NOTES_REF, \"show\", &hash])\n            .stdout(std::process::Stdio::null())\n            .stderr(std::process::Stdio::null())\n            .status()\n            .unwrap();\n        assert!(!status.success());\n\n        // Add a note\n        run_git(\n            path,\n            &[\n                \"notes\",\n                \"--ref\",\n                NOTES_REF,\n                \"add\",\n                \"-m\",\n                \"test note content\",\n                &hash,\n            ],\n        );\n\n        // Now note exists\n        let status = Command::new(\"git\")\n            .args([\"-C\", path.to_str().unwrap()])\n            .args([\"notes\", \"--ref\", NOTES_REF, \"show\", &hash])\n            .stdout(std::process::Stdio::null())\n            .stderr(std::process::Stdio::null())\n            .status()\n            .unwrap();\n        assert!(status.success());\n\n        // Verify content\n        let note_content =\n            git_output_in(path, &[\"notes\", \"--ref\", NOTES_REF, \"show\", &hash]).unwrap();\n        assert_eq!(note_content, \"test note content\");\n    }\n\n    // -----------------------------------------------------------------------\n    // has_upstream\n    // -----------------------------------------------------------------------\n\n    #[test]\n    fn test_has_upstream_false_when_no_remote() {\n        let dir = init_temp_repo();\n        let remotes = git_output_in(dir.path(), &[\"remote\"]).unwrap();\n        assert!(remotes.is_empty());\n    }\n\n    #[test]\n    fn test_has_upstream_true_when_remote_added() {\n        let dir = init_temp_repo();\n        let path = dir.path();\n        run_git(\n            path,\n            &[\n                \"remote\",\n                \"add\",\n                \"origin\",\n                \"https://github.com/test-org/test-repo.git\",\n            ],\n        );\n        let remotes = git_output_in(path, &[\"remote\"]).unwrap();\n        assert!(!remotes.is_empty());\n    }\n\n    // -----------------------------------------------------------------------\n    // remote_org (via parse_org_from_url — pure function)\n    // -----------------------------------------------------------------------\n\n    #[test]\n    fn test_parse_org_from_ssh_url() {\n        let org = parse_org_from_url(\"git@github.com:my-org/my-repo.git\");\n        assert_eq!(org, Some(\"my-org\".to_string()));\n    }\n\n    #[test]\n    fn test_parse_org_from_https_url() {\n        let org = parse_org_from_url(\"https://github.com/other-org/some-repo.git\");\n        assert_eq!(org, Some(\"other-org\".to_string()));\n    }\n\n    #[test]\n    fn test_parse_org_from_http_url() {\n        let org = parse_org_from_url(\"http://github.com/http-org/repo.git\");\n        assert_eq!(org, Some(\"http-org\".to_string()));\n    }\n\n    #[test]\n    fn test_parse_org_from_unknown_url() {\n        let org = parse_org_from_url(\"svn://example.com/repo\");\n        assert_eq!(org, None);\n    }\n\n    #[test]\n    fn test_parse_org_empty_url() {\n        let org = parse_org_from_url(\"\");\n        assert_eq!(org, None);\n    }\n\n    // -----------------------------------------------------------------------\n    // parse_org_from_url (integration test with temp repo)\n    // -----------------------------------------------------------------------\n\n    #[test]\n    fn test_parse_org_from_url_integration() {\n        let dir = init_temp_repo();\n        let path = dir.path();\n        run_git(\n            path,\n            &[\n                \"remote\",\n                \"add\",\n                \"origin\",\n                \"git@github.com:acme-corp/widgets.git\",\n            ],\n        );\n        let url = git_output_in(path, &[\"remote\", \"get-url\", \"origin\"]).unwrap();\n        let org = parse_org_from_url(&url);\n        assert_eq!(org, Some(\"acme-corp\".to_string()));\n    }\n\n    // -----------------------------------------------------------------------\n    // config_get + config_set\n    // -----------------------------------------------------------------------\n\n    #[test]\n    fn test_config_get_missing_key() {\n        let dir = init_temp_repo();\n        let path = dir.path();\n        let output = Command::new(\"git\")\n            .args([\"-C\", path.to_str().unwrap()])\n            .args([\"config\", \"--get\", \"ai.barometer.nonexistent\"])\n            .output()\n            .unwrap();\n        // Should exit non-zero (key not set)\n        assert!(!output.status.success());\n    }\n\n    #[test]\n    fn test_config_set_then_get() {\n        let dir = init_temp_repo();\n        let path = dir.path();\n\n        // Set a config value\n        run_git(path, &[\"config\", \"ai.barometer.autopush\", \"true\"]);\n\n        // Read it back\n        let value = git_output_in(path, &[\"config\", \"--get\", \"ai.barometer.autopush\"]).unwrap();\n        assert_eq!(value, \"true\");\n    }\n\n    #[test]\n    fn test_config_overwrite() {\n        let dir = init_temp_repo();\n        let path = dir.path();\n\n        run_git(path, &[\"config\", \"ai.barometer.org\", \"first-org\"]);\n        run_git(path, &[\"config\", \"ai.barometer.org\", \"second-org\"]);\n\n        let value = git_output_in(path, &[\"config\", \"--get\", \"ai.barometer.org\"]).unwrap();\n        assert_eq!(value, \"second-org\");\n    }\n\n    // -----------------------------------------------------------------------\n    // Multiple commits — verify head_hash changes\n    // -----------------------------------------------------------------------\n\n    #[test]\n    fn test_head_hash_changes_after_new_commit() {\n        let dir = init_temp_repo();\n        let path = dir.path();\n\n        let hash1 = run_git(path, &[\"rev-parse\", \"HEAD\"]);\n\n        // Make another commit\n        std::fs::write(path.join(\"file2.txt\"), \"content\").unwrap();\n        run_git(path, &[\"add\", \"file2.txt\"]);\n        run_git(path, &[\"commit\", \"-m\", \"second commit\"]);\n\n        let hash2 = run_git(path, &[\"rev-parse\", \"HEAD\"]);\n\n        assert_ne!(hash1, hash2);\n        assert_eq!(hash2.len(), 40);\n    }\n\n    // -----------------------------------------------------------------------\n    // validate_commit_hash\n    // -----------------------------------------------------------------------\n\n    #[test]\n    fn test_validate_commit_hash_valid_short() {\n        assert!(validate_commit_hash(\"abcdef0\").is_ok());\n    }\n\n    #[test]\n    fn test_validate_commit_hash_valid_full() {\n        assert!(validate_commit_hash(\"abcdef0123456789abcdef0123456789abcdef01\").is_ok());\n    }\n\n    #[test]\n    fn test_validate_commit_hash_rejects_flag_injection() {\n        assert!(validate_commit_hash(\"--help\").is_err());\n    }\n\n    #[test]\n    fn test_validate_commit_hash_rejects_too_short() {\n        assert!(validate_commit_hash(\"abc\").is_err());\n    }\n\n    #[test]\n    fn test_validate_commit_hash_rejects_non_hex() {\n        assert!(validate_commit_hash(\"ghijklm\").is_err());\n    }\n\n    #[test]\n    fn test_validate_commit_hash_rejects_empty() {\n        assert!(validate_commit_hash(\"\").is_err());\n    }\n\n    #[test]\n    fn test_validate_commit_hash_rejects_too_long() {\n        assert!(validate_commit_hash(\"a\".repeat(41).as_str()).is_err());\n    }\n\n    // -----------------------------------------------------------------------\n    // parse_org_from_url — edge cases\n    // -----------------------------------------------------------------------\n\n    #[test]\n    fn test_parse_org_from_url_https_with_trailing_slash() {\n        // Trailing slash after org — org segment should still parse\n        let org = parse_org_from_url(\"https://github.com/org/\");\n        assert_eq!(org, Some(\"org\".to_string()));\n    }\n\n    #[test]\n    fn test_parse_org_from_url_https_host_only() {\n        // No org segment after host\n        let org = parse_org_from_url(\"https://github.com/\");\n        assert_eq!(org, None);\n    }\n\n    #[test]\n    fn test_parse_org_from_url_https_host_no_trailing_slash() {\n        let org = parse_org_from_url(\"https://github.com\");\n        assert_eq!(org, None);\n    }\n\n    #[test]\n    fn test_parse_org_from_url_ssh_nested_path() {\n        // SSH with nested paths — org is the first segment after the colon\n        let org = parse_org_from_url(\"git@github.com:org/sub/repo.git\");\n        assert_eq!(org, Some(\"org\".to_string()));\n    }\n\n    #[test]\n    fn test_parse_org_from_url_https_with_port() {\n        let org = parse_org_from_url(\"https://github.com:443/org/repo.git\");\n        // The host segment is \"github.com:443\", org is next path segment\n        assert_eq!(org, Some(\"org\".to_string()));\n    }\n\n    #[test]\n    fn test_parse_org_from_url_https_with_auth() {\n        // URL with authentication credentials embedded\n        let org = parse_org_from_url(\"https://user:pass@github.com/org/repo.git\");\n        // \"user:pass@github.com\" is treated as host, \"org\" is the org\n        assert_eq!(org, Some(\"org\".to_string()));\n    }\n\n    // -----------------------------------------------------------------------\n    // Public API tests — use set_current_dir, must run serially\n    //\n    // These tests exercise the actual Rust wrapper functions against temp\n    // repos to ensure the wrappers (argument order, trim, error mapping)\n    // work correctly, not just the underlying git commands.\n    // -----------------------------------------------------------------------\n\n    /// Helper: create a temp repo and chdir into it. Returns the TempDir\n    /// (must be kept alive to prevent cleanup) and the original cwd for\n    /// restoration.\n    fn enter_temp_repo() -> (TempDir, PathBuf) {\n        let original_cwd = std::env::current_dir().expect(\"failed to get cwd\");\n        let dir = init_temp_repo();\n        std::env::set_current_dir(dir.path()).expect(\"failed to chdir into temp repo\");\n        (dir, original_cwd)\n    }\n\n    #[test]\n    #[serial]\n    fn test_api_repo_root() {\n        let (_dir, original_cwd) = enter_temp_repo();\n        let root = repo_root().expect(\"repo_root failed\");\n        assert!(root.join(\"README.md\").exists());\n        std::env::set_current_dir(original_cwd).unwrap();\n    }\n\n    #[test]\n    #[serial]\n    fn test_api_head_hash() {\n        let (_dir, original_cwd) = enter_temp_repo();\n        let hash = head_hash().expect(\"head_hash failed\");\n        assert_eq!(hash.len(), 40);\n        assert!(hash.chars().all(|c| c.is_ascii_hexdigit()));\n        std::env::set_current_dir(original_cwd).unwrap();\n    }\n\n    #[test]\n    #[serial]\n    fn test_api_head_timestamp() {\n        let (_dir, original_cwd) = enter_temp_repo();\n        let ts = head_timestamp().expect(\"head_timestamp failed\");\n        assert!(ts > 1_577_836_800); // After 2020\n        std::env::set_current_dir(original_cwd).unwrap();\n    }\n\n    #[test]\n    #[serial]\n    fn test_api_note_exists_and_add_note() {\n        let (_dir, original_cwd) = enter_temp_repo();\n        let hash = head_hash().expect(\"head_hash failed\");\n\n        // No note yet\n        assert!(!note_exists(&hash).expect(\"note_exists failed\"));\n\n        // Add a note via the public API\n        add_note(&hash, \"test session data\").expect(\"add_note failed\");\n\n        // Now it should exist\n        assert!(note_exists(&hash).expect(\"note_exists failed after add\"));\n\n        std::env::set_current_dir(original_cwd).unwrap();\n    }\n\n    #[test]\n    #[serial]\n    fn test_api_has_upstream_no_remote() {\n        let (_dir, original_cwd) = enter_temp_repo();\n        assert!(!has_upstream().expect(\"has_upstream failed\"));\n        std::env::set_current_dir(original_cwd).unwrap();\n    }\n\n    #[test]\n    #[serial]\n    fn test_api_has_upstream_with_remote() {\n        let (dir, original_cwd) = enter_temp_repo();\n        run_git(\n            dir.path(),\n            &[\n                \"remote\",\n                \"add\",\n                \"origin\",\n                \"https://github.com/test-org/test-repo.git\",\n            ],\n        );\n        assert!(has_upstream().expect(\"has_upstream failed\"));\n        std::env::set_current_dir(original_cwd).unwrap();\n    }\n\n    #[test]\n    #[serial]\n    fn test_api_config_get_missing() {\n        let (_dir, original_cwd) = enter_temp_repo();\n        let val = config_get(\"ai.barometer.nonexistent\").expect(\"config_get failed\");\n        assert_eq!(val, None);\n        std::env::set_current_dir(original_cwd).unwrap();\n    }\n\n    #[test]\n    #[serial]\n    fn test_api_config_set_then_get() {\n        let (_dir, original_cwd) = enter_temp_repo();\n        config_set(\"ai.barometer.autopush\", \"true\").expect(\"config_set failed\");\n        let val = config_get(\"ai.barometer.autopush\").expect(\"config_get failed