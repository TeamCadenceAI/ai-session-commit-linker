result = push_notes();\n        assert!(result.is_err());\n\n        std::env::set_current_dir(original_cwd).unwrap();\n    }\n\n    #[test]\n    #[serial]\n    fn test_remote_orgs_empty_when_no_remotes() {\n        let (_dir, original_cwd) = enter_temp_repo();\n\n        let orgs = remote_orgs().expect(\"remote_orgs failed\");\n        assert!(orgs.is_empty());\n\n        std::env::set_current_dir(original_cwd).unwrap();\n    }\n}\n","structuredPatch":[{"oldStart":460,"oldLines":6,"newStart":460,"newLines":8,"lines":["         // Set required user config for commits","         run_git(path, &[\"config\", \"user.email\", \"test@test.com\"]);","         run_git(path, &[\"config\", \"user.name\", \"Test User\"]);","+        // Disable ai-barometer so the global post-commit hook doesn't fire","+        run_git(path, &[\"config\", \"ai.barometer.enabled\", \"false\"]);","         // Create an initial commit","         std::fs::write(path.join(\"README.md\"), \"hello\").unwrap();","         run_git(path, &[\"add\", \"README.md\"]);"]}],"userModified":false,"replaceAll":false},"sourceToolAssistantUUID":"6e1b50cb-8140-4007-8d73-3994585bb36f"}
