hes(\"My-Org\", &orgs));\n   523→        assert!(org_matches(\"MY-ORG\", &orgs));\n   524→    }\n   525→\n   526→    #[test]\n   527→    fn test_org_matches_reverse_case() {\n   528→        // Configured is lowercase, remote is mixed case\n   529→        let orgs = vec![\"My-Org\".to_string()];\n   530→        assert!(org_matches(\"my-org\", &orgs));\n   531→    }\n   532→\n   533→    #[test]\n   534→    fn test_org_matches_no_match() {\n   535→        let orgs = vec![\"other-org\".to_string()];\n   536→        assert!(!org_matches(\"my-org\", &orgs));\n   537→    }\n   538→\n   539→    #[test]\n   540→    fn test_org_matches_empty_remotes() {\n   541→        let orgs: Vec<String> = vec![];\n   542→        assert!(!org_matches(\"my-org\", &orgs));\n   543→    }\n   544→\n   545→    #[test]\n   546→    fn test_org_matches_multiple_remotes_one_matches() {\n   547→        let orgs = vec![\"unrelated\".to_string(), \"my-org\".to_string()];\n   548→        assert!(org_matches(\"my-org\", &orgs));\n   549→    }\n   550→\n   551→    #[test]\n   552→    fn test_org_matches_multiple_remotes_none_match() {\n   553→        let orgs = vec![\"org-a\".to_string(), \"org-b\".to_string()];\n   554→        assert!(!org_matches(\"my-org\", &orgs));\n   555→    }\n   556→\n   557→    // -----------------------------------------------------------------------\n   558→    // should_push with org filter\n   559→    // -----------------------------------------------------------------------\n   560→\n   561→    #[test]\n   562→    #[serial]\n   563→    fn test_should_push_org_filter_denies_returns_false() {\n   564→        let dir = init_temp_repo();\n   565→        let original_cwd = safe_cwd();\n   566→        std::env::set_current_dir(dir.path()).expect(\"failed to chdir\");\n   567→\n   568→        // Add a remote with org \"actual-org\"\n   569→        run_git(\n   570→            dir.path(),\n   571→            &[\n   572→                \"remote\",\n   573→                \"add\",\n   574→                \"origin\",\n   575→                \"git@github.com:actual-org/repo.git\",\n   576→            ],\n   577→        );\n   578→\n   579→        // Pre-set consent so we isolate the org filter behavior\n   580→        run_git(dir.path(), &[\"config\", \"ai.barometer.autopush\", \"true\"]);\n   581→\n   582→        // Create a temp global config file with a different org filter\n   583→        let global_config = dir.path().join(\"fake-global-gitconfig\");\n   584→        std::fs::write(\n   585→            &global_config,\n   586→            \"[ai \\\"barometer\\\"]\\n    org = required-org\\n\",\n   587→        )\n   588→        .unwrap();\n   589→\n   590→        // Point GIT_CONFIG_GLOBAL to our fake global config\n   591→        let original_global = std::env::var(\"GIT_CONFIG_GLOBAL\").ok();\n   592→        unsafe {\n   593→            std::env::set_var(\"GIT_CONFIG_GLOBAL\", &global_config);\n   594→        }\n   595→\n   596→        // should_push should return false because \"actual-org\" != \"required-org\"\n   597→        assert!(!should_push());\n   598→\n   599→        // Restore GIT_CONFIG_GLOBAL\n   600→        unsafe {\n   601→            match original_global {\n   602→                Some(g) => std::env::set_var(\"GIT_CONFIG_GLOBAL\", g),\n   603→                None => std::env::remove_var(\"GIT_CONFIG_GLOBAL\"),\n   604→            }\n   605→        }\n   606→        std::env::set_current_dir(original_cwd).unwrap();\n   607→    }\n   608→\n   609→    #[test]\n   610→    #[serial]\n   611→    fn test_should_push_org_filter_allows_matching_org() {\n   612→        let dir = init_temp_repo();\n   613→        let original_cwd = safe_cwd();\n   614→        std::env::set_current_dir(dir.path()).expect(\"failed to chdir\");\n   615→\n   616→        // Add a remote with org \"my-org\"\n   617→        run_git(\n   618→            dir.path(),\n   619→            &[\"remote\", \"add\", \"origin\", \"git@github.com:my-org/repo.git\"],\n   6