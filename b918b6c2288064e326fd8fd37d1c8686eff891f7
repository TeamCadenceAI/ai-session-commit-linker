ccepts a home path, allowing\n    37→/// tests to use a temp directory instead of the real `$HOME`.\n    38→fn pending_dir_in(home: &Path) -> anyhow::Result<PathBuf> {\n    39→    let dir = home.join(\".ai-barometer\").join(\"pending\");\n    40→    if !dir.exists() {\n    41→        std::fs::create_dir_all(&dir)?;\n    42→    }\n    43→    Ok(dir)\n    44→}\n    45→\n    46→// ---------------------------------------------------------------------------\n    47→// Public API\n    48→// ---------------------------------------------------------------------------\n    49→\n    50→/// Return the pending directory: `~/.ai-barometer/pending/`.\n    51→///\n    52→/// Creates the directory (and parents) if it does not exist.\n    53→pub fn pending_dir() -> anyhow::Result<PathBuf> {\n    54→    let home = crate::agents::home_dir()\n    55→        .ok_or_else(|| anyhow::anyhow!(\"cannot determine home directory\"))?;\n    56→    pending_dir_in(&home)\n    57→}\n    58→\n    59→/// Write a pending record for a commit that could not be resolved.\n    60→///\n    61→/// Creates `<commit-hash>.json` in the pending directory. The write is\n    62→/// atomic: data is written to a temporary file (`<commit-hash>.json.tmp`)\n    63→/// first, then renamed into place. This prevents concurrent commits from\n    64→/// reading a half-written file.\n    65→pub fn write_pending(commit: &str, repo: &str, commit_time: i64) -> anyhow::Result<()> {\n    66→    let dir = pending_dir()?;\n    67→    write_pending_in(&dir, commit, repo, commit_time)\n    68→}\n    69→\n    70→/// Internal implementation of `write_pending` that accepts the pending\n    71→/// directory, for testability.\n    72→fn write_pending_in(dir: &Path, commit: &str, repo: &str, commit_time: i64) -> anyhow::Result<()> {\n    73→    let now = current_unix_timestamp();\n    74→\n    75→    let record = PendingRecord {\n    76→        commit: commit.to_string(),\n    77→        repo: repo.to_string(),\n    78→        commit_time,\n    79→        attempts: 1,\n    80→        last_attempt: now,\n    81→    };\n    82→\n    83→    let json = serde_json::to_string_pretty(&record)?;\n    84→    let final_path = dir.join(format!(\"{}.json\", commit));\n    85→    let tmp_path = dir.join(format!(\"{}.json.tmp\", commit));\n    86→\n    87→    // Atomic write: write to temp file, then rename\n    88→    std::fs::write(&tmp_path, &json)?;\n    89→    std::fs::rename(&tmp_path, &final_path)?;\n    90→\n    91→    Ok(())\n    92→}\n    93→\n    94→/// List all pending records for a given repository.\n    95→///\n    96→/// Reads all `.json` files in the pending directory, deserializes them\n    97→/// as `PendingRecord`, and filters by repo path. Files that cannot be\n    98→/// read or parsed are silently skipped. Orphaned `.json.tmp` files\n    99→/// (left behind by crashed writes) are cleaned up automatically.\n   100→///\n   101→/// The `repo` parameter must be a canonical absolute path as returned by\n   102→/// `git rev-parse --show-toplevel`. Filtering uses exact string equality,\n   103→/// so paths with trailing slashes, symlinks, or other non-canonical\n   104→/// representations will not match records written with the canonical form.\n   105→pub fn list_for_repo(repo: &str) -> anyhow::Result<Vec<PendingRecord>> {\n   106→    let dir = match pending_dir() {\n   107→        Ok(d) => d,\n   108→        Err(_) => return Ok(Vec::new()),\n   109→    };\n   110→\n   111→    list_for_repo_in(&dir, repo)\n   112→}\n   113→\n   114→/// Internal implementation of `list_for_repo` that accepts the pending\n   115→/// directory, for testability.\n   116→fn list_for_repo_in(dir: &Path, repo: &str) -> anyhow::Result<Vec<PendingRecord>> {\n   117→    if !dir.exists() {\n   118→        return Ok(Vec::new());\n   119→    }\n   120→\n   121→    let mut records = Vec::new();\n   122→    let entries = match std::fs::read_dir(dir) {\n   123→        Ok(e) => e,\n   124→        Err(_) => return Ok(Vec::new()),\n   125→    };\n   126→\n   127→    for entry in entries {\n   128→        let entry = match entry {\n   129→            Ok(e) => e,\n   130→            Err(_) => continue,\n   131→        };\n   132→\n   133→        let path = entry.path();\n   134→        if path.extension().and_then(|e| e.to_str()) != Some(\"json\") {\n   135→            // Clean up orphaned .json.tmp files left behind by crashed writes.\n   136→            if path\n   137→                .file_name()\n   138→                .and_then(|n| n.to_str())\n   139→                .is_some_and(|n| n.ends_with(\".json.tmp\"))\n   140→            {\n   141→                let _ = std::fs::remove_file(&path);\n   142→            }\n   143→            continue;\n   144→        }\n   145→\n   146→        let content = match std::fs::read_to_string(&path) {\n   147→            Ok(c) => c,\n   148→            Err(_) => continue,\n   149→        };\n   150→\n   151→        let record: PendingRecord = match serde_json::from_str(&content) {\n   152→            Ok(r) => r,\n   153→            Err(_) => continue,\n   154→        };\n   155→\n   156→        if record.repo != repo {\n   157→            continue;\n   158→        }\n   159→\n   160→        records.push(record);\n   161→    }\n   162→\n   163→    Ok(records)\n   164→}\n   165→\n   166→/// Increment the attempt counter on a pending record and rewrite it.\n   167→///\n   168→/// Bumps `attempts` by 1, updates `last_attempt` to the current time,\n   169→/// and atomically rewrites the file.\n   170→pub fn increment(record: &mut PendingRecord) -> anyhow::Result<()> {\n   171→    let dir = pending_dir()?;\n   172→    increment_in(&dir, record)\n   173→}\n   174→\n   175→/// Internal implementation of `increment` that accepts the pending\n   176→/// directory, for testability.\n   177→fn increment_in(dir: &Path, record: &mut PendingRecord) -> anyhow::Result<()> {\n   178→    record.attempts += 1;\n   179→    record.last_attempt = current_unix_timestamp();\n   