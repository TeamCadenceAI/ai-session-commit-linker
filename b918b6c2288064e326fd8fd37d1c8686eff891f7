{"parentUuid":"aede0d23-a621-4556-a8bc-b3be19befdf2","isSidechain":false,"userType":"external","cwd":"/Users/daveslutzkin/dev/ai-barometer","sessionId":"0eae50f1-5fc6-498a-8228-14a4199c9db2","version":"2.1.37","gitBranch":"main","slug":"concurrent-stargazing-gadget","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AKpqBNoAWhmAnUATQ2i4PB","type":"tool_result","content":"     1→//! Push decision logic for AI session notes.\n     2→//!\n     3→//! Orchestrates the decision of whether to push notes to the remote after\n     4→//! attaching them locally. The decision depends on several factors:\n     5→//!\n     6→//! 1. **Has upstream**: repo must have at least one configured remote.\n     7→//! 2. **Org filter**: if `git config --global ai.barometer.org` is set,\n     8→//!    at least one remote must belong to that org. Otherwise, notes are\n     9→//!    attached locally only (no push).\n    10→//! 3. **Autopush consent**: `git config ai.barometer.autopush` -- on first\n    11→//!    push for a repo, print a warning and record consent. After that,\n    12→//!    push silently.\n    13→//!\n    14→//! Note: The per-repo enabled check (`git config ai.barometer.enabled`) is\n    15→//! handled by [`git::check_enabled()`] in the git module, since it gates\n    16→//! ALL processing (not just push).\n    17→//!\n    18→//! Push failures are always non-fatal: logged to stderr, never block the\n    19→//! commit, never retry automatically in the hook.\n    20→\n    21→use crate::git;\n    22→\n    23→// ---------------------------------------------------------------------------\n    24→// Public API\n    25→// ---------------------------------------------------------------------------\n    26→\n    27→/// Determine whether notes should be pushed for this repository.\n    28→///\n    29→/// Orchestrates all checks: enabled (already checked by caller), has upstream,\n    30→/// org filter, and autopush consent.\n    31→///\n    32→/// Returns `true` if all conditions are met and notes should be pushed.\n    33→/// Returns `false` if any condition prevents pushing.\n    34→pub fn should_push() -> bool {\n    35→    // Check 1: Does the repo have a remote?\n    36→    match git::has_upstream() {\n    37→        Ok(true) => {}\n    38→        _ => return false,\n    39→    }\n    40→\n    41→    // Check 2: Org filter\n    42→    if !check_org_filter() {\n    43→        return false;\n    44→    }\n    45→\n    46→    // Check 3: Autopush consent\n    47→    if !check_or_request_consent() {\n    48→        return false;\n    49→    }\n    50→\n    51→    true\n    52→}\n    53→\n    54→/// Attempt to push notes to the remote. Handles failure gracefully.\n    55→///\n    56→/// On success: silent (no output).\n    57→/// On failure: logs a warning to stderr. Never blocks, never retries.\n    58→pub fn attempt_push() {\n    59→    if let Err(e) = git::push_notes() {\n    60→        eprintln!(\"[ai-barometer] warning: failed to push notes: {}\", e);\n    61→    }\n    62→}\n    63→\n    64→/// Check the org filter: if a global org is configured, verify that at least\n    65→/// one remote belongs to that org.\n    66→///\n    67→/// Reads `git config --global ai.barometer.org`. If not set, the filter\n    68→/// passes (no org restriction). If set, extracts orgs from ALL remotes\n    69→/// and checks for a match via [`org_matches`].\n    70→///\n    71→/// Returns `true` if push is allowed (no filter, or filter matches).\n    72→/// Returns `false` if the org filter is set and no remote matches.\n    73→pub fn check_org_filter() -> bool {\n    74→    let configured_org = match git::config_get_global(\"ai.barometer.org\") {\n    75→        Ok(Some(org)) => org,\n    76→        // No org filter configured: allow push\n    77→        _ => return true,\n    78→    };\n    79→\n    80→    // Get orgs from ALL remotes\n    81→    let remote_orgs = match git::remote_orgs() {\n    82→        Ok(orgs) => orgs,\n    83→        // If we can't read remotes, don't push\n    84→        Err(_) => return false,\n    85→    };\n    86→\n    87→    org_matches(&configured_org, &remote_orgs)\n    88→}\n    89→\n    90→/// Pure-logic helper: check whether any of the `remote_orgs` matches the\n    91→/// `configured_org` using case-insensitive comparison.\n    92→///\n    93→/// This is extracted from [`check_org_filter`] for testability — the\n    94→/// orchestration function reads from global git config which is hard to\n    95→/// isolate in tests, but this pure function can be tested directly.\n    96→pub fn org_matches(configured_org: &str, remote_orgs: &[String]) -> bool {\n    97→    remote_orgs\n    98→        .iter()\n    99→        .any(|org| org.eq_ignore_ascii_case(configured_org))\n   100→}\n   101→\n   102→/// Check autopush consent. On first push for a repo, print a warning to\n   103→/// stderr and record consent by setting `git config ai.barometer.autopush true`.\n   104→///\n   105→/// Returns `true` if consent is granted (either already recorded or just granted).\n   106→/// Returns `false` if consent cannot be recorded (config write failure).\n   107→pub fn check_or_request_consent() -> bool {\n   108→    match git::config_get(\"ai.barometer.autopush\") {\n   109→        Ok(Some(val)) if val == \"true\" => {\n   110→            // Consent already recorded, push silently\n   111→            return true;\n   112→        }\n   113→        Ok(Some(val)) if val == \"false\" => {\n   114→            // Explicitly opted out of push\n   115→            return false;\n   116→        }\n   117→        _ => {\n   118→            // Not set or error reading: this is the first push for this repo.\n   119→            // Print a consent warning and record it.\n   120→        }\n   121→    }\n   122→\n   123→    // First push for this repo: print informational warning\n   124→    eprintln!(\n   125→        \"[ai-barometer] This is the first time AI Barometer will push notes for this repository.\"\n   126→    );\n   127→    eprintln!(\"[ai-barometer] AI session notes will be pushed to the remote via:\");\n   128→    eprintln!(\"[ai-barometer]   git push origin refs/notes/ai-sessions\");\n   129→    eprintln!(\"[ai-barometer] To disable, run: git config ai.barometer.autopush false\");\n   130→\n   131→    // Record consent\n   132→    if let Err(e) = git::config_set(\"ai.barometer.autopush\", \"true\") {\n   133→        eprintln!(\n   134→            \"[ai-barometer] warning: failed to record autopush consent: {}\",\n   135→            e\n   136→        );\n   137→        // Still allow this push attempt even if we couldn't save the config\n   138→        return true;\n   139→    }\n   140→\n   141→    true\n   142→}\n   143→\n   144→// ---------------------------------------------------------------------------\n   145→// Tests\n   146→// ---------------------------------------------------------------------------\n   147→\n   148→#[cfg(test)]\n   149→mod tests {\n   150→    use super::*;\n   151→    use serial_test::serial;\n   152→    use std::path::{Path, PathBuf};\n   153→    use std::process::Command;\n   154→    use tempfile::TempDir;\n   155→\n   156→    /// Helper: create a temporary git repo with one commit.\n   157→    fn init_temp_repo() -> TempDir {\n   158→        let dir = TempDir::new().expect(\"failed to create temp dir\");\n   159→        let path = dir.path();\n   160→\n   161→        run_git(path, &[\"init\"]);\n   162→        run_git(path, &[\"config\", \"user.email\", \"test@test.com\"]);\n   163→        run_git(path, &[\"config\", \"user.name\", \"Test User\"]);\n   164→        std::fs::write(path.join(\"README.md\"), \"hello\").unwrap();\n   165→        run_git(path, &[\"add\", \"README.md\"]);\n   166→        run_git(path, &[\"commit\", \"-m\", \"initial commit\"]);\n   167→\n   168→        dir\n   169→    }\n   170→\n   171→    /// Run a git command inside the given directory, panicking on failure.\n   172→    fn run_git(dir: &Path, args: &[&str]) -> String {\n   173→        let output = Command::new(\"git\")\n   174→            .args([\"-C\", dir.to_str().unwrap()])\n   175→            .args(args)\n   176→            .output()\n   177→            .expect(\"failed to run git\");\n   178→        if !output.status.success() {\n   179→            let stderr = String::from_utf8_lossy(&output.stderr);\n   180→            panic!(\"git {:?} failed: {}\", args, stderr);\n   181→        }\n   182→        String::from_utf8(output.stdout).unwrap().trim().to_string()\n   183→    }\n   184→\n   185→    /// Helper: get a stable directory to use as a fallback CWD.\n   186→    fn safe_cwd() -> PathBuf {\n   187→        match std::env::current_dir() {\n   188→            Ok(cwd) if cwd.exists() => cwd,\n   189→            _ => {\n   190→                let fallback = std::env::temp_dir();\n   191→                std::env::set_current_dir(&fallback).ok();\n   192→                fallback\n   193→            }\n   194→        }\n   195→    }\n   196→\n   197→    // -----------------------------------------------------------------------\n   198→    // check_or_request_consent\n   199→    // -----------------------------------------------------------------------\n   200→\n   201→    #[test]\n   202→    #[serial]\n   203→    fn test_consent_first_time_grants_and_records() {\n   204→        let dir = init_temp_repo();\n   205→        let original_cwd = safe_cwd();\n   206→        std::env::set_current_dir(dir.path()).expect(\"failed to chdir\");\n   207→\n   208→        // No autopush config set -- first time\n   209→        assert!(check_or_request_consent());\n   210→\n   211→        // Should now have autopush=true recorded\n   212→        let val = run_git(dir.path(), &[\"config\", \"--get\", \"ai.barometer.autopush\"]);\n   213→        assert_eq!(val, \"true\");\n   214→\n   215→        std::env::set_current_dir(original_cwd).unwrap();\n   216→    }\n   217→\n   218→    #[test]\n   219→    #[serial]\n   220→    fn test_consent_already_true() {\n   221→        let dir = init_temp_repo();\n   222→        let original_cwd = safe_cwd();\n   223→        std::env::set_current_dir(dir.path()).expect(\"failed to chdir\");\n   224→\n   225→        run_git(dir.path(), &[\"config\", \"ai.barometer.autopush\", \"true\"]);\n   226→        assert!(check_or_request_consent());\n   227→\n   228→        std::env::set_current_dir(original_cwd).unwrap();\n   229→    }\n   230→\n   231→    #[test]\n   232→    #[serial]\n   233→    fn test_consent_explicitly_false_denies() {\n   234→        let dir = init_temp_repo();\n   235→        let original_cwd = safe_cwd();\n   236→        std::env::set_current_dir(dir.path()).expect(\"failed to chdir\");\n   237→\n   238→        run_git(dir.path(), &[\"config\", \"ai.barometer.autopush\", \"false\"]);\n   239→        assert!(!check_or_request_consent());\n   240→\n   241→        std::env::set_current_dir(original_cwd).unwrap();\n   242→    }\n   243→\n   244→    #[test]\n   245→    #[serial]\n   246→    fn test_consent_second_call_is_silent() {\n   247→        let dir = init_temp_repo();\n   248→        let original_cwd = safe_cwd();\n   249→        std::env::set_current_dir(dir.path()).expect(\"failed to chdir\");\n   250→\n   251→        // First call: grants consent and records it\n   252→        assert!(check_or_request_consent());\n   253→        // Second call: should still return true (already recorded)\n   254→        assert!(check_or_request_consent());\n   255→\n   256→        std::env::set_current_dir(original_cwd).unwrap();\n   257→    }\n   258→\n   259→    // -----------------------------------------------------------------------\n   260→    // check_org_filter\n   261→    // -----------------------------------------------------------------------\n   262→\n   263→    #[test]\n   264→    #[serial]\n   265→    fn test_org_filter_no_config_allows_push() {\n   266→        let dir = init_temp_repo();\n   267→        let original_cwd = safe_cwd();\n   268→        std::env::set_current_dir(dir.path()).expect(\"failed to chdir\");\n   269→\n   270→        // Use an empty global config so we don't depend on the developer's\n   271→        // real global git config (which might have ai.barometer.org set).\n   272→        let global_config = dir.path().join(\"fake-global-gitconfig\");\n   273→        std::fs::write(&global_config, \"\").unwrap();\n   274→\n   275→        let original_global = std::env::var(\"GIT_CONFIG_GLOBAL\").ok();\n   276→        unsafe {\n   277→            std::env::set_var(\"GIT_CONFIG_GLOBAL\", &global_config);\n   278→        }\n   279→\n   280→        // No global org config -- filter should pass\n   281→        assert!(check_org_filter());\n   282→\n   283→        // Restore\n   284→        unsafe {\n   285→            match original_global {\n   286→                Some(g) => std::env::set_var(\"GIT_CONFIG_GLOBAL\", g),\n   287→                None => std::env::remove_var(\"GIT_CONFIG_GLOBAL\"),\n   288→            }\n   289→        }\n   290→        std::env::set_current_dir(original_cwd).unwrap();\n   291→    }\n   292→\n   293→    #[test]\n   294→    #[serial]\n   295→    fn test_org_filter_matching_org_allows_push() {\n   296→        let dir = init_temp_repo();\n   297→        let original_cwd = safe_cwd();\n   298→        std::env::set_current_dir(dir.path()).expect(\"failed to chdir\");\n   299→\n   300→        // Add a remote with a known org\n   301→        run_git(\n   302→            dir.path(),\n   303→            &[\n   304→                \"remote\",\n   305→                \"add\",\n   306→                \"origin\",\n   307→                \"git@github.com:my-org/my-repo.git\",\n   308→            ],\n   309→        );\n   310→\n   311→        // Create a global config with matching org filter\n   312→        let global_config = dir.path().join(\"fake-global-gitconfig\");\n   313→        std::fs::write(&global_config, \"[ai \\\"barometer\\\"]\\n    org = my-org\\n\").unwrap();\n   314→\n   315→        let original_global = std::env::var(\"GIT_CONFIG_GLOBAL\").ok();\n   316→        unsafe {\n   317→            std::env::set_var(\"GIT_CONFIG_GLOBAL\", &global_config);\n   318→        }\n   319→\n   320→        // check_org_filter should pass because the remote org matches\n   321→        assert!(check_org_filter());\n   322→\n   323→        // Restore\n   324→        unsafe {\n   325→            match original_global {\n   326→                Some(g) => std::env::set_var(\"GIT_CONFIG_GLOBAL\", g),\n   327→                None => std::env::remove_var(\"GIT_CONFIG_GLOBAL\"),\n   328→            }\n   329→        }\n   330→        std::env::set_current_dir(original_cwd).unwrap();\n   331→    }\n   332→\n   333→    #[test]\n   334→    #[serial]\n   335→    fn test_org_filter_no_remote_denies_push() {\n   336→        let dir = init_temp_repo();\n   337→        let original_cwd = safe_cwd();\n   338→        std::env::set_current_dir(dir.path()).expect(\"failed to chdir\");\n   339→\n   340→        // Create a global config with an org filter set\n   341→        let global_config = dir.path().join(\"fake-global-gitconfig\");\n   342→        std::fs::write(\n   343→            &global_config,\n   344→            \"[ai \\\"barometer\\\"]\\n    org = required-org\\n\",\n   345→        )\n   346→        .unwrap();\n   347→\n   348→        let original_global = std::env::var(\"GIT_CONFIG_GLOBAL\").ok();\n   349→        unsafe {\n   350→            std::env::set_var(\"GIT_CONFIG_GLOBAL\", &global_config);\n   351→        }\n   352→\n   353→        // No remotes configured -- org filter should deny (no remote matches)\n   354→        assert!(!check_org_filter());\n   355→\n   356→        // Restore\n   357→        unsafe {\n   358→            match original_global {\n   359→                Some(g) => std::env::set_var(\"GIT_CONFIG_GLOBAL\", g),\n   360→                None => std::env::remove_var(\"GIT_CONFIG_GLOBAL\"),\n   361→            }\n   362→        }\n   363→        std::env::set_current_dir(original_cwd).unwrap();\n   364→    }\n   365→\n   366→    // -----------------------------------------------------------------------\n   367→    // should_push\n   368→    // -----------------------------------------------------------------------\n   369→\n   370→    #[test]\n   371→    #[serial]\n   372→    fn test_should_push_no_remote_returns_false() {\n   373→        let dir = init_temp_repo();\n   374→        let original_cwd = safe_cwd();\n   375→        std::env::set_current_dir(dir.path()).expect(\"failed to chdir\");\n   376→\n   377→        // No remote -- should_push should return false\n   378→        assert!(!should_push());\n   379→\n   380→        std::env::set_current_dir(original_cwd).unwrap();\n   381→    }\n   382→\n   383→    #[test]\n   384→    #[serial]\n   385→    fn test_should_push_with_remote_and_consent() {\n   386→        let dir = init_temp_repo();\n   387→        let original_cwd = safe_cwd();\n   388→        std::env::set_current_dir(dir.path()).expect(\"failed to chdir\");\n   389→\n   390→        // Add a remote\n   391→        run_git(\n   392→            dir.path(),\n   393→            &[\n   394→                \"remote\",\n   395→                \"add\",\n   396→                \"origin\",\n   397→                \"git@github.com:test-org/test-repo.git\",\n   398→            ],\n   399→        );\n   400→\n   401→        // Pre-set consent so should_push doesn't need to print the warning\n   402→        run_git(dir.path(), &[\"config\", \"ai.barometer.autopush\", \"true\"]);\n   403→\n   404→        // should_push should return true (remote exists, no org filter, consent given)\n   405→        assert!(should_push());\n   406→\n   407→        std::env::set_current_dir(original_cwd).unwrap();\n   408→    }\n   409→\n   410→    #[test]\n   411→    #[serial]\n   412→    fn test_should_push_consent_denied_returns_false() {\n   413→        let dir = init_temp_repo();\n   414→