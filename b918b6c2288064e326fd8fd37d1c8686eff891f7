path(), \"session.jsonl\", content);\n   829→\n   830→        let metadata = parse_session_metadata(&file);\n   831→\n   832→        assert_eq!(metadata.session_id, Some(\"first-id\".to_string()));\n   833→    }\n   834→\n   835→    // -----------------------------------------------------------------------\n   836→    // verify_match — requires real git repos, run serially\n   837→    // -----------------------------------------------------------------------\n   838→\n   839→    /// Helper: create a temp git repo with one commit, return (TempDir, commit_hash).\n   840→    fn init_temp_repo() -> (TempDir, String) {\n   841→        let dir = TempDir::new().expect(\"failed to create temp dir\");\n   842→        let path = dir.path();\n   843→\n   844→        run_git(path, &[\"init\"]);\n   845→        run_git(path, &[\"config\", \"user.email\", \"test@test.com\"]);\n   846→        run_git(path, &[\"config\", \"user.name\", \"Test User\"]);\n   847→        fs::write(path.join(\"README.md\"), \"hello\").unwrap();\n   848→        run_git(path, &[\"add\", \"README.md\"]);\n   849→        run_git(path, &[\"commit\", \"-m\", \"initial commit\"]);\n   850→\n   851→        let hash = run_git(path, &[\"rev-parse\", \"HEAD\"]);\n   852→        (dir, hash)\n   853→    }\n   854→\n   855→    fn run_git(dir: &Path, args: &[&str]) -> String {\n   856→        let output = Command::new(\"git\")\n   857→            .args([\"-C\", dir.to_str().unwrap()])\n   858→            .args(args)\n   859→            .output()\n   860→            .expect(\"failed to run git\");\n   861→        if !output.status.success() {\n   862→            let stderr = String::from_utf8_lossy(&output.stderr);\n   863→            panic!(\"git {:?} failed: {}\", args, stderr);\n   864→        }\n   865→        String::from_utf8(output.stdout).unwrap().trim().to_string()\n   866→    }\n   867→\n   868→    #[test]\n   869→    fn test_verify_match_same_repo() {\n   870→        let (dir, commit_hash) = init_temp_repo();\n   871→        let repo_root = dir.path().to_path_buf();\n   872→\n   873→        let metadata = SessionMetadata {\n   874→            session_id: Some(\"test-session\".to_string()),\n   875→            cwd: Some(dir.path().to_string_lossy().to_string()),\n   876→            agent_type: Some(AgentType::Claude),\n   877→        };\n   878→\n   879→        assert!(verify_match(&metadata, &repo_root, &commit_hash));\n   880→    }\n   881→\n   882→    #[test]\n   883→    fn test_verify_match_missing_cwd() {\n   884→        let (dir, commit_hash) = init_temp_repo();\n   885→        let repo_root = dir.path().to_path_buf();\n   886→\n   887→        let metadata = SessionMetadata {\n   888→            session_id: Some(\"test-session\".to_string()),\n   889→            cwd: None,\n   890→            agent_type: Some(AgentType::Claude),\n   891→        };\n   892→\n   893→        assert!(!verify_match(&metadata, &repo_root, &commit_hash));\n   894→    }\n   895→\n   896→    #[test]\n   897→    fn test_verify_match_different_repo() {\n   898→        let (dir1, commit_hash) = init_temp_repo();\n   899→        let (dir2, _) = init_temp_repo();\n   900→\n   901→        let metadata = SessionMetadata {\n   902→            session_id: Some(\"test-session\".to_string()),\n   903→            // cwd points to dir2 but we're checking against dir1\n   904→            cwd: Some(dir2.path().to_string_lossy().to_string()),\n   905→            agent_type: Some(AgentType::Claude),\n   906→        };\n   907→\n   908→        assert!(!verify_match(\n   909→            &metadata,\n   910→            &dir1.path().to_path_buf(),\n   911→            &commit_hash\n   912→        ));\n   913→    }\n   914→\n   915→    #[test]\n   916→    fn test_verify_match_nonexistent_cwd() {\n   917→        let (dir, commit_hash) = init_temp_repo();\n   918→        let repo_root = dir.path().to_path_buf();\n   919→\n   920→        let metadata = SessionMetadata {\n   921→            session_id: Some(\"test-session\".to_string()),\n   922→            cwd: Some(\"/nonexistent/path/that/does/not/exist\".to_string()),\n   923→            agent_type: Some(AgentType::Claude),\n   924→        };\n   925→\n   926→        assert!(!verify_match(&metadata, &repo_root, &commit_hash));\n   927→    }\n   928→\n   929→    #[test]\n   930→    fn test_verify_match_nonexistent_commit() {\n   931→        let (dir, _) = init_temp_repo();\n   932→        let repo_root = dir.path().to_path_buf();\n   933→        let fake_commit = \"0000000000000000000000000000000000000000\";\n   934→\n   935→        let metadata = SessionMetadata {\n   936→            session_id: Some(\"test-session\".to_string()),\n   937→            cwd: Some(dir.path().to_string_lossy().to_string()),\n   938→            agent_type: Some(AgentType::Claude),\n   939→        };\n   940→\n   941→        assert!(!verify_match(&metadata, &repo_root, fake_commit));\n   942→    }\n   943→\n   944→    #[test]\n   945→    fn test_verify_match_cwd_in_subdirectory() {\n   946→        let (dir, commit_hash) = init_temp_repo();\n   947→        let repo_root = dir.path().to_path_buf();\n   948→\n   949→        // Create a subdirectory inside the repo\n   950→        let subdir = dir.path().join(\"src\");\n   951→        fs::create_dir(&subdir).unwrap();\n   952→\n   953→        let metadata = SessionMetadata {\n   954→            session_id: Some(\"test-session\".to_string()),\n   955→            // cwd is a subdirectory of the repo -- should still resolve to same repo root\n   956→            cwd: Some(subdir.to_string_lossy().to_string()),\n   957→            agent_type: Some(AgentType::Claude),\n   958→        };\n   959→\n   960→        assert!(verify_match(&metadata, &repo_root, &commit_hash));\n   961→    }\n   962→\n   963→    // -----------------------------------------------------------------------\n   964→    // extract_commit_hashes\n   965→    // -----------------------------------------------------------------------\n   966→\n   967→    #[test]\n   968→    fn test_extract_commit_hashes_finds_short_hash() {\n   969→        let dir = TempDir::new().unwrap();\n   970→        let content = r#\"{\"content\":\"[main abcdef0] fix bug\"}\"#;\n   971→        let file = write_temp_file(dir.path(), \"session.jsonl\", &content);\n   972→\n   973→        let hashes = extract_commit_hashes(&file);\n   974→        assert_eq!(hashes.len(), 1);\n   975→        assert_eq!(hashes[0], \"abcdef0\");\n   976→    }\n   977→\n   978→    #[test]\n   979→    fn test_extract_commit_hashes_finds_full_hash() {\n   980→        let dir = TempDir::new().unwrap();\n   981→        let hash = \"abcdef0123456789abcdef0123456789abcdef01\";\n   982→        let content = format!(r#\"{{\"content\":\"[main {hash}] fix bug\"}}\"#);\n   983→        let file = write_temp_file(dir.path(), \"session.jsonl\", &content);\n   984→\n   985→        let hashes = extract_commit_hashes(&file);\n   986→        assert_eq!(hashes.len(), 1);\n   987→        assert_eq!(hashes[0], hash);\n   988→    }\n   989→\n   990→    #[test]\n   991→    fn test_extract_commit_hashes_finds_multiple() {\n   992→        let dir = TempDir::new().unwrap();\n   993→        let content = r#\"{\"content\":\"[main abcdef0] first commit\"}\n   994→{\"content\":\"[main 1234567] second commit\"}\n   995→\"#;\n   996→        let file = write_temp_file(dir.path(), \"session.jsonl\", &content);\n   997→\n   998→        let hashes = extract_commit_hashes(&file);\n   999→        assert_eq!(hashes.len(), 2);\n  1000→        assert!(hashes.contains(&\"abcdef0\".to_string()));\n  1001→        assert!(hashes.contains(&\"1234567\".to_string()));\n  1002→    }\n  1003→\n  1004→    #[test]\n  1005→    fn test_extract_commit_hashes_deduplicates() {\n  1006→        let dir = TempDir::new().unwrap();\n  1007→        let content = r#\"{\"content\":\"[main abcdef0] fix bug\"}\n  1008→{\"content\":\"[main abcdef0] fix bug\"}\n  1009→\"#;\n  1010→        let file = write_temp_file(dir