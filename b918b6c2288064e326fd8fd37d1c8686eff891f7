t home = TempDir::new().unwrap();\n   362→        let dir = pending_dir_in(home.path()).unwrap();\n   363→\n   364→        let records = list_for_repo_in(&dir, \"/Users/foo/bar\").unwrap();\n   365→        assert!(records.is_empty());\n   366→    }\n   367→\n   368→    #[test]\n   369→    fn test_list_for_repo_filters_by_repo() {\n   370→        let home = TempDir::new().unwrap();\n   371→        let dir = pending_dir_in(home.path()).unwrap();\n   372→\n   373→        // Write records for two different repos\n   374→        write_pending_in(\n   375→            &dir,\n   376→            \"aaaaaaa0000000000000000000000000000000aa\",\n   377→            \"/repo/a\",\n   378→            100,\n   379→        )\n   380→        .unwrap();\n   381→        write_pending_in(\n   382→            &dir,\n   383→            \"bbbbbbb0000000000000000000000000000000bb\",\n   384→            \"/repo/b\",\n   385→            200,\n   386→        )\n   387→        .unwrap();\n   388→        write_pending_in(\n   389→            &dir,\n   390→            \"ccccccc0000000000000000000000000000000cc\",\n   391→            \"/repo/a\",\n   392→            300,\n   393→        )\n   394→        .unwrap();\n   395→\n   396→        let records_a = list_for_repo_in(&dir, \"/repo/a\").unwrap();\n   397→        assert_eq!(records_a.len(), 2);\n   398→\n   399→        let records_b = list_for_repo_in(&dir, \"/repo/b\").unwrap();\n   400→        assert_eq!(records_b.len(), 1);\n   401→        assert_eq!(\n   402→            records_b[0].commit,\n   403→            \"bbbbbbb0000000000000000000000000000000bb\"\n   404→        );\n   405→    }\n   406→\n   407→    #[test]\n   408→    fn test_list_for_repo_no_matching_repo() {\n   409→        let home = TempDir::new().unwrap();\n   410→        let dir = pending_dir_in(home.path()).unwrap();\n   411→\n   412→        write_pending_in(\n   413→            &dir,\n   414→            \"aaaaaaa0000000000000000000000000000000aa\",\n   415→            \"/repo/a\",\n   416→            100,\n   417→        )\n   418→        .unwrap();\n   419→\n   420→        let records = list_for_repo_in(&dir, \"/repo/nonexistent\").unwrap();\n   421→        assert!(records.is_empty());\n   422→    }\n   423→\n   424→    #[test]\n   425→    fn test_list_for_repo_skips_non_json_files() {\n   426→        let home = TempDir::new().unwrap();\n   427→        let dir = pending_dir_in(home.path()).unwrap();\n   428→\n   429→        // Write a valid record\n   430→        write_pending_in(\n   431→            &dir,\n   432→            \"aaaaaaa0000000000000000000000000000000aa\",\n   433→            \"/repo\",\n   434→            100,\n   435→        )\n   436→        .unwrap();\n   437→\n   438→        // Write a non-json file\n   439→        std::fs::write(dir.join(\"notes.txt\"), \"not a record\").unwrap();\n   440→\n   441→        // Write a .json.tmp file (should be ignored and cleaned up)\n   442→        let tmp_path = dir.join(\"leftover.json.tmp\");\n   443→        std::fs::write(&tmp_path, \"{}\").unwrap();\n   444→\n   445→        let records = list_for_repo_in(&dir, \"/repo\").unwrap();\n   446→        assert_eq!(records.len(), 1);\n   447→\n   448→        // The .json.tmp file should have been cleaned up\n   449→        assert!(\n   450→            !tmp_path.exists(),\n   451→            \"orphaned .json.tmp file should be cleaned up\"\n   452→        );\n   453→\n   454→        // The .txt file should NOT be cleaned up (only .json.tmp files)\n   455→        assert!(dir.join(\"notes.txt\").exists());\n   456→    }\n   457→\n   458→    #[test]\n   459→    fn test_list_for_repo_cleans_up_orphaned_tmp_files() {\n   460→        let home = TempDir::new().unwrap();\n   461→        let dir = pending_dir_in(home.path()).unwrap();\n   462→\n   463→        // Create multiple orphaned .json.tmp files\n   464→        let tmp1 = dir.join(\"abc1234.json.tmp\");\n   465→        let tmp2 = dir.join(\"def5678.json.tmp\");\n   466→        std::fs::write(&tmp1, r#\"{\"partial\":\"write\"}\"#).unwrap();\n   467→        std::fs::write(&tmp2, \"corrupted data\").unwrap();\n   468→\n   469→        assert!(tmp1.exists());\n   470→        assert!(tmp2.exists());\n   471→\n   472→        // Listing should clean them up\n   473→        let records = list_for_repo_in(&dir, \"/repo\").unwrap();\n   474→        assert!(records.is_empty());\n   475→\n   476→        assert!(!tmp1.exists(), \"first orphaned tmp should be removed\");\n   477→        assert!(!tmp2.exists(), \"second orphaned tmp should be removed\");\n   478→    }\n   479→\n   480→    #[test]\n   481→    fn test_list_for_repo_skips_invalid_json() {\n   482→        let home = TempDir::new().unwrap();\n   483→        let dir = pending_dir_in(home.path()).unwrap();\n   484→\n   485→        // Write a valid record\n   486→        write_pending_in(\n   487→            &dir,\n   488→            \"aaaaaaa0000000000000000000000000000000aa\",\n   489→            \"/repo\",\n   490→            100,\n   491→        )\n   492→        .unwrap();\n   493→\n   494→        // Write an invalid JSON file with .json extension\n   495→        std::fs::write(dir.join(\"corrupt.json\"), \"not valid json {{{{\").unwrap();\n   496→\n   497→        let records = list_for_repo_in(&dir, \"/repo\").unwrap();\n   498→        assert_eq!(records.len(), 1);\n   499→    }\n   500→\n   501→    #[test]\n   502→    fn test_list_for_repo_nonexistent_dir() {\n   503→        let dir = PathBuf::from(\"/nonexistent/dir/that/does/not/exist\");\n   504→        let records = list_for_repo_in(&dir, \"/repo\").unwrap();\n   505→        assert!(records.is_empty());\n   506→    }\n   507→\n   508→    // -----------------------------------------------------------------------\n   509→    // increment_in\n   510→    // -----------------------------------------------------------------------\n   511→\n   512→    #[test]\n   513→    fn test_increment_bumps_attempts() {\n   514→        let home = TempDir::new().unwrap();\n   515→        let dir = pending_dir_in(home.path()).unwrap();\n   516→        let commit = \"abcdef0123456789abcdef0123456789abcdef01\";\n   517→\n   518→        write_pending_in(&dir, commit, \"/repo\", 1_700_000_000).unwrap();\n   519→\n   520→        // Read it back\n   521→        let file_path = dir.join(format!(\"{}.json\", commit));\n   522→        let content = std::fs::read_to_string(&file_path).unwrap();\n   523→        let mut record: PendingRecord = serde_json::from_str(&content).unwrap();\n   524→        assert_eq!(record.attempts, 1);\n   525→\n   526→        let old_last_attempt = record.last_attempt;\n   527→\n   528→        // Increment\n   529→        increment_in(&dir, &mut record).unwrap();\n   530→\n   531→        assert_eq!(record.attempts, 2);\n   532→        assert!(record.last_attempt >= old_last_attempt);\n   533→\n   534→        // Verify the file on disk was updated\n   535→        let content2 = std::fs::read_to_string(&file_path).unwrap();\n   536→        let record2: PendingRecord = serde_json::from_str(&content2).unwrap();\n   537→        assert_eq!(record2.attempts, 2);\n   538→    }\n   539→\n   540→    #[test]\n   541→    fn test_increment_multiple_times() {\n   542→        let home = TempDir::new().unwrap();\n   543→        let dir = pending_dir_in(home.path()).unwrap();\n   544→        let commit = \"abcdef0123456789abcdef0123456789abcdef01\";\n   545→\n   546→        write_pending_in(&dir, commit, \"/repo\", 1_700_000_000).unwrap();\n   547→\n   548→        let file_path = dir.join(format!(\"{}.json\", commit));\n   549→        let content = std::fs::read_to_string(&file_path).unwrap();\n   550→        let mut record: PendingRecord = serde_json::from_str(&content).unwrap();\n   551→\n   552→        increment_in(&dir, &mut record).unwrap();\n   553→        increment_in(&dir, &mut record).unwrap();\n   554→        increment_in(&dir, &mut record).unwrap();\n   555→\n   556→        assert_eq!(record.attempts, 4); // 1 initial + 3 increments\n   557→\n   558→        // Verify disk\n   559→        let content2 = std::fs::read_to_string(&file_path).unwrap();\n   560→        let record2: PendingRecord = serde_json::from_str(&content2).unwrap();\n   561→        assert_eq!(record2.attempts, 4);\n   562→    }\n   563→\n   564→    #[test]\n   565→    fn test_increment_on_nonexistent_file_creates_it() {\n   566→        // If the on-disk file was deleted (e.g. by a concurrent remove) but\n   567→        // the in-memory record is still being iterated, increment should\n   568→        // handle this gracefully by creating the file anew rather than\n   569→        // panicking.\n   570→        let home = TempDir::new().unwrap();\n   571→        let dir = pending_dir_in(home.path()).unwrap();\n   572→        let commit = \"abcdef0123456789abcdef0123456789abcdef01\";\n   573→\n   574→        // Create a record in memory without writing it to disk first\n   575→        let mut record = PendingRecord {\n   576→            commit: commit.to_string(),\n   577→            repo: \"/repo\".to_string(),\n   578→            commit_time: 1_700_000_000,\n   579→            attempts: 1,\n   580→            last_attempt: 1_700_000_000,\n   581→        };\n   582→\n   583→        // The file does not exist on disk -- increment should still succeed\n   584→        let file_path = dir.join(format!(\"{}.json\", commit));\n   585→        assert!(!file_path.exists());\n   586→\n   587→        increment_in(&dir, &mut record).unwrap();\n   588→\n   589→        // The in-memory record should be updated\n   590→        assert_eq!(record.attempts, 2);\n   591→\n   592→        // A file should now exist on disk with the updated record\n   593→        assert!(file_path.exists());\n   594→        let content = std::fs::read_to_string(&file_path).unwrap();\n   595→        let disk_record: PendingRecord = serde_json::from_str(&content).unwrap();\n   596→        assert_eq!(disk_record.attempts, 2);\n   597→        assert_eq!(disk_record.commit, commit);\n   598→        assert_eq!(disk_record.repo, \"/repo\");\n   599→    }\n   600→\n   601→    #[test]\n   602→    fn test_increment_preserves_other_fields() {\n   603→        let home = TempDir::new().unwrap();\n   604→        let dir = pending_dir_in(home.path()).unwrap();\n   605→        let commit = \"abcdef0123456789abcdef0123456789abcdef01\";\n   606→\n   607→        write_pending_in(&dir, commit, \"/Users/foo/bar\", 1_700_000_000).unwrap();\n   608→\n   609→        let file_path = dir.join(format!(\"{}.json\", commit));\n   610→        let content = std::fs::read_to_string(&file_path).unwrap();\n   611→        let mut record: PendingRecord = serde_json::from_str(&content).unwrap();\n   612→\n   613→        increment_in(&dir, &mut record).unwrap();\n   614→\n   615→        assert_eq!(record.commit, commit);\n   616→        assert_eq!(record.repo, \"/Users/foo/bar\");\n   617→        assert_eq!(record.commit_time, 1_700_000_000);\n   618→    }\n   619→\n   620→    // -----------------------------------------------------------------------\n   621→    // remove_in\n   622→    // -----------------------------------------------------------------------\n   623→\n   624→    #[test]\n   625→    fn test_remove_deletes_file() {\n   626→        let home = TempDir::new().unwrap();\n   627→        let dir = pending_dir_in(home.path()).unwrap();\n   628→        let commit = \"abcdef0123456789abcdef0123456789abcdef01\";\n   629→\n   630→        write_pending_in(&dir, commit, \"/repo\", 1_700_000_000).unwrap();\n   631→        let file_path = dir.join(format!(\"{}.json\", commit));\n   632→        assert!(file_path.exists());\n   633→\n   634→        remove_in(&dir, commit).unwrap();\n   635→        assert!(!file_path.exists());\n   636→    }\n   637→\n   638→    #[test]\n   639→    fn test_remove_idempotent() {\n   640→        let home = TempDir::new().unwrap();\n   641→        let dir = pending_dir_in(home.path()).unwrap();\n   642→        let commit